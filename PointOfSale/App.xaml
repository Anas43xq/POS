<Application x:Class="UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xml:lang="en-AE">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- 0. Global TextBlock fallback: guarantees Foreground is
                        never DependencyProperty.UnsetValue, which crashes
                        the layout pass.  Uses a literal brush so there is
                        no dependency on later-loaded resource dictionaries.
                        Any explicit Foreground on a TextBlock or its style
                        takes precedence. -->
                <ResourceDictionary>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="#1F2937"/>
                    </Style>
                </ResourceDictionary>
                <!-- 1. Converters (no dependencies) -->
                <ResourceDictionary Source="Resources/Converters.xaml" />
                <!-- 2. Common layer — single source of truth for brand
                         palette, generic buttons, and reusable list/badge
                         components.  Loaded before any module dictionary. -->
                <ResourceDictionary Source="Resources/Common/Brushes.xaml" />
                <ResourceDictionary Source="Resources/Common/Buttons.xaml" />
                <ResourceDictionary Source="Resources/Common/Lists.xaml" />
                <!-- 3. Dashboard chrome (brushes, KPI tiles, card styles) -->
                <ResourceDictionary Source="Resources/DashboardChrome.xaml" />
                <!-- 4. Dialog chrome (modal styles) -->
                <ResourceDictionary Source="Resources/DialogChrome.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>