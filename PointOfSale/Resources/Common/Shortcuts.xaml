<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
        Shared keyboard shortcut key-cap styles used by both Cashier
        and Manager page headers. Moved from CashierDashboardView.xaml
        so all modules can reuse them without duplication.
    -->

    <!-- Keyboard shortcut key-cap (header strip) -->
    <Style x:Key="ShortcutKeyCap" TargetType="Border">
        <Setter Property="Background"      Value="#33FFFFFF"/>
        <Setter Property="BorderBrush"      Value="#55FFFFFF"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="CornerRadius"     Value="5"/>
        <Setter Property="Padding"          Value="7,3"/>
        <Setter Property="Margin"           Value="0,0,6,0"/>
    </Style>

    <Style x:Key="ShortcutKeyText" TargetType="TextBlock">
        <Setter Property="FontSize"     Value="13"/>
        <Setter Property="FontWeight"   Value="Bold"/>
        <Setter Property="Foreground"   Value="White"/>
    </Style>

    <Style x:Key="ShortcutLabelText" TargetType="TextBlock">
        <Setter Property="FontSize"     Value="13"/>
        <Setter Property="FontWeight"   Value="Medium"/>
        <Setter Property="Foreground"   Value="#EAF6FF"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="ShortcutChip" TargetType="StackPanel">
        <Setter Property="Orientation" Value="Horizontal"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,0,18,0"/>
    </Style>
</ResourceDictionary>
