<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
        Reusable list / grid surface components shared across modules
        (Manager list views primarily). Badge styles are used by both the
        Transactions list and Shift list. None of these are module-specific.
    -->

    <!-- Filter panel container — the toolbar/card that groups
         filter chips, period pickers, and action buttons at the top
         of a list view.  Matches the chrome of a list-view card. -->
    <Style x:Key="FilterPanel" TargetType="Border">
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="{StaticResource BrandBorder}"/>
        <Setter Property="BorderThickness" Value="0.5"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="12,9"/>
        <Setter Property="Margin" Value="0,0,0,10"/>
    </Style>

    <!-- Column-header cell text (any list view) -->
    <Style x:Key="ListHeaderCell" TargetType="TextBlock">
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
    </Style>

    <!-- Slim ScrollViewer used by the rows area -->
    <Style x:Key="ThinScrollViewer" TargetType="ScrollViewer">
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <!-- List row background / divider (unselected) -->
    <Style x:Key="ListRow" TargetType="Border">
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="#EFF6FF"/>
        <Setter Property="BorderThickness" Value="0,0,0,0.5"/>
    </Style>

    <!-- Selected list row — same divider, blue tint background. -->
    <Style x:Key="SelectedListRow" TargetType="Border" BasedOn="{StaticResource ListRow}">
        <Setter Property="Background" Value="{StaticResource RowSelectedBg}"/>
    </Style>

    <!-- Pill-shaped badge border (Payment / Status etc.) -->
    <Style x:Key="BadgeBase" TargetType="Border">
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="8,2"/>
        <Setter Property="Background" Value="#F1F5F9"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Text inside a badge -->
    <Style x:Key="BadgeText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="{StaticResource TextDark}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
</ResourceDictionary>