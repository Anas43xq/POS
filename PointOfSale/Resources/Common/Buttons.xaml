<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
        Generic application-wide buttons. These are not module-specific:
        OutlineBtn is used by Manager list views, DangerBtn by destructive
        actions across modules, and PrimaryGradientBtn by primary
        actions. Module-specific buttons (Manager HdrBtn, Cashier
        ProductBtn, Dialog SaveBtn) remain in their owning layers.
    -->

    <!-- Outline button (Refresh / Previous / Delete etc.) -->
    <Style x:Key="OutlineBtn" TargetType="Button">
        <Setter Property="Height" Value="28"/>
        <Setter Property="Padding" Value="14,0"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="{StaticResource BrandDark}"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="{StaticResource BrandBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
    </Style>

    <!-- Danger button (Void / Delete / Remove — destructive actions) -->
    <Style x:Key="DangerBtn" TargetType="Button">
        <Setter Property="Height" Value="28"/>
        <Setter Property="Padding" Value="14,0"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Background" Value="{StaticResource DangerMid}"/>
        <Setter Property="BorderBrush" Value="{StaticResource DangerDark}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
    </Style>

    <!-- Primary gradient button (Next / apply actions) -->
    <Style x:Key="PrimaryGradientBtn" TargetType="Button">
        <Setter Property="Height" Value="28"/>
        <Setter Property="Padding" Value="18,0"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Background" Value="{StaticResource BrandMid}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
    </Style>
</ResourceDictionary>