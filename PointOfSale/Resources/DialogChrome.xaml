<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="ModalBrandDark" Color="#1A6FC4"/>
    <SolidColorBrush x:Key="ModalBrandLight" Color="#F0F7FF"/>
    <SolidColorBrush x:Key="ModalBrandBorder" Color="#B8D8F5"/>
    <SolidColorBrush x:Key="ModalTextDark" Color="#1A3A5C"/>
    <SolidColorBrush x:Key="ModalTextMuted" Color="#8AB0CC"/>
    <SolidColorBrush x:Key="ModalErrorFg" Color="#A32D2D"/>
    <SolidColorBrush x:Key="ModalErrorBg" Color="#FFF0F0"/>
    <SolidColorBrush x:Key="ModalErrorBorder" Color="#F5C1C1"/>

    <Style x:Key="ModalCardBorder" TargetType="Border">
        <Setter Property="CornerRadius" Value="14"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="{StaticResource ModalBrandBorder}"/>
        <Setter Property="BorderThickness" Value="0.5"/>
    </Style>

    <Style x:Key="ModalHeaderBorder" TargetType="Border">
        <Setter Property="CornerRadius" Value="14,14,0,0"/>
        <Setter Property="Background" Value="{StaticResource ModalBrandLight}"/>
        <Setter Property="BorderBrush" Value="#E8F3FF"/>
        <Setter Property="BorderThickness" Value="0,0,0,0.5"/>
    </Style>

    <Style x:Key="ModalFooterBorder" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource ModalBrandLight}"/>
        <Setter Property="BorderBrush" Value="{StaticResource ModalBrandBorder}"/>
        <Setter Property="BorderThickness" Value="0,0.5,0,0"/>
    </Style>

    <Style x:Key="ModalCloseButton" TargetType="Button">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{StaticResource ModalTextMuted}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
    </Style>

    <Style x:Key="ModalLabel" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="{StaticResource ModalBrandDark}"/>
    </Style>

    <Style x:Key="ModalInputBorder" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource ModalBrandLight}"/>
        <Setter Property="BorderBrush" Value="{StaticResource ModalBrandBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>
</ResourceDictionary>
