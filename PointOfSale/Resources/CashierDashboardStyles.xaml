<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:UI.Controls">

    <!-- =====================================================================
         DESIGN TOKENS
         Radius scale : 12 = cards / panels, 9 = primary buttons, 7 = inputs & chips, 6 = small tabs
         Spacing scale: 4, 8, 12, 16, 20
         ===================================================================== -->

    <!-- Palette (unchanged values from the original view, centralized here) -->
    <SolidColorBrush x:Key="BrandDark"   Color="#1A6FC4"/>
    <SolidColorBrush x:Key="BrandMid"    Color="#2589E0"/>
    <SolidColorBrush x:Key="BrandLight"  Color="#F0F7FF"/>
    <SolidColorBrush x:Key="BrandBorder" Color="#B8D8F5"/>
    <SolidColorBrush x:Key="BrandIcon"   Color="#5BAAE0"/>
    <SolidColorBrush x:Key="PageBg"      Color="#EAF4FF"/>
    <SolidColorBrush x:Key="CardBg"      Color="#FFFFFF"/>
    <SolidColorBrush x:Key="CardHdrBg"   Color="#F0F7FF"/>
    <!-- Renamed from TotalSummaryBg: the pending running total should not read as
         "already paid" - green is reserved for post-payment / success states
         (Start Day button, PayCash button) elsewhere in this app. -->
    <SolidColorBrush x:Key="TotalSummaryBg" Color="#F0F7FF"/>
    <SolidColorBrush x:Key="TextDark"    Color="#1A3A5C"/>
    <SolidColorBrush x:Key="TextMuted"   Color="#5B8AB0"/>
    <SolidColorBrush x:Key="SuccessGreen" Color="#16A34A"/>
    <SolidColorBrush x:Key="FooterBg"    Color="#1A6FC4"/>
    <SolidColorBrush x:Key="ModifierChipBg" Color="#F0F7FF"/>
    <SolidColorBrush x:Key="ModifierChipBorder" Color="#B8D8F5"/>

    <!-- =====================================================================
         CARDS
         ===================================================================== -->

    <Style x:Key="CardBorder" TargetType="Border">
        <Setter Property="Background"      Value="{StaticResource CardBg}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource BrandBorder}"/>
        <Setter Property="BorderThickness" Value="0.5"/>
        <Setter Property="CornerRadius"    Value="12"/>
    </Style>

    <Style x:Key="CardHeaderBorder" TargetType="Border">
        <Setter Property="Background"      Value="{StaticResource CardHdrBg}"/>
        <Setter Property="BorderBrush"     Value="#E8F3FF"/>
        <Setter Property="BorderThickness" Value="0,0,0,0.5"/>
        <Setter Property="Padding"         Value="12,10"/>
    </Style>

    <Style x:Key="PanelTitle" TargetType="TextBlock">
        <Setter Property="FontSize"          Value="13"/>
        <Setter Property="FontWeight"        Value="Medium"/>
        <Setter Property="Foreground"        Value="{StaticResource TextDark}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="CountBadge" TargetType="Border">
        <Setter Property="Background"        Value="#DBEEFF"/>
        <Setter Property="BorderBrush"       Value="{StaticResource BrandBorder}"/>
        <Setter Property="BorderThickness"   Value="1"/>
        <Setter Property="CornerRadius"      Value="6"/>
        <Setter Property="Padding"           Value="8,2"/>
        <Setter Property="Margin"            Value="8,0,0,0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- =====================================================================
         BUTTONS
         SolidActionBtn is the single shared template for every solid-fill
         action button (header Start/End Day, footer Cash/Card). Background is
         supplied per-instance via Button.Background and read back through
         TemplateBinding, so hover/press states work identically for every
         color without duplicating the ControlTemplate. This replaces five
         near-identical hand-written templates from the original file.
         ===================================================================== -->

    <Style x:Key="SolidActionBtn" TargetType="Button">
        <Setter Property="Foreground"        Value="White"/>
        <Setter Property="BorderThickness"   Value="0"/>
        <Setter Property="Cursor"            Value="Hand"/>
        <Setter Property="FocusVisualStyle"  Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg"
                            CornerRadius="9"
                            Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Opacity" Value="0.90"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bg" Property="Opacity" Value="0.80"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bg" Property="Opacity" Value="0.45"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Bg" Property="BorderBrush"     Value="White"/>
                            <Setter TargetName="Bg" Property="BorderThickness" Value="2"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Primary brand button (kept for spots that used PrimaryBtn / Settings icon button) -->
    <Style x:Key="PrimaryBtn" TargetType="Button" BasedOn="{StaticResource SolidActionBtn}">
        <Setter Property="Background" Value="{StaticResource BrandDark}"/>
    </Style>

    <!-- Header icon / action buttons (Settings, Start Day, End Day) -->
    <Style x:Key="HdrBtn" TargetType="Button" BasedOn="{StaticResource SolidActionBtn}">
        <Setter Property="Height"     Value="34"/>
        <Setter Property="Padding"    Value="14,0"/>
        <Setter Property="FontSize"   Value="11"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Background" Value="{StaticResource BrandDark}"/>
    </Style>

    <!-- Danger (logout) button - reuses SolidActionBtn, Background set to DangerRed
         which is provided by the app-level resource dictionary (unchanged). -->
    <Style x:Key="HdrDangerBtn" TargetType="Button" BasedOn="{StaticResource HdrBtn}">
        <Setter Property="Background" Value="{DynamicResource DangerRed}"/>
    </Style>

    <!-- Footer payment buttons (Cash / Card) -->
    <Style x:Key="FooterPayBtn" TargetType="Button" BasedOn="{StaticResource SolidActionBtn}">
        <Setter Property="Width"  Value="130"/>
        <Setter Property="Height" Value="56"/>
    </Style>

    <!-- Ghost footer button (Clear Sale) -->
    <Style x:Key="FooterGhostBtn" TargetType="Button">
        <Setter Property="Height"            Value="56"/>
        <Setter Property="Padding"           Value="18,0"/>
        <Setter Property="FontSize"          Value="12"/>
        <Setter Property="FontWeight"        Value="Medium"/>
        <Setter Property="Foreground"        Value="White"/>
        <Setter Property="Cursor"            Value="Hand"/>
        <Setter Property="FocusVisualStyle"  Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg"
                            CornerRadius="9"
                            Background="Transparent"
                            BorderBrush="#60FFFFFF"
                            BorderThickness="1.5">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="#20FFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bg" Property="Opacity" Value="0.4"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Bg" Property="BorderBrush"     Value="White"/>
                            <Setter TargetName="Bg" Property="BorderThickness" Value="2"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Category tab -->
    <Style x:Key="CategoryBtn" TargetType="Button">
        <Setter Property="Height"           Value="32"/>
        <Setter Property="Padding"          Value="14,0"/>
        <Setter Property="Margin"           Value="0,0,6,0"/>
        <Setter Property="FontSize"         Value="12"/>
        <Setter Property="FontWeight"       Value="Medium"/>
        <Setter Property="Cursor"           Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg"
                            CornerRadius="7"
                            Background="#F0F7FF"
                            BorderBrush="{StaticResource BrandBorder}"
                            BorderThickness="1">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background"  Value="#DBEEFF"/>
                            <Setter TargetName="Bg" Property="BorderBrush" Value="{StaticResource BrandDark}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="#DBEEFF"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Bg" Property="BorderBrush"     Value="{StaticResource BrandDark}"/>
                            <Setter TargetName="Bg" Property="BorderThickness" Value="2"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SubCategoryBtn" TargetType="Button" BasedOn="{StaticResource CategoryBtn}">
        <Setter Property="Height"   Value="26"/>
        <Setter Property="Padding"  Value="12,0"/>
        <Setter Property="Margin"   Value="0,0,5,0"/>
        <Setter Property="FontSize" Value="11"/>
    </Style>

    <!-- Product card - taller than the original 76px for a firmer touch target -->
    <Style x:Key="ProductBtn" TargetType="Button">
        <Setter Property="Height"              Value="84"/>
        <Setter Property="Margin"              Value="4"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="VerticalAlignment"   Value="Stretch"/>
        <Setter Property="Cursor"              Value="Hand"/>
        <Setter Property="FocusVisualStyle"    Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg"
                            CornerRadius="9"
                            Background="{StaticResource CardBg}"
                            BorderBrush="{StaticResource BrandBorder}"
                            BorderThickness="1">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background"  Value="#F0F7FF"/>
                            <Setter TargetName="Bg" Property="BorderBrush" Value="{StaticResource BrandDark}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="#DBEEFF"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Bg" Property="BorderBrush"     Value="{StaticResource BrandDark}"/>
                            <Setter TargetName="Bg" Property="BorderThickness" Value="2"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Quick-action tile -->
    <Style x:Key="QuickActionBtn" TargetType="Button">
        <Setter Property="Height"              Value="76"/>
        <Setter Property="Margin"              Value="6,0,6,6"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="Cursor"              Value="Hand"/>
        <Setter Property="FocusVisualStyle"    Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg"
                            CornerRadius="9"
                            Background="#F0F7FF"
                            BorderBrush="{StaticResource BrandBorder}"
                            BorderThickness="1">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background"  Value="#DBEEFF"/>
                            <Setter TargetName="Bg" Property="BorderBrush" Value="{StaticResource BrandDark}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="#DBEEFF"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bg" Property="Opacity" Value="0.45"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Bg" Property="BorderBrush"     Value="{StaticResource BrandDark}"/>
                            <Setter TargetName="Bg" Property="BorderThickness" Value="2"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Modifier chip (forward-compatible with the future modifier system) -->
    <Style x:Key="ModifierChipBtn" TargetType="Button">
        <Setter Property="Height"           Value="52"/>
        <Setter Property="MinWidth"         Value="130"/>
        <Setter Property="Margin"           Value="0,0,8,8"/>
        <Setter Property="Padding"          Value="14,0"/>
        <Setter Property="Cursor"           Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg"
                            CornerRadius="9"
                            Background="{StaticResource ModifierChipBg}"
                            BorderBrush="{StaticResource ModifierChipBorder}"
                            BorderThickness="1">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background"  Value="#DBEEFF"/>
                            <Setter TargetName="Bg" Property="BorderBrush" Value="{StaticResource BrandDark}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="#DBEEFF"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- =====================================================================
         DATAGRID (Cart)
         ===================================================================== -->

    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background"                Value="#F0F7FF"/>
        <Setter Property="Foreground"                Value="{StaticResource TextMuted}"/>
        <Setter Property="FontSize"                  Value="10"/>
        <Setter Property="FontWeight"                Value="Medium"/>
        <Setter Property="Padding"                   Value="10,8"/>
        <Setter Property="BorderBrush"               Value="{StaticResource BrandBorder}"/>
        <Setter Property="BorderThickness"           Value="0,0,0,0.5"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
    </Style>

    <Style TargetType="DataGridRow">
        <Setter Property="BorderBrush"     Value="#F0F7FF"/>
        <Setter Property="BorderThickness" Value="0,0,0,0.5"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#F8FCFF"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#DBEEFF"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="DataGridCell">
        <Setter Property="BorderThickness"   Value="0"/>
        <Setter Property="Padding"           Value="10,0"/>
        <Setter Property="FontSize"          Value="12"/>
        <Setter Property="Foreground"        Value="{StaticResource TextDark}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource TextDark}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Larger, centered touch target for the editable Quantity cell -->
    <Style x:Key="QtyDisplayText" TargetType="TextBlock">
        <Setter Property="TextAlignment"       Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment"   Value="Center"/>
        <Setter Property="FontSize"            Value="13"/>
        <Setter Property="FontWeight"          Value="Medium"/>
    </Style>

    <Style x:Key="QtyEditText" TargetType="TextBox">
        <Setter Property="TextAlignment"        Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="FontSize"             Value="14"/>
        <Setter Property="MinHeight"            Value="40"/>
    </Style>

    <!-- Remove-item button, sized to a real touch target (was 13px glyph, no min hit area) -->
    <Style x:Key="RemoveItemBtn" TargetType="Button">
        <Setter Property="Width"                Value="40"/>
        <Setter Property="Height"               Value="40"/>
        <Setter Property="Background"           Value="Transparent"/>
        <Setter Property="BorderThickness"      Value="0"/>
        <Setter Property="Cursor"               Value="Hand"/>
        <Setter Property="FocusVisualStyle"     Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg" CornerRadius="7" Background="Transparent">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="#FCE8E8"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Modifier line inside cart RowDetails (scaffold, inert until the
         modifier system exists - RowDetailsVisibilityMode is Collapsed by
         default on the DataGrid so this template never renders today). -->
    <Style x:Key="CartModifierLine" TargetType="TextBlock">
        <Setter Property="FontSize"   Value="11"/>
        <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
        <Setter Property="Margin"     Value="0,2,0,0"/>
    </Style>

    <!-- =====================================================================
         CURRENCY TEXT
         ===================================================================== -->

    <Style x:Key="CurrencyTextStyle" TargetType="controls:CurrencyText">
        <Setter Property="FontSize"           Value="12"/>
        <Setter Property="FontWeight"         Value="Medium"/>
        <Setter Property="Foreground"         Value="{StaticResource TextDark}"/>
        <Setter Property="HorizontalAlignment" Value="Right"/>
    </Style>

    <Style x:Key="CurrencyTextStyleLarge" TargetType="controls:CurrencyText">
        <Setter Property="FontSize"           Value="24"/>
        <Setter Property="FontWeight"         Value="Medium"/>
        <Setter Property="Foreground"         Value="{StaticResource BrandDark}"/>
        <Setter Property="HorizontalAlignment" Value="Right"/>
    </Style>

    <Style x:Key="CurrencyTextStyleWhite" TargetType="controls:CurrencyText">
        <Setter Property="FontSize"           Value="15"/>
        <Setter Property="FontWeight"         Value="Medium"/>
        <Setter Property="Foreground"         Value="White"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
    </Style>

</ResourceDictionary>
