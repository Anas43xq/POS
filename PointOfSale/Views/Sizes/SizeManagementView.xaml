<UserControl x:Class="UI.Views.SizeManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignWidth="1200" d:DesignHeight="820"
             Background="#F5F6FA">

    <UserControl.Resources>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- Toolbar -->
            <RowDefinition Height="*"/>
            <!-- Content -->
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Sizes"
                       FontSize="18" FontWeight="Medium"
                       Foreground="{StaticResource TextDark}"
                       VerticalAlignment="Center"/>

        </Grid>
        <!-- Toolbar -->
        <Border Grid.Row="1"
                Background="White"
                BorderBrush="{StaticResource BrandBorder}"
                BorderThickness="0.5"
                CornerRadius="10"
                Padding="12,9"
                Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <Button Margin="0,0,6,0" Command="{Binding AddCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="＋  " FontSize="13" Foreground="White"/>
                        <TextBlock Text="Add" FontSize="12" FontWeight="Medium" Foreground="White"/>
                    </StackPanel>
                </Button>

                <Button Margin="0,0,6,0"
                        IsEnabled="{Binding HasSelection}"
                        Command="{Binding EditCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✏  " FontSize="12"/>
                        <TextBlock Text="Edit" FontSize="12"/>
                    </StackPanel>
                </Button>

                <Button Margin="0,0,6,0"
                        IsEnabled="{Binding HasSelection}"
                        Command="{Binding DeleteCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🗑  " FontSize="12" Foreground="{StaticResource DangerRed}"/>
                        <TextBlock Text="Delete" FontSize="12" Foreground="{StaticResource DangerRed}"/>
                    </StackPanel>
                </Button>

                <Button Margin="0,0,6,0"
                        IsEnabled="{Binding HasSelection}"
                        Command="{Binding TranslationsCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🌐  " FontSize="12"/>
                        <TextBlock Text="Translations" FontSize="12"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding RefreshCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔄  " FontSize="12"/>
                        <TextBlock Text="Refresh" FontSize="12"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- Size Table -->
            <Border Grid.Column="0"
                    Background="White"
                    BorderBrush="{StaticResource BrandBorder}"
                    BorderThickness="0.5"
                    CornerRadius="10"
                    Padding="12">
                <DataGrid AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserResizeRows="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          ItemsSource="{Binding Sizes}"
                          SelectedItem="{Binding SelectedSize, Mode=TwoWay}"
                          HeadersVisibility="Column"
                          AlternatingRowBackground="#F9FBFF"
                          GridLinesVisibility="Horizontal">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*"/>
                        <DataGridTextColumn Header="Display Order" Binding="{Binding DisplayOrder}" Width="1*"/>
                        <DataGridTextColumn Header="Active" Binding="{Binding Status}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Edit Panel -->
            <Border Grid.Column="2"
                    Background="White"
                    BorderBrush="{StaticResource BrandBorder}"
                    BorderThickness="0.5"
                    CornerRadius="10"
                    Padding="16"
                    Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="Size Details"
                               FontSize="14" FontWeight="Medium"
                               Foreground="{StaticResource TextDark}"
                               Margin="0,0,0,14"/>

                    <!-- Error -->
                    <Border Background="#FEE2E2"
                            BorderBrush="#FECACA"
                            BorderThickness="1" CornerRadius="7"
                            Padding="10,8" Margin="0,0,0,12"
                            Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="{Binding ErrorMessage}"
                                   FontSize="11" Foreground="#DC2626"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <!-- Name -->
                    <TextBlock Text="Name" FontSize="11" FontWeight="Medium"
                               Foreground="{StaticResource BrandDark}" Margin="0,0,0,4"/>
                    <Border Background="{StaticResource BrandLight}"
                            BorderBrush="{StaticResource BrandBorder}"
                            BorderThickness="1" CornerRadius="7"
                            Height="34" Margin="0,0,0,12">
                        <TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                                 Background="Transparent" BorderThickness="0"
                                 FontSize="12" Foreground="{StaticResource TextDark}"
                                 VerticalContentAlignment="Center" Padding="9,0"/>
                    </Border>

                    <!-- Display Order -->
                    <TextBlock Text="Display Order" FontSize="11" FontWeight="Medium"
                               Foreground="{StaticResource BrandDark}" Margin="0,0,0,4"/>
                    <Border Background="{StaticResource BrandLight}"
                            BorderBrush="{StaticResource BrandBorder}"
                            BorderThickness="1" CornerRadius="7"
                            Height="34" Margin="0,0,0,12">
                        <TextBox Text="{Binding EditDisplayOrder, UpdateSourceTrigger=PropertyChanged}"
                                 Background="Transparent" BorderThickness="0"
                                 FontSize="12" Foreground="{StaticResource TextDark}"
                                 VerticalContentAlignment="Center" Padding="9,0"/>
                    </Border>

                    <!-- Active -->
                    <Border Background="{StaticResource BrandLight}"
                            BorderBrush="{StaticResource BrandBorder}"
                            BorderThickness="1" CornerRadius="7"
                            Height="34" Margin="0,0,0,16" Padding="9,0">
                        <CheckBox Content="Is active"
                                  IsChecked="{Binding EditIsActive}"
                                  FontSize="12" Foreground="{StaticResource TextDark}"
                                  VerticalAlignment="Center"/>
                    </Border>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel" Margin="0,0,8,0"
                                Command="{Binding CancelEditCommand}"/>
                        <Button Content="Save" Command="{Binding SaveCommand}">
                            <Button.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1A6FC4" Offset="0"/>
                                    <GradientStop Color="#2589E0" Offset="1"/>
                                </LinearGradientBrush>
                            </Button.Background>
                            <Button.Foreground>
                                <SolidColorBrush Color="White"/>
                            </Button.Foreground>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>