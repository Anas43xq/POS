<Window x:Class="UI.Views.EditShortcutDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="Edit Shortcut"
        Width="420" Height="340"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/DialogChrome.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="FieldLabel" TargetType="TextBlock">
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="Foreground" Value="{StaticResource BrandDark}"/>
                <Setter Property="Margin" Value="0,0,0,4"/>
            </Style>

            <Style x:Key="SaveBtn" TargetType="Button">
                <Setter Property="Height" Value="34"/>
                <Setter Property="Padding" Value="20,0"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" CornerRadius="7">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#1A6FC4" Offset="0"/>
                                        <GradientStop Color="#2589E0" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Opacity" Value="0.9"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bg" Property="Opacity" Value="0.8"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bg" Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="CancelBtn" TargetType="Button">
                <Setter Property="Height" Value="34"/>
                <Setter Property="Padding" Value="20,0"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" CornerRadius="7" Background="White"
                                    BorderBrush="{StaticResource BrandBorder}"
                                    BorderThickness="1.5">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#F0F7FF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid x:Name="OverlayGrid"
          Background="#55000000"
          MouseDown="OverlayGrid_MouseDown">

        <Border x:Name="DialogCard"
                Width="380"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Style="{StaticResource ModalCardBorder}"
                MouseDown="DialogCard_MouseDown">
            <Border.Effect>
                <DropShadowEffect BlurRadius="28" ShadowDepth="6"
                                  Direction="270" Opacity="0.13" Color="#1A3A5C"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- HEADER -->
                <Border Grid.Row="0"
                        Style="{StaticResource ModalHeaderBorder}"
                        Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="28" Height="28" CornerRadius="7"
                                    Background="{StaticResource ModalBrandDark}"
                                    Margin="0,0,9,0">
                                <TextBlock Text="⌨" FontSize="14"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Edit Shortcut"
                                       FontSize="13" FontWeight="Medium"
                                       Foreground="{StaticResource ModalTextDark}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Content="&#x2715;" FontSize="13"
                                Style="{StaticResource ModalCloseButton}"
                                Command="{Binding CloseCommand}"/>
                    </Grid>
                </Border>

                <!-- ERROR BANNER -->
                <Border Grid.Row="1"
                        Background="{StaticResource ModalErrorBg}"
                        BorderBrush="{StaticResource ModalErrorBorder}"
                        BorderThickness="1" CornerRadius="7"
                        Padding="11,8" Margin="16,10,16,0"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#x26A0; " FontSize="13" Foreground="{StaticResource ModalErrorFg}"/>
                        <TextBlock Text="{Binding ErrorMessage}"
                                   FontSize="11" Foreground="{StaticResource ModalErrorFg}"
                                   TextWrapping="Wrap" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- CONFLICT WARNING -->
                <Border Grid.Row="2"
                        Background="#FEF3C7"
                        BorderBrush="#FCD34D"
                        BorderThickness="1" CornerRadius="7"
                        Padding="11,8" Margin="16,10,16,0"
                        Visibility="{Binding HasConflict, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="&#x26A0; Conflict Detected"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="#92400E" Margin="0,0,0,4"/>
                        <TextBlock FontSize="11" Foreground="#92400E" TextWrapping="Wrap">
                            <Run Text="This shortcut is already assigned to: "/>
                            <Run Text="{Binding Conflict.ExistingAction, Mode=OneWay}" FontWeight="SemiBold"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- ACTION NAME -->
                <StackPanel Grid.Row="3" Margin="16,16,16,0">
                    <TextBlock Text="Action" Style="{StaticResource FieldLabel}"/>
                    <TextBlock Text="{Binding ActionName}"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextDark}"/>
                </StackPanel>

                <!-- CURRENT SHORTCUT -->
                <StackPanel Grid.Row="4" Margin="16,12,16,0">
                    <TextBlock Text="Current Shortcut" Style="{StaticResource FieldLabel}"/>
                    <Border Background="{StaticResource BrandLight}"
                            BorderBrush="{StaticResource BrandBorder}"
                            BorderThickness="1" CornerRadius="7"
                            Height="36" Padding="12,0">
                        <TextBlock Text="{Binding CurrentGesture}"
                                   FontSize="13" FontWeight="Medium"
                                   Foreground="{StaticResource TextDark}"
                                   VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>

                <!-- NEW SHORTCUT -->
                <StackPanel Grid.Row="5" Margin="16,12,16,0">
                    <TextBlock Text="New Shortcut" Style="{StaticResource FieldLabel}"/>
                    <Border Background="{StaticResource BrandLight}"
                            BorderBrush="{StaticResource BrandBorder}"
                            BorderThickness="1" CornerRadius="7"
                            Height="36" Padding="12,0">
                        <Grid>
                            <TextBlock Text="{Binding NewGesture}"
                                       FontSize="13" FontWeight="Medium"
                                       Foreground="{StaticResource TextDark}"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding HasNewGesture, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            <TextBlock Text="{Binding CapturePrompt}"
                                       FontSize="12"
                                       Foreground="{StaticResource TextMuted}"
                                       VerticalAlignment="Center"
                                       FontStyle="Italic"
                                       Visibility="{Binding IsCapturing, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- FOOTER -->
                <Border Grid.Row="6"
                        Style="{StaticResource ModalFooterBorder}"
                        CornerRadius="0,0,14,14"
                        Padding="16,12">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource CancelBtn}"
                                Content="Cancel"
                                Margin="0,0,8,0"
                                Command="{Binding CloseCommand}"/>
                        <Button Style="{StaticResource SaveBtn}"
                                Content="Start Capture"
                                Margin="0,0,8,0"
                                Command="{Binding StartCaptureCommand}"
                                Visibility="{Binding IsCapturing, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                        <Button Style="{StaticResource CancelBtn}"
                                Content="Cancel Capture"
                                Margin="0,0,8,0"
                                Command="{Binding CancelCaptureCommand}"
                                Visibility="{Binding IsCapturing, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        <Button Style="{StaticResource SaveBtn}"
                                Content="Save"
                                Command="{Binding SaveCommand}"
                                Visibility="{Binding HasNewGesture, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
