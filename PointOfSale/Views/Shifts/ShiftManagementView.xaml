<!--
    ╔══════════════════════════════════════════════════════╗
    ║   Cafeteria Hawa POS  –  Manager · Shift Management  ║
    ║   Filter bar + dense shift list + pagination          ║
    ╚══════════════════════════════════════════════════════╝
-->
<UserControl x:Class="UI.Views.ShiftManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:UI.Controls"
             mc:Ignorable="d"
             d:DesignWidth="1420" d:DesignHeight="820">

    <Grid Background="#EAF4FF">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Filter bar -->
            <RowDefinition Height="*"/>
            <!-- Table card -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════
             FILTER BAR
             ══════════════════════════════════════ -->
        <Border Grid.Row="0" Style="{StaticResource FilterPanel}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <RadioButton Style="{StaticResource FilterChip}" Content="{DynamicResource Common.Day}"
                                 IsChecked="True"
                                 GroupName="ShiftFilter"
                                 Command="{Binding LoadDayCommand}"/>
                    <RadioButton Style="{StaticResource FilterChip}" Content="{DynamicResource Common.Week}"
                                 GroupName="ShiftFilter"
                                 Command="{Binding LoadWeekCommand}"/>
                    <RadioButton Style="{StaticResource FilterChip}" Content="{DynamicResource Common.Month}"
                                 GroupName="ShiftFilter"
                                 Command="{Binding LoadMonthCommand}"/>
                    <RadioButton Style="{StaticResource FilterChip}" Content="{DynamicResource Common.Period}"
                                 GroupName="ShiftFilter"
                                 Command="{Binding LoadPeriodCommand}"/>

                    <controls:PeriodFilterPanel FilterVisibility="{Binding IsPeriodFilterVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                                                FromDate="{Binding FromDate, Mode=TwoWay}"
                                                ToDate="{Binding ToDate, Mode=TwoWay}"
                                                ApplyCommand="{Binding ApplyPeriodCommand}"
                                                FromLabel="{DynamicResource Common.From}"
                                                ToLabel="{DynamicResource Common.To}"
                                                ApplyButtonText="{DynamicResource Common.Apply}"
                                                Margin="6,0,0,0"/>

                    <!-- Status filter (Open / Closed / All) -->
                    <TextBlock Text="{DynamicResource Manager.Shifts.StatusFilter}"
                               VerticalAlignment="Center"
                               Margin="12,0,4,0"
                               FontSize="11"
                               Foreground="{StaticResource TextMuted}"/>
                    <ComboBox Width="110"
                              Height="26"
                              FontSize="11"
                              VerticalContentAlignment="Center"
                              ItemsSource="{Binding ShiftStatusFilterOptions}"
                              SelectedItem="{Binding SelectedShiftStatusFilter, Mode=TwoWay}"
                              DisplayMemberPath="Label"/>

                </StackPanel>

                <!-- Refresh -->
                <Button Grid.Column="1"
                        Style="{StaticResource OutlineBtn}"
                        Content="{DynamicResource Common.Refresh}"
                        Command="{Binding RefreshCommand}"/>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════
             SHIFTS TABLE CARD
             ══════════════════════════════════════ -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- header -->
                    <RowDefinition Height="*"/>
                    <!-- grid -->
                    <RowDefinition Height="Auto"/>
                    <!-- pager -->
                </Grid.RowDefinitions>

                <!-- Card header -->
                <Border Grid.Row="0" Style="{StaticResource CardHeaderBorder}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{DynamicResource Manager.Shifts.CardTitle}" Style="{StaticResource CardTitle}"/>
                        <TextBlock Grid.Column="1"
                                   Text="{DynamicResource Manager.Shifts.Loading}"
                                   FontSize="11"
                                   Foreground="{StaticResource TextMuted}"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </Grid>
                </Border>

                <!-- Column headings + scrollable rows -->
                <Grid Grid.Row="1" Grid.IsSharedSizeScope="True">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Column headings -->
                    <Border Grid.Row="0"
                            Background="{StaticResource CardHdrBg}"
                            BorderBrush="{StaticResource BrandBorder}"
                            BorderThickness="0,0,0,0.5">
                        <Grid Margin="16,10,16,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="Col0"/>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="Col1"/>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="Col2"/>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="Col3"/>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="Col4"/>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="Col5"/>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="Col6"/>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="Col7"/>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="Col8"/>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="Col9"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{DynamicResource Manager.Shifts.ColShiftId}"   Style="{StaticResource ListHeaderCell}" Margin="0,0,20,0"/>
                            <TextBlock Grid.Column="1" Text="{DynamicResource Manager.Shifts.ColCashier}"    Style="{StaticResource ListHeaderCell}" Margin="0,0,20,0"/>
                            <TextBlock Grid.Column="2" Text="{DynamicResource Manager.Shifts.ColOpenedAt}"  Style="{StaticResource ListHeaderCell}" Margin="0,0,20,0"/>
                            <TextBlock Grid.Column="3" Text="{DynamicResource Manager.Shifts.ColClosedAt}"  Style="{StaticResource ListHeaderCell}" Margin="0,0,20,0"/>
                            <TextBlock Grid.Column="4" Text="{DynamicResource Manager.Shifts.ColOpening}"    Style="{StaticResource ListHeaderCell}" Margin="0,0,20,0"/>
                            <TextBlock Grid.Column="5" Text="{DynamicResource Manager.Shifts.ColClosing}"    Style="{StaticResource ListHeaderCell}" Margin="0,0,20,0"/>
                            <TextBlock Grid.Column="6" Text="{DynamicResource Manager.Shifts.ColExpected}"   Style="{StaticResource ListHeaderCell}" Margin="0,0,20,0"/>
                            <TextBlock Grid.Column="7" Text="{DynamicResource Manager.Shifts.ColDifference}" Style="{StaticResource ListHeaderCell}" Margin="0,0,20,0"/>
                            <TextBlock Grid.Column="8" Text="{DynamicResource Manager.Shifts.ColStatus}"     Style="{StaticResource ListHeaderCell}" Margin="0,0,20,0"/>
                            <TextBlock Grid.Column="9" Text="{DynamicResource Manager.Shifts.ColDuration}"   Style="{StaticResource ListHeaderCell}"/>
                        </Grid>
                    </Border>

                    <!-- Scrollable rows -->
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding ShiftsView}">
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="MinHeight" Value="40"/>
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White" BorderBrush="#EFF6FF" BorderThickness="0,0,0,0.5">
                                    <Grid Margin="16,8,16,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" SharedSizeGroup="Col0"/>
                                            <ColumnDefinition Width="Auto" SharedSizeGroup="Col1"/>
                                            <ColumnDefinition Width="Auto" SharedSizeGroup="Col2"/>
                                            <ColumnDefinition Width="Auto" SharedSizeGroup="Col3"/>
                                            <ColumnDefinition Width="Auto" SharedSizeGroup="Col4"/>
                                            <ColumnDefinition Width="Auto" SharedSizeGroup="Col5"/>
                                            <ColumnDefinition Width="Auto" SharedSizeGroup="Col6"/>
                                            <ColumnDefinition Width="Auto" SharedSizeGroup="Col7"/>
                                            <ColumnDefinition Width="Auto" SharedSizeGroup="Col8"/>
                                            <ColumnDefinition Width="Auto" SharedSizeGroup="Col9"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Shift ID (clickable, like receipt number) -->
                                        <Button Grid.Column="0"
                                                FontSize="11"
                                                Cursor="Hand"
                                                HorizontalAlignment="Left"
                                                Background="#DBEEFF"
                                                BorderThickness="0"
                                                Padding="8,2"
                                                VerticalAlignment="Center"
                                                Margin="0,0,20,0"
                                                Command="{Binding DataContext.OpenShiftDetailCommand,
                                                          RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bg" Background="#DBEEFF" CornerRadius="4" Padding="8,2">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bg" Property="Background" Value="#C4DDF5"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                            <TextBlock Text="{Binding ShiftId}" FontWeight="Medium" FontSize="11" Foreground="{StaticResource BrandDark}"/>
                                        </Button>

                                        <!-- Cashier -->
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding CashierName}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextDark}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,0,20,0"/>

                                        <!-- Opened At -->
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding OpenedAt, StringFormat='yyyy-MM-dd HH:mm'}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextDark}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,20,0"/>

                                        <!-- Closed At -->
                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding ClosedAt, StringFormat='yyyy-MM-dd HH:mm'}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextDark}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,20,0"/>

                                        <!-- Opening -->
                                        <controls:CurrencyText Grid.Column="4"
                                                   Amount="{Binding OpeningCash}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextDark}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,20,0"/>

                                        <!-- Closing -->
                                        <controls:CurrencyText Grid.Column="5"
                                                   Amount="{Binding ClosingCash}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextDark}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,20,0"/>

                                        <!-- Expected -->
                                        <controls:CurrencyText Grid.Column="6"
                                                   Amount="{Binding ExpectedCash}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextDark}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,20,0"/>

                                        <!-- Difference -->
                                        <controls:CurrencyText Grid.Column="7"
                                                   Amount="{Binding CashDifference}"
                                                   FontSize="11"
                                                   FontWeight="Medium"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,20,0">
                                            <controls:CurrencyText.Style>
                                                <Style TargetType="controls:CurrencyText">
                                                    <Setter Property="Foreground" Value="#16A34A"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding CashDifference}" Value="{x:Null}">
                                                            <Setter Property="Foreground" Value="{StaticResource TextDark}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </controls:CurrencyText.Style>
                                        </controls:CurrencyText>

                                        <!-- Status badge -->
                                        <Border Grid.Column="8" HorizontalAlignment="Left" VerticalAlignment="Center"
                                                CornerRadius="10" Padding="8,2" Margin="0,0,20,0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding StatusLabel}" Value="Open">
                                                            <Setter Property="Background" Value="#DCFCE7"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding StatusLabel}" Value="Closed">
                                                            <Setter Property="Background" Value="#DBEAFE"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding StatusLabel}" FontSize="11" FontWeight="Medium" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding StatusLabel}" Value="Open">
                                                                <Setter Property="Foreground" Value="#16A34A"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StatusLabel}" Value="Closed">
                                                                <Setter Property="Foreground" Value="#1A6FC4"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>

                                        <!-- Duration -->
                                        <TextBlock Grid.Column="9"
                                                   Text="{Binding DurationHours, StringFormat={}{0:F1}h}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextDark}"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>

                <!-- Pagination footer -->
                <Border Grid.Row="2"
                        Background="{StaticResource CardHdrBg}"
                        BorderBrush="{StaticResource BrandBorder}"
                        BorderThickness="0,0.5,0,0"
                        Padding="14,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock FontSize="11" Foreground="{StaticResource TextMuted}">
                                <Run Text="{DynamicResource Common.Page}"/>
                                <Run Text=" "/>
                                <Run Text="{Binding PageInfo, Mode=OneWay}"/>
                                <Run Text="  ·  "/>
                                <Run Text="{Binding TotalCount, Mode=OneWay}"/>
                                <Run Text=" "/>
                                <Run Text="{DynamicResource Manager.Shifts.PagerSuffix}"/>
                            </TextBlock>
                            <!-- Error banner -->
                            <TextBlock Text="{Binding ErrorMessage}"
                                       FontSize="11" Foreground="#A32D2D"
                                       Margin="0,4,0,0"
                                       TextWrapping="Wrap"
                                       Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Style="{StaticResource OutlineBtn}"
                                    Content="{DynamicResource Common.Previous}"
                                    Margin="0,0,6,0"
                                    Command="{Binding PreviousPageCommand}"/>
                            <Button Style="{StaticResource PrimaryGradientBtn}"
                                    Content="{DynamicResource Common.Next}"
                                    Command="{Binding NextPageCommand}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
