<Window x:Class="UI.Views.StartDayDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Start Day" Height="250" Width="400"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        Background="#F5F5F5">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="350">
            <!-- Title -->
            <TextBlock Text="{DynamicResource Shift.Start.Title}" FontSize="18" FontWeight="Bold"
                       Foreground="#333333" Margin="0,0,0,20" TextAlignment="Center"/>

            <!-- Explanation -->
            <TextBlock Text="{DynamicResource Shift.Start.Description}"
                       FontSize="12" Foreground="#666666" TextWrapping="Wrap" Margin="0,0,0,15"/>

            <!-- Opening Cash Input -->
            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="{DynamicResource Shift.OpeningCash}" FontSize="12" FontWeight="SemiBold"
                           Foreground="#333333" Margin="0,0,0,8"/>
                <TextBox x:Name="OpeningCashBox"
                         Text="{Binding OpeningCash, UpdateSourceTrigger=PropertyChanged}"
                         Height="40" Padding="12" FontSize="14"
                         Background="White" Foreground="#333333"
                         BorderBrush="#CCCCCC" BorderThickness="1"
                         Loaded="OpeningCashBox_Loaded"
                         KeyDown="OpeningCashBox_KeyDown"
                         PreviewTextInput="OpeningCashBox_PreviewTextInput"/>
            </StackPanel>

            <!-- Error Message -->
            <TextBlock Text="{Binding ErrorMessage}" Foreground="#D32F2F"
                       FontSize="11" TextWrapping="Wrap" Margin="0,0,0,15"
                       Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <!-- Buttons
                 IsCancel  on Cancel   → Esc closes the dialog (no shift opened).
                 IsDefault on Start    → Enter opens the shift
                                       (but the TextBox also handles Enter
                                       via its own KeyDown handler so the
                                       shortcut works while the textbox
                                       has focus, not just the button).
            -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="{DynamicResource Common.Cancel}" Width="100" Height="36"
                        Background="#EEEEEE" Foreground="#333333"
                        BorderBrush="#CCCCCC" BorderThickness="1"
                        Command="{Binding CancelCommand}"
                        IsCancel="True"
                        FontSize="12" Margin="0,0,10,0"/>
                <Button Content="{DynamicResource Shift.Start.Button}" Width="100" Height="36"
                        Background="#4CAF50" Foreground="White"
                        Command="{Binding StartDayCommand}"
                        IsDefault="True"
                        FontSize="12" FontWeight="SemiBold"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
