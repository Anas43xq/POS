<Window x:Class="UI.Views.StartDayDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Start Day" Height="250" Width="400"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        Background="#F5F5F5">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="350">
            <!-- Title -->
            <TextBlock Text="Start a New Shift" FontSize="18" FontWeight="Bold" 
                       Foreground="#333333" Margin="0,0,0,20" TextAlignment="Center"/>

            <!-- Explanation -->
            <TextBlock Text="Enter the opening cash amount in the drawer to start a new shift." 
                       FontSize="12" Foreground="#666666" TextWrapping="Wrap" Margin="0,0,0,15"/>

            <!-- Opening Cash Input -->
            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="Opening Cash:" FontSize="12" FontWeight="SemiBold" 
                           Foreground="#333333" Margin="0,0,0,8"/>
                <TextBox Text="{Binding OpeningCash, UpdateSourceTrigger=PropertyChanged}" 
                         Height="40" Padding="12" FontSize="14"
                         Background="White" Foreground="#333333"
                         BorderBrush="#CCCCCC" BorderThickness="1"/>
            </StackPanel>

            <!-- Error Message -->
            <TextBlock Text="{Binding ErrorMessage}" Foreground="#D32F2F" 
                       FontSize="11" TextWrapping="Wrap" Margin="0,0,0,15"
                       Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Width="100" Height="36" 
                        Background="#EEEEEE" Foreground="#333333"
                        BorderBrush="#CCCCCC" BorderThickness="1"
                        Command="{Binding CancelCommand}"
                        FontSize="12" Margin="0,0,10,0"/>
                <Button Content="Start Shift" Width="100" Height="36" 
                        Background="#4CAF50" Foreground="White"
                        Command="{Binding StartDayCommand}"
                        FontSize="12" FontWeight="SemiBold"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
