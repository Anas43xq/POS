<Window x:Class="UI.Views.EndDayDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="End Day" Height="450" Width="450"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        Background="#F5F5F5">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="400">
            <!-- Title -->
            <TextBlock Text="{DynamicResource Shift.End.Title}" FontSize="18" FontWeight="Bold" 
                       Foreground="#333333" Margin="0,0,0,10" TextAlignment="Center"/>

            <!-- Warning Message -->
            <Border Background="#FFF3CD" BorderBrush="#FFC107" BorderThickness="1" 
                    Padding="12" CornerRadius="4" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Common.Warning}" FontSize="12" FontWeight="SemiBold" 
                               Foreground="#856404" Margin="0,0,0,5"/>
                    <TextBlock Text="{DynamicResource Shift.WarningMessage}" 
                               FontSize="11" Foreground="#856404" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Shift Summary -->
            <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" 
                    Padding="12" CornerRadius="4" Margin="0,0,0,20">
                <StackPanel>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{DynamicResource Shift.OpeningCash}" Foreground="#666666"/>
                        <TextBlock Text="{Binding OpeningCashDisplay}" Grid.Column="1" 
                                   FontWeight="SemiBold" Foreground="#333333"/>
                    </Grid>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{DynamicResource Shift.TotalSales}" Foreground="#666666"/>
                        <TextBlock Text="{Binding TotalSalesDisplay}" Grid.Column="1" 
                                   FontWeight="SemiBold" Foreground="#333333"/>
                    </Grid>
                    <Grid Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{DynamicResource Shift.ExpectedCash}" Foreground="#666666"/>
                        <TextBlock Text="{Binding ExpectedCashDisplay}" Grid.Column="1" 
                                   FontWeight="SemiBold" Foreground="#333333"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Closing Cash Input -->
            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="{DynamicResource Shift.ActualClosingCash}" FontSize="12" FontWeight="SemiBold" 
                           Foreground="#333333" Margin="0,0,0,8"/>
                <TextBox Text="{Binding ClosingCash, UpdateSourceTrigger=PropertyChanged}"
         Height="40"
         Padding="9"
         FontSize="14"
         PreviewTextInput="DecimalTextBox_PreviewTextInput"
         DataObject.Pasting="DecimalTextBox_Pasting"
         LostFocus="DecimalTextBox_LostFocus"/>
            </StackPanel>

            <!-- Cash Difference Display -->
            <Border Background="#E8F5E9" BorderBrush="#4CAF50" BorderThickness="1" 
                    Padding="12" CornerRadius="4" Margin="0,0,0,20"
                    Visibility="{Binding ShowCashDifference, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{DynamicResource Shift.CashDifference}" FontWeight="SemiBold" Foreground="#2E7D32"/>
                    <TextBlock Text="{Binding CashDifferenceDisplay}" Grid.Column="1" 
                               FontWeight="SemiBold" Foreground="#2E7D32"/>
                </Grid>
            </Border>

            <!-- Error Message -->
            <TextBlock Text="{Binding ErrorMessage}" Foreground="#D32F2F" 
                       FontSize="11" TextWrapping="Wrap" Margin="0,0,0,15"
                       Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="{DynamicResource Common.Cancel}" Width="100" Height="36" 
                        Background="#EEEEEE" Foreground="#333333"
                        BorderBrush="#CCCCCC" BorderThickness="1"
                        Command="{Binding CancelCommand}"
                        FontSize="12" Margin="0,0,10,0"/>
                <Button Content="{DynamicResource Shift.End.Button}" Width="120" Height="36" 
                        Background="#F57C00" Foreground="White"
                        Command="{Binding EndDayCommand}"
                        FontSize="12" FontWeight="SemiBold"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
