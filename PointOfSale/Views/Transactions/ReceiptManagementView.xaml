<UserControl x:Class="UI.Views.ReceiptManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignWidth="1420" d:DesignHeight="920">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <SolidColorBrush x:Key="BrandDark" Color="#1A6FC4"/>
        <SolidColorBrush x:Key="BrandMid" Color="#2589E0"/>
        <SolidColorBrush x:Key="BrandLight" Color="#F0F7FF"/>
        <SolidColorBrush x:Key="BrandBorder" Color="#B8D8F5"/>
        <SolidColorBrush x:Key="CardBg" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="CardHdrBg" Color="#F0F7FF"/>
        <SolidColorBrush x:Key="TextDark" Color="#1A3A5C"/>
        <SolidColorBrush x:Key="TextMuted" Color="#8AB0CC"/>
        <SolidColorBrush x:Key="DangerRed" Color="#DC2626"/>

        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrandBorder}"/>
            <Setter Property="BorderThickness" Value="0.5"/>
            <Setter Property="CornerRadius" Value="10"/>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextDark}"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="FilterField" TargetType="Control">
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Background" Value="{StaticResource BrandLight}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrandBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" CornerRadius="6">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1A6FC4" Offset="0"/>
                                    <GradientStop Color="#2589E0" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.92"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OutlineBtn" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource BrandDark}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" CornerRadius="6" Background="{StaticResource BrandLight}" BorderBrush="{StaticResource BrandBorder}" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#DBEEFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TabItemStyle" TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border" CornerRadius="8,8,0,0" Background="Transparent" Margin="0,0,6,0" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="White"/>
                                <Setter Property="Foreground" Value="{StaticResource BrandDark}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#F6FAFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="#EAF4FF" Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                BorderBrush="{StaticResource BrandBorder}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="16,14"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Receipt Management"
                               Style="{StaticResource SectionTitle}"/>
                    <TextBlock Text="Sales receipts, supplier purchases and receipt documents in one manager workspace."
                               FontSize="12"
                               Foreground="{StaticResource TextMuted}"
                               Margin="0,4,0,0"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Style="{StaticResource OutlineBtn}"
                        Content="↻ Refresh"
                        Command="{Binding RefreshCommand}"/>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="White"
                BorderBrush="{StaticResource BrandBorder}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="14"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Search" Style="{StaticResource FieldLabel}"/>
                    <TextBox Style="{StaticResource FilterField}" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Padding="8,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,10,0">
                    <TextBlock Text="Date From" Style="{StaticResource FieldLabel}"/>
                    <DatePicker Style="{StaticResource FilterField}" SelectedDate="{Binding DateFrom}"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,10,0">
                    <TextBlock Text="Date To" Style="{StaticResource FieldLabel}"/>
                    <DatePicker Style="{StaticResource FilterField}" SelectedDate="{Binding DateTo}"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="0,0,10,0">
                    <TextBlock Text="Supplier" Style="{StaticResource FieldLabel}"/>
                    <ComboBox Style="{StaticResource FilterField}" ItemsSource="{Binding Suppliers}" SelectedItem="{Binding SelectedSupplier}" DisplayMemberPath="CompanyName"/>
                </StackPanel>

                <StackPanel Grid.Column="4" Margin="0,0,10,0">
                    <TextBlock Text="Category" Style="{StaticResource FieldLabel}"/>
                    <TextBox Style="{StaticResource FilterField}" Text="{Binding CategoryFilter, UpdateSourceTrigger=PropertyChanged}" Padding="8,0"/>
                </StackPanel>

                <StackPanel Grid.Column="5" Margin="0,0,10,0">
                    <TextBlock Text="Receipt Type" Style="{StaticResource FieldLabel}"/>
                    <ComboBox Style="{StaticResource FilterField}" ItemsSource="{Binding ReceiptTypeFilterOptions}" SelectedItem="{Binding SelectedReceiptTypeFilter}"/>
                </StackPanel>

                <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button Style="{StaticResource PrimaryBtn}" Content="Apply" Margin="0,0,8,0" Command="{Binding ApplyFiltersCommand}"/>
                    <Button Style="{StaticResource OutlineBtn}" Content="Reset" Command="{Binding ResetFiltersCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardBorder}">
            <TabControl Background="Transparent" BorderThickness="0" Padding="0" Margin="0">
                <TabItem Header="Sales" Style="{StaticResource TabItemStyle}">
                    <Grid Margin="0,8,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{StaticResource CardHdrBg}"
                                BorderBrush="{StaticResource BrandBorder}"
                                BorderThickness="0,0,0,0.5"
                                CornerRadius="10,10,0,0"
                                Padding="12,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Sales receipts" Style="{StaticResource SectionTitle}"/>
                                <Button Grid.Column="1"
                                        Style="{StaticResource OutlineBtn}"
                                        Content="Open"
                                        Command="{Binding OpenSalesReceiptCommand}"/>
                            </Grid>
                        </Border>

                        <DataGrid Grid.Row="1"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow"
                                  ItemsSource="{Binding SalesReceipts}"
                                  SelectedItem="{Binding SelectedSalesReceipt, Mode=TwoWay}"
                                  HeadersVisibility="Column"
                                  AlternatingRowBackground="#F9FBFF"
                                  GridLinesVisibility="Horizontal"
                                  BorderThickness="0"
                                  Background="White">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Receipt Number" Binding="{Binding ReceiptNumber}" Width="1.2*"/>
                                <DataGridTextColumn Header="Date" Binding="{Binding TransactionDate, StringFormat=d}" Width="1*"/>
                                <DataGridTextColumn Header="Payment Method" Binding="{Binding PaymentMethod}" Width="1.2*"/>
                                <DataGridTextColumn Header="Grand Total" Binding="{Binding GrandTotal, StringFormat=0.00}" Width="1*"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="0.8*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <TabItem Header="VAT Purchases" Style="{StaticResource TabItemStyle}">
                    <Grid Margin="0,8,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{StaticResource CardHdrBg}"
                                BorderBrush="{StaticResource BrandBorder}"
                                BorderThickness="0,0,0,0.5"
                                CornerRadius="10,10,0,0"
                                Padding="12,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="VAT purchase receipts" Style="{StaticResource SectionTitle}"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button Style="{StaticResource PrimaryBtn}" Content="Add" Margin="0,0,8,0" Command="{Binding AddVatReceiptCommand}"/>
                                    <Button Style="{StaticResource OutlineBtn}" Content="Edit" Margin="0,0,8,0" Command="{Binding EditVatReceiptCommand}"/>
                                    <Button Style="{StaticResource OutlineBtn}" Content="Delete" Margin="0,0,8,0" Command="{Binding DeleteVatReceiptCommand}"/>
                                    <Button Style="{StaticResource OutlineBtn}" Content="View" Margin="0,0,8,0" Command="{Binding ViewVatReceiptCommand}"/>
                                    <Button Style="{StaticResource OutlineBtn}" Content="Export" Command="{Binding ExportVatPurchasesCommand}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <DataGrid Grid.Row="1"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow"
                                  ItemsSource="{Binding VatReceipts}"
                                  SelectedItem="{Binding SelectedVatReceipt, Mode=TwoWay}"
                                  HeadersVisibility="Column"
                                  AlternatingRowBackground="#F9FBFF"
                                  GridLinesVisibility="Horizontal"
                                  BorderThickness="0"
                                  Background="White">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Receipt" Binding="{Binding InvoiceNumber}" Width="1.1*"/>
                                <DataGridTextColumn Header="Date" Binding="{Binding InvoiceDate, StringFormat=d}" Width="1*"/>
                                <DataGridTextColumn Header="Supplier" Binding="{Binding SupplierName}" Width="1.3*"/>
                                <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="1.2*"/>
                                <DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal, StringFormat=0.00}" Width="0.9*"/>
                                <DataGridTextColumn Header="Grand Total" Binding="{Binding GrandTotal, StringFormat=0.00}" Width="0.9*"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border Grid.Row="2"
                                Visibility="{Binding IsFormVisible, Converter={StaticResource BoolToVis}}"
                                Margin="0,10,0,0"
                                Background="#FCFEFF"
                                BorderBrush="{StaticResource BrandBorder}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding FormTitle}" Style="{StaticResource SectionTitle}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding StatusMessage}" Foreground="{StaticResource DangerRed}" FontSize="11" VerticalAlignment="Center"/>
                                </Grid>

                                <Grid Grid.Row="1">
                                    <Grid Visibility="{Binding IsVatReceiptMode, Converter={StaticResource BoolToVis}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="1*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,8">
                                            <TextBlock Text="Supplier" Style="{StaticResource FieldLabel}"/>
                                            <ComboBox Style="{StaticResource FilterField}" ItemsSource="{Binding Suppliers}" SelectedItem="{Binding SelectedSupplier}" DisplayMemberPath="CompanyName" IsEnabled="{Binding IsFormEditable}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,10,8">
                                            <TextBlock Text="Receipt Number" Style="{StaticResource FieldLabel}"/>
                                            <TextBox Style="{StaticResource FilterField}" Text="{Binding InvoiceNumber, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsFormEditable}" Padding="8,0"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,8">
                                            <TextBlock Text="Date" Style="{StaticResource FieldLabel}"/>
                                            <DatePicker Style="{StaticResource FilterField}" SelectedDate="{Binding InvoiceDate}" IsEnabled="{Binding IsFormEditable}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,8">
                                            <TextBlock Text="Category" Style="{StaticResource FieldLabel}"/>
                                            <TextBox Style="{StaticResource FilterField}" Text="{Binding Category, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsFormEditable}" Padding="8,0"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,10,8">
                                            <TextBlock Text="Subtotal" Style="{StaticResource FieldLabel}"/>
                                            <TextBox Style="{StaticResource FilterField}" Text="{Binding Subtotal, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsFormEditable}" Padding="8,0"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,8">
                                            <TextBlock Text="VAT Rate" Style="{StaticResource FieldLabel}"/>
                                            <TextBox Style="{StaticResource FilterField}" Text="{Binding VatRate, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsFormEditable}" Padding="8,0"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,10,8">
                                            <TextBlock Text="VAT Amount" Style="{StaticResource FieldLabel}"/>
                                            <TextBox Style="{StaticResource FilterField}" Text="{Binding VatAmount, StringFormat=N2}" IsReadOnly="True" Padding="8,0"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,10,8">
                                            <TextBlock Text="Grand Total" Style="{StaticResource FieldLabel}"/>
                                            <TextBox Style="{StaticResource FilterField}" Text="{Binding GrandTotal, StringFormat=N2}" IsReadOnly="True" Padding="8,0"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,8">
                                            <TextBlock Text="Receipt Image" Style="{StaticResource FieldLabel}"/>
                                            <TextBox Style="{StaticResource FilterField}" Text="{Binding ImagePath, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsFormEditable}" Padding="8,0"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,8">
                                            <TextBlock Text="Description" Style="{StaticResource FieldLabel}"/>
                                            <TextBox Style="{StaticResource FilterField}" Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" Height="72" AcceptsReturn="True" TextWrapping="Wrap" IsEnabled="{Binding IsFormEditable}" Padding="8,6"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3">
                                            <TextBlock Text="Notes" Style="{StaticResource FieldLabel}"/>
                                            <TextBox Style="{StaticResource FilterField}" Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" Height="72" AcceptsReturn="True" TextWrapping="Wrap" IsEnabled="{Binding IsFormEditable}" Padding="8,6"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid Visibility="{Binding IsNonVatReceiptMode, Converter={StaticResource BoolToVis}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="1*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,8">
                                            <TextBlock Text="Supplier" Style="{StaticResource FieldLabel}"/>
                                            <ComboBox Style="{StaticResource FilterField}" ItemsSource="{Binding Suppliers}" SelectedItem="{Binding SelectedSupplier}" DisplayMemberPath="CompanyName" IsEnabled="{Binding IsFormEditable}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,10,8">
                                            <TextBlock Text="Receipt Number" Style="{StaticResource FieldLabel}"/>
                                            <TextBox Style="{StaticResource FilterField}" Text="{Binding InvoiceNumber, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsFormEditable}" Padding="8,0"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,8">
                                            <TextBlock Text="Date" Style="{StaticResource FieldLabel}"/>
                                            <DatePicker Style="{StaticResource FilterField}" SelectedDate="{Binding InvoiceDate}" IsEnabled="{Binding IsFormEditable}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,8">
                                            <TextBlock Text="Category" Style="{StaticResource FieldLabel}"/>
                                            <TextBox Style="{StaticResource FilterField}" Text="{Binding Category, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsFormEditable}" Padding="8,0"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,10,8">
                                            <TextBlock Text="Amount" Style="{StaticResource FieldLabel}"/>
                                            <TextBox Style="{StaticResource FilterField}" Text="{Binding Subtotal, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsFormEditable}" Padding="8,0"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,8">
                                            <TextBlock Text="Receipt Image" Style="{StaticResource FieldLabel}"/>
                                            <TextBox Style="{StaticResource FilterField}" Text="{Binding ImagePath, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsFormEditable}" Padding="8,0"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,8">
                                            <TextBlock Text="Description" Style="{StaticResource FieldLabel}"/>
                                            <TextBox Style="{StaticResource FilterField}" Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" Height="72" AcceptsReturn="True" TextWrapping="Wrap" IsEnabled="{Binding IsFormEditable}" Padding="8,6"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3">
                                            <TextBlock Text="Notes" Style="{StaticResource FieldLabel}"/>
                                            <TextBox Style="{StaticResource FilterField}" Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" Height="72" AcceptsReturn="True" TextWrapping="Wrap" IsEnabled="{Binding IsFormEditable}" Padding="8,6"/>
                                        </StackPanel>
                                    </Grid>
                                </Grid>

                                <StackPanel Grid.Row="1" HorizontalAlignment="Right" VerticalAlignment="Bottom" Orientation="Horizontal">
                                    <Button Style="{StaticResource PrimaryBtn}" Content="Save" Margin="0,0,8,0" Command="{Binding SaveReceiptCommand}" Visibility="{Binding IsFormEditable, Converter={StaticResource BoolToVis}}"/>
                                    <Button Style="{StaticResource OutlineBtn}" Content="Cancel" Command="{Binding CancelReceiptCommand}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Non-VAT Purchases" Style="{StaticResource TabItemStyle}">
                    <Grid Margin="0,8,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{StaticResource CardHdrBg}"
                                BorderBrush="{StaticResource BrandBorder}"
                                BorderThickness="0,0,0,0.5"
                                CornerRadius="10,10,0,0"
                                Padding="12,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Non-VAT purchase receipts" Style="{StaticResource SectionTitle}"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button Style="{StaticResource PrimaryBtn}" Content="Add" Margin="0,0,8,0" Command="{Binding AddNonVatReceiptCommand}"/>
                                    <Button Style="{StaticResource OutlineBtn}" Content="Edit" Margin="0,0,8,0" Command="{Binding EditNonVatReceiptCommand}"/>
                                    <Button Style="{StaticResource OutlineBtn}" Content="Delete" Margin="0,0,8,0" Command="{Binding DeleteNonVatReceiptCommand}"/>
                                    <Button Style="{StaticResource OutlineBtn}" Content="View" Margin="0,0,8,0" Command="{Binding ViewNonVatReceiptCommand}"/>
                                    <Button Style="{StaticResource OutlineBtn}" Content="Export" Command="{Binding ExportNonVatPurchasesCommand}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <DataGrid Grid.Row="1"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow"
                                  ItemsSource="{Binding NonVatReceipts}"
                                  SelectedItem="{Binding SelectedNonVatReceipt, Mode=TwoWay}"
                                  HeadersVisibility="Column"
                                  AlternatingRowBackground="#F9FBFF"
                                  GridLinesVisibility="Horizontal"
                                  BorderThickness="0"
                                  Background="White">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Receipt" Binding="{Binding InvoiceNumber}" Width="1.1*"/>
                                <DataGridTextColumn Header="Date" Binding="{Binding InvoiceDate, StringFormat=d}" Width="1*"/>
                                <DataGridTextColumn Header="Supplier" Binding="{Binding SupplierName}" Width="1.3*"/>
                                <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="1.2*"/>
                                <DataGridTextColumn Header="Grand Total" Binding="{Binding GrandTotal, StringFormat=0.00}" Width="0.9*"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border Grid.Row="1"
                                Visibility="{Binding IsFormVisible, Converter={StaticResource BoolToVis}}"
                                Margin="0,10,0,0"
                                Background="#FCFEFF"
                                BorderBrush="{StaticResource BrandBorder}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding FormTitle}" Style="{StaticResource SectionTitle}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding StatusMessage}" Foreground="{StaticResource DangerRed}" FontSize="11" VerticalAlignment="Center"/>
                                </Grid>

                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1*"/>
                                        <ColumnDefinition Width="1*"/>
                                        <ColumnDefinition Width="1*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,8">
                                        <TextBlock Text="Supplier" Style="{StaticResource FieldLabel}"/>
                                        <ComboBox Style="{StaticResource FilterField}" ItemsSource="{Binding Suppliers}" SelectedItem="{Binding SelectedSupplier}" DisplayMemberPath="CompanyName" IsEnabled="{Binding IsFormEditable}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,10,8">
                                        <TextBlock Text="Receipt Number" Style="{StaticResource FieldLabel}"/>
                                        <TextBox Style="{StaticResource FilterField}" Text="{Binding InvoiceNumber, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsFormEditable}" Padding="8,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,8">
                                        <TextBlock Text="Date" Style="{StaticResource FieldLabel}"/>
                                        <DatePicker Style="{StaticResource FilterField}" SelectedDate="{Binding InvoiceDate}" IsEnabled="{Binding IsFormEditable}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,8">
                                        <TextBlock Text="Category" Style="{StaticResource FieldLabel}"/>
                                        <TextBox Style="{StaticResource FilterField}" Text="{Binding Category, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsFormEditable}" Padding="8,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,10,8">
                                        <TextBlock Text="Amount" Style="{StaticResource FieldLabel}"/>
                                        <TextBox Style="{StaticResource FilterField}" Text="{Binding Subtotal, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsFormEditable}" Padding="8,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,8">
                                        <TextBlock Text="Receipt Image" Style="{StaticResource FieldLabel}"/>
                                        <TextBox Style="{StaticResource FilterField}" Text="{Binding ImagePath, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsFormEditable}" Padding="8,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,8">
                                        <TextBlock Text="Description" Style="{StaticResource FieldLabel}"/>
                                        <TextBox Style="{StaticResource FilterField}" Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" Height="72" AcceptsReturn="True" TextWrapping="Wrap" IsEnabled="{Binding IsFormEditable}" Padding="8,6"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3">
                                        <TextBlock Text="Notes" Style="{StaticResource FieldLabel}"/>
                                        <TextBox Style="{StaticResource FilterField}" Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" Height="72" AcceptsReturn="True" TextWrapping="Wrap" IsEnabled="{Binding IsFormEditable}" Padding="8,6"/>
                                    </StackPanel>
                                </Grid>

                                <StackPanel Grid.Row="1" HorizontalAlignment="Right" VerticalAlignment="Bottom" Orientation="Horizontal">
                                    <Button Style="{StaticResource PrimaryBtn}" Content="Save" Margin="0,0,8,0" Command="{Binding SaveReceiptCommand}" Visibility="{Binding IsFormEditable, Converter={StaticResource BoolToVis}}"/>
                                    <Button Style="{StaticResource OutlineBtn}" Content="Cancel" Command="{Binding CancelReceiptCommand}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>
        </Border>
    </Grid>
</UserControl>
