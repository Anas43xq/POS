<!--
    ╔══════════════════════════════════════════════════════╗
    ║   Cafeteria Hawa POS  –  Manager · Transactions      ║
    ║   Filter bar + grouped DataGrid + pagination         ║
    ╚══════════════════════════════════════════════════════╝
-->
<UserControl x:Class="UI.Views.TransactionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:UI.Controls"
             xmlns:converters="clr-namespace:UI.Converters"
             mc:Ignorable="d"
             d:DesignWidth="1420" d:DesignHeight="820">

    <UserControl.Resources>

        <converters:StatusToVoidVisConverter x:Key="StatusToVoidVis"/>

        <!-- Payment badge border (shared by every row) -->
        <Style x:Key="PaymentBadgeBorderStyle" TargetType="Border" BasedOn="{StaticResource BadgeBase}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding PaymentMethod}" Value="Cash">
                    <Setter Property="Background" Value="#DCFCE7"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding PaymentMethod}" Value="Card">
                    <Setter Property="Background" Value="#DBEAFE"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Payment badge text (shared by every row) -->
        <Style x:Key="PaymentBadgeTextStyle" TargetType="TextBlock" BasedOn="{StaticResource BadgeText}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding PaymentMethod}" Value="Cash">
                    <Setter Property="Foreground" Value="#16A34A"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding PaymentMethod}" Value="Card">
                    <Setter Property="Foreground" Value="#1A6FC4"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Status badge border (shared by every row) -->
        <Style x:Key="StatusBadgeBorderStyle" TargetType="Border" BasedOn="{StaticResource BadgeBase}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="Completed">
                    <Setter Property="Background" Value="#DBEAFE"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Voided">
                    <Setter Property="Background" Value="{StaticResource DangerLight}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Pending">
                    <Setter Property="Background" Value="#FEF3C7"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Status badge text (shared by every row) -->
        <Style x:Key="StatusBadgeTextStyle" TargetType="TextBlock" BasedOn="{StaticResource BadgeText}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="Completed">
                    <Setter Property="Foreground" Value="#1A6FC4"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Voided">
                    <Setter Property="Foreground" Value="{StaticResource DangerDark}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Pending">
                    <Setter Property="Foreground" Value="#92400E"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

    </UserControl.Resources>

    <Grid Background="#EAF4FF">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Filter bar -->
            <RowDefinition Height="*"/>
            <!-- Table card -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════
             FILTER BAR
             ══════════════════════════════════════ -->
        <Border Grid.Row="0" Style="{StaticResource FilterPanel}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <RadioButton Style="{StaticResource FilterChip}" Content="{DynamicResource Common.Day}"
                                 IsChecked="True"
                                 Command="{Binding LoadDayCommand}"/>
                    <RadioButton Style="{StaticResource FilterChip}" Content="{DynamicResource Common.Week}"
                                 Command="{Binding LoadWeekCommand}"/>
                    <RadioButton Style="{StaticResource FilterChip}" Content="{DynamicResource Common.Month}"
                                 Command="{Binding LoadMonthCommand}"/>
                    <RadioButton Style="{StaticResource FilterChip}" Content="{DynamicResource Common.Period}"
                                 Command="{Binding LoadPeriodCommand}"/>

                    <controls:PeriodFilterPanel FilterVisibility="{Binding IsPeriodFilterVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                                                FromDate="{Binding FromDate, Mode=TwoWay}"
                                                ToDate="{Binding ToDate, Mode=TwoWay}"
                                                ApplyCommand="{Binding ApplyPeriodCommand}"
                                                FromLabel="{DynamicResource Common.From}"
                                                ToLabel="{DynamicResource Common.To}"
                                                ApplyButtonText="{DynamicResource Common.Apply}"
                                                Margin="6,0,0,0"/>

                    <!-- Status filter (Completed / Voided / Pending / All).
                         Combines with the date filter — picking "Voided"
                         + "Week" shows this week's voided transactions. -->
                    <TextBlock Text="{DynamicResource Manager.Transactions.StatusFilter}"
                               VerticalAlignment="Center"
                               Margin="12,0,4,0"
                               FontSize="11"
                               Foreground="{StaticResource TextMuted}"/>
                    <ComboBox Width="110"
                              Height="26"
                              FontSize="11"
                              VerticalContentAlignment="Center"
                              ItemsSource="{Binding StatusOptions}"
                              SelectedItem="{Binding SelectedStatusFilter, Mode=TwoWay}"
                              DisplayMemberPath="Label"/>

                </StackPanel>

                <!-- Void + Refresh grouped together -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Destructive: red DangerBtn, only visible when the
                         selected row is in Completed state. -->
                    <Button Style="{StaticResource DangerBtn}"
                            Content="{DynamicResource Manager.Transactions.VoidButton}"
                            Margin="0,0,6,0"
                            Command="{Binding VoidTransactionCommand}"
                            CommandParameter="{Binding SelectedTransaction}"
                            Visibility="{Binding SelectedTransaction.Status, Converter={StaticResource StatusToVoidVis}}"/>

                    <Button Style="{StaticResource OutlineBtn}"
                            Content="{DynamicResource Common.Refresh}"
                            Command="{Binding RefreshCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════
             TRANSACTIONS TABLE CARD
             ══════════════════════════════════════ -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- header  -->
                    <RowDefinition Height="*"/>
                    <!-- grid    -->
                    <RowDefinition Height="Auto"/>
                    <!-- pager   -->
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource CardHeaderBorder}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{DynamicResource Manager.Transactions.TransactionsCardTitle}" Style="{StaticResource CardTitle}"/>
                        <!-- Busy spinner -->
                        <TextBlock Grid.Column="1"
                                   Text="{DynamicResource Manager.Transactions.Loading}"
                                   FontSize="11"
                                   Foreground="{StaticResource TextMuted}"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </Grid>
                </Border>

                <!-- Transactions list (column header + scrollable rows) -->
                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- column headings -->
                        <RowDefinition Height="*"/>
                        <!-- scrollable rows -->
                    </Grid.RowDefinitions>

                    <!-- Column headings -->
                    <Border Grid.Row="0"
                            Background="{StaticResource CardHdrBg}"
                            BorderBrush="{StaticResource BrandBorder}"
                            BorderThickness="0,0,0,0.5">
                        <Grid Margin="14,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*" MinWidth="80"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="150"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{DynamicResource Manager.Transactions.ColReceipt}"      Style="{StaticResource ListHeaderCell}"/>
                            <TextBlock Grid.Column="1" Text="{DynamicResource Manager.Transactions.ColAmount}"      Style="{StaticResource ListHeaderCell}"/>
                            <TextBlock Grid.Column="2" Text="{DynamicResource Manager.Transactions.ColPayment}"     Style="{StaticResource ListHeaderCell}"/>
                            <TextBlock Grid.Column="3" Text="{DynamicResource Manager.Transactions.ColNotes}"       Style="{StaticResource ListHeaderCell}"/>
                            <TextBlock Grid.Column="4" Text="{DynamicResource Manager.Transactions.ColStatus}"      Style="{StaticResource ListHeaderCell}"/>
                            <TextBlock Grid.Column="5" Text="{DynamicResource Manager.Transactions.ColDateTime}" Style="{StaticResource ListHeaderCell}"/>
                        </Grid>
                    </Border>

                    <!-- Scrollable rows.  ListBox gives us built-in
                         selection; SelectedItem is two-way bound to
                         the VM so a click on a row sets SelectedTransaction
                         and enables the Void action. -->
                    <ListBox Grid.Row="1"
                             x:Name="TransactionsList"
                             ItemsSource="{Binding TransactionsView}"
                             SelectedItem="{Binding SelectedTransaction, Mode=TwoWay}"
                             Background="Transparent"
                             BorderThickness="0"
                             HorizontalContentAlignment="Stretch"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             Padding="0,0,4,0">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="RowBorder"
                                                    MinHeight="40"
                                                    Background="White"
                                                    BorderBrush="#EFF6FF"
                                                    BorderThickness="0,0,0,0.5">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="RowBorder"
                                                            Property="Background"
                                                            Value="{StaticResource RowSelectedBg}"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="RowBorder"
                                                            Property="Background"
                                                            Value="#F8FBFF"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="14,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*" MinWidth="80"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="150"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Receipt button -->
                                    <Button Grid.Column="0"
                                            Content="{Binding ReceiptNumber}"
                                            FontSize="11"
                                            Cursor="Hand"
                                            HorizontalAlignment="Left"
                                            Command="{Binding DataContext.OpenReceiptCommand,
                                                      RelativeSource={RelativeSource AncestorType=ListBox}}"
                                            CommandParameter="{Binding}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="#DBEEFF" CornerRadius="4" Padding="7,2">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      TextElement.Foreground="{StaticResource BrandDark}"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <!-- Amount -->
                                    <controls:CurrencyText Grid.Column="1"
                                               Amount="{Binding GrandTotal}"
                                               Foreground="{StaticResource TextDark}"
                                               VerticalAlignment="Center"/>

                                    <!-- Payment badge -->
                                    <Border Grid.Column="2" HorizontalAlignment="Left"
                                            Style="{StaticResource PaymentBadgeBorderStyle}">
                                        <TextBlock Text="{Binding PaymentMethod}"
                                                   Style="{StaticResource PaymentBadgeTextStyle}"/>
                                    </Border>

                                    <!-- Notes -->
                                    <TextBlock Grid.Column="3"
                                               Text="{Binding Notes}"
                                               FontSize="13"
                                               Foreground="{StaticResource TextDark}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>

                                    <!-- Status badge — color by status so a
                                         voided row is visually unmistakable. -->
                                    <Border Grid.Column="4"
                                            Style="{StaticResource StatusBadgeBorderStyle}">
                                        <TextBlock Text="{Binding Status}"
                                                   Style="{StaticResource StatusBadgeTextStyle}"/>
                                    </Border>

                                    <!-- Date & time -->
                                    <TextBlock Grid.Column="5"
                                               Text="{Binding TransactionDate, StringFormat='yyyy-MM-dd HH:mm'}"
                                               FontSize="13"
                                               Foreground="{StaticResource TextDark}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>

                <!-- Pagination footer -->
                <Border Grid.Row="2"
                        Background="{StaticResource CardHdrBg}"
                        BorderBrush="{StaticResource BrandBorder}"
                        BorderThickness="0,0.5,0,0"
                        Padding="14,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock FontSize="11" Foreground="{StaticResource TextMuted}">
                                <Run Text="{DynamicResource Common.Page}"/>
                                <Run Text=" "/>
                                <Run Text="{Binding PageInfo, Mode=OneWay}"/>
                                <Run Text="  ·  "/>
                                <Run Text="{Binding TotalCount, Mode=OneWay}"/>
                                <Run Text=" "/>
                                <Run Text="{DynamicResource Manager.Transactions.PagerSuffix}"/>
                            </TextBlock>
                            <!-- Error banner -->
                            <TextBlock Text="{Binding ErrorMessage}"
                                       FontSize="11" Foreground="#A32D2D"
                                       Margin="0,4,0,0"
                                       TextWrapping="Wrap"
                                       Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Style="{StaticResource OutlineBtn}"
                                    Content="{DynamicResource Common.Previous}"
                                    Margin="0,0,6,0"
                                    Command="{Binding PreviousPageCommand}"/>
                            <Button Style="{StaticResource PrimaryGradientBtn}"
                                    Content="{DynamicResource Common.Next}"
                                    Command="{Binding NextPageCommand}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
