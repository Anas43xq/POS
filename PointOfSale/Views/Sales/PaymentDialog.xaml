<Window x:Class="UI.Views.PaymentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:conv="clr-namespace:UI.Converters"
        xmlns:controls="clr-namespace:UI.Controls"
        mc:Ignorable="d"
        Title="Cash Payment"
        WindowStartupLocation="CenterOwner"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="Transparent"
        AllowsTransparency="True">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Window.Resources>

    <Border Width="520"
            Background="White"
            Padding="28"
            BorderBrush="#CBD5E1"
            BorderThickness="1"
            CornerRadius="8">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,22">
                <TextBlock Text="{DynamicResource Payment.Cash.Title}" FontSize="28" FontWeight="Bold" Foreground="#0F172A"/>
                <TextBlock Text="{DynamicResource Payment.Cash.Subtitle}" FontSize="15" Foreground="#64748B" Margin="0,4,0,0"/>
            </StackPanel>

            <Border Grid.Row="1" Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1" Padding="18" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{DynamicResource Payment.AmountDue}" FontSize="17" FontWeight="SemiBold" Foreground="#475569" VerticalAlignment="Center"/>
                    <controls:CurrencyText Grid.Column="1"
                                           Amount="{Binding PaymentTotal}"
                                           FontSize="32"
                                           FontWeight="Bold"
                                           Foreground="#16A34A"
                                           VerticalAlignment="Center"/>                    
                </Grid>
            </Border>

            <Grid Grid.Row="2" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Payment.CashReceived}" FontSize="16" FontWeight="SemiBold" Foreground="#0F172A" Margin="0,0,0,8"/>
                <TextBox Text="{Binding CashReceivedText, UpdateSourceTrigger=PropertyChanged}"
                             Height="48"
                             FontSize="18"
                             Padding="12"
                             VerticalContentAlignment="Center"
                             Margin="0,0,0,14"
                             PreviewTextInput="CashReceived_PreviewTextInput"
                             DataObject.Pasting="CashReceived_Pasting"
                             IsTabStop="True"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{DynamicResource Common.Change}" FontSize="16" Foreground="#64748B" VerticalAlignment="Center"/>
                        <controls:CurrencyText Grid.Column="1"
                                               Amount="{Binding ChangeAmount}"
                                               FontSize="24"
                                               FontWeight="Bold"
                                               Foreground="#2563EB"
                                               VerticalAlignment="Center"/>                    </Grid>
                </StackPanel>
            </Grid>

            <Border Grid.Row="3" Background="#FEE2E2" BorderBrush="#FECACA" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,16" Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#DC2626" TextWrapping="Wrap"/>
            </Border>

            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="{DynamicResource Common.Cancel}" Width="100" Height="38" Margin="0,0,10,0"
                        Background="#E2E8F0" Foreground="#0F172A"
                        Command="{Binding CancelCommand}"
                        IsCancel="True"/>
                <Button Content="{DynamicResource Payment.Cash.Confirm}" Width="120" Height="38"
                        Background="#16A34A" Foreground="White"
                        Command="{Binding ConfirmPaymentCommand}"
                        IsDefault="True"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
