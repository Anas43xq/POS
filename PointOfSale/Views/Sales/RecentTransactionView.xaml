<UserControl x:Class="UI.Views.RecentTransactionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:vm="clr-namespace:UI.ViewModels"
             xmlns:views="clr-namespace:UI.Views"
             xmlns:conv="clr-namespace:UI.Converters"
             xmlns:controls="clr-namespace:UI.Controls">
    <!-- Recent sales overlay -->
    <Grid>

        <Border Width="720"
                    MaxHeight="620"
                    Background="White"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    BorderBrush="#CBD5E1"
                    BorderThickness="1">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Recent Sales"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="#0F172A"/>
                        <TextBlock Text="Open a recent receipt"
                                       FontSize="15"
                                       Foreground="#64748B"
                                       Margin="0,4,0,0"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                                Content="Close"
                                Width="100"
                                Height="42"
                                Command="{Binding CloseRecentSalesCommand}"/>
                </Grid>

                <Border Grid.Row="1"
                            BorderBrush="#CBD5E1"
                            BorderThickness="1">
                    <DataGrid ItemsSource="{Binding CashierDashboardViewModel.RecentSales}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  RowHeight="52"
                                  ColumnHeaderHeight="42"
                                  BorderThickness="0"
                                  FontSize="14">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Receipt"
                                                    Binding="{Binding ReceiptNumber}"
                                                    Width="*"
                                                    MinWidth="130"/>
                            <DataGridTextColumn Header="Date"
                                                    Binding="{Binding TransactionDate, StringFormat={}{0:yyyy-MM-dd HH:mm}}"
                                                    Width="155"/>
                            <DataGridTextColumn Header="Payment"
                                                    Binding="{Binding PaymentMethod}"
                                                    Width="110"/>
                            <DataGridTextColumn Header="Status"
                                                    Binding="{Binding Status}"
                                                    Width="100"/>
                            <DataGridTemplateColumn Header="Total" Width="105">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <controls:CurrencyText Amount="{Binding GrandTotal}" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="" Width="95">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Open"
                                                    Height="34"
                                                    Command="{Binding DataContext.OpenRecentSaleReceiptCommand,
                                                                      RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <TextBlock Grid.Row="2"
                               Text="Select Open to view the receipt again."
                               Foreground="#64748B"
                               FontSize="13"
                               Margin="0,14,0,0"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
