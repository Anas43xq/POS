<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- - Palette -->
    <SolidColorBrush x:Key="BrandDark"      Color="#1A6FC4"/>
    <SolidColorBrush x:Key="BrandMid"       Color="#2589E0"/>
    <SolidColorBrush x:Key="BrandLight"     Color="#F0F7FF"/>
    <SolidColorBrush x:Key="BrandBorder"    Color="#B8D8F5"/>
    <SolidColorBrush x:Key="BrandIcon"      Color="#5BAAE0"/>
    <SolidColorBrush x:Key="PageBg"         Color="#EAF4FF"/>
    <SolidColorBrush x:Key="CardBg"         Color="#FFFFFF"/>
    <SolidColorBrush x:Key="CardHdrBg"      Color="#F0F7FF"/>
    <SolidColorBrush x:Key="TotalSummaryBg" Color="#DCFCE7"/>
    <SolidColorBrush x:Key="TextDark"       Color="#1A3A5C"/>
    <SolidColorBrush x:Key="TextMuted"      Color="#5B8AB0"/>
    <SolidColorBrush x:Key="SuccessGreen"   Color="#16A34A"/>
    <SolidColorBrush x:Key="DangerRed"      Color="#DC2626"/>
    <SolidColorBrush x:Key="DangerHover"    Color="#B91C1C"/>

    <!-- - Modifier panel additions -->
    <SolidColorBrush x:Key="NoticeBg"       Color="#FEF3C7"/>
    <SolidColorBrush x:Key="NoticeBorder"   Color="#F59E0B"/>
    <SolidColorBrush x:Key="NoticeText"     Color="#92400E"/>
    <SolidColorBrush x:Key="OverlayScrim"   Color="#48000000"/>

</ResourceDictionary>
