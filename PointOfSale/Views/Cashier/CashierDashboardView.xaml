<UserControl x:Class="UI.Views.Cashier.CashierDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:UI.Controls"
             xmlns:cashier="clr-namespace:UI.Views.Cashier"
             mc:Ignorable="d"
             d:DesignWidth="1600" d:DesignHeight="900">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="CashierPalette.xaml"/>
                <ResourceDictionary Source="CashierControlStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <!-- -
         ROOT  –  4 rows: error banner | header | content | footer
         Matches HTML: error-banner | topbar(52px) | main(flex) | paybar(58px)
         -->
    <Grid>
        <Grid.Background>
            <SolidColorBrush Color="#ECEEEA"/>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Error banner — collapses to 0 height when HasError is false -->
            <RowDefinition Height="52"/>
            <!-- Header (HTML: 52px)  -->
            <RowDefinition Height="*"/>
            <!-- Content              -->
            <RowDefinition Height="58"/>
            <!-- Footer (HTML: 58px)  -->
        </Grid.RowDefinitions>

        <cashier:ErrorBannerView Grid.Row="0"/>

        <cashier:CashierHeaderView Grid.Row="1"/>

        <!-- -
             ROW 2 · MAIN CONTENT
             2 columns: Catalog(Products+Categories) | Cart
             Matches HTML: .catalog(flex) + .cart(288px)
             Modifier panel overlays catalog area only, never the cart.
             -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <!-- Catalog (Products + Categories) -->
                <ColumnDefinition Width="288"/>
                <!-- Cart (HTML: 288px fixed)         -->
            </Grid.ColumnDefinitions>

            <cashier:ProductsPanelView Grid.Column="0" Margin="0"/>

            <!--
                Modifier panel sits in the SAME column as Products, drawn after it
                so it paints on top, plus a high ZIndex for certainty. It is never
                placed in the Cart's column (1) or the root Grid — same isolation
                rule we used in the HTML mockup so it physically cannot cover the cart.
            -->
            <cashier:ModifierPanelView Grid.Column="0" Panel.ZIndex="10"
                DataContext="{Binding ModifierPanel}"/>

            <cashier:CartPanelView Grid.Column="1"/>
        </Grid>

        <!-- -
             ROW 3 · FOOTER ACTION BAR
             Matches HTML .paybar: 58px, flex row, gap 10px, padding 0 12px
             -->
        <Border Grid.Row="3"
                BorderBrush="{StaticResource BrandBorder}"
                BorderThickness="0,0.5,0,0"
                Padding="12,0"
                Background="{StaticResource CardHdrBg}">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <!-- Cash      -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Card      -->
                    <ColumnDefinition Width="*"/>
                    <!-- Spacer    -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Clear     -->
                </Grid.ColumnDefinitions>

                <!-- CASH (HTML: .pay-btn.pay-cash, height 42px, padding 0 18px) -->
                <Button Height="42"
                        Margin="0,0,10,0"
                        BorderThickness="0"
                        Cursor="Hand"
                        Command="{Binding PayCashCommand}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg"
                                    Background="{StaticResource SuccessGreen}"
                                    BorderBrush="Transparent"
                                    BorderThickness="0"
                                    CornerRadius="9"
                                    Padding="18,0">
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="&#xE8C7;"
                                               FontSize="11"
                                               FontFamily="Segoe MDL2 Assets"
                                               Foreground="White"
                                               VerticalAlignment="Center"
                                               Margin="0,0,6,0"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{DynamicResource Common.Cash}"
                                                   FontSize="11" FontWeight="Bold"
                                                   Foreground="White"/>
                                        <controls:CurrencyText Amount="{Binding Total}"
                                                   Style="{StaticResource CurrencyTextStyleWhite}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#3F7551"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bg" Property="Opacity" Value="0.88"/>
                                </Trigger>
                                <Trigger Property="IsKeyboardFocused" Value="True">
                                    <Setter TargetName="Bg" Property="BorderBrush" Value="White"/>
                                    <Setter TargetName="Bg" Property="BorderThickness" Value="2"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- CARD (HTML: .pay-btn.pay-card, height 42px, padding 0 18px) -->
                <Button Grid.Column="1" Height="42"
                        Margin="0,0,10,0"
                        BorderThickness="0"
                        Cursor="Hand"
                        Command="{Binding PayCardCommand}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg"
                                    Background="{StaticResource BrandDark}"
                                    BorderBrush="Transparent"
                                    BorderThickness="0"
                                    CornerRadius="9"
                                    Padding="18,0">
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="&#xE8C7;"
                                               FontSize="11"
                                               FontFamily="Segoe MDL2 Assets"
                                               Foreground="White"
                                               VerticalAlignment="Center"
                                               Margin="0,0,6,0"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{DynamicResource Common.Card}"
                                                   FontSize="11" FontWeight="Bold"
                                                   Foreground="White"/>
                                        <controls:CurrencyText Amount="{Binding Total}"
                                                   Style="{StaticResource CurrencyTextStyleWhite}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="{StaticResource BrandMid}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bg" Property="Opacity" Value="0.88"/>
                                </Trigger>
                                <Trigger Property="IsKeyboardFocused" Value="True">
                                    <Setter TargetName="Bg" Property="BorderBrush" Value="White"/>
                                    <Setter TargetName="Bg" Property="BorderThickness" Value="2"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Clear Sale (HTML: .pay-clear, margin-left:auto → Grid.Column=3 with * spacer) -->
                <Button Grid.Column="3" Style="{StaticResource FooterGhostBtn}"
                        Margin="0"
                        Command="{Binding ClearSaleCommand}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE74D;"
                                   FontSize="11"
                                   FontFamily="Segoe MDL2 Assets"
                                   Foreground="{StaticResource TextMuted}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,6,0"/>
                        <TextBlock Text="{DynamicResource Cashier.ClearSale}"
                                   FontSize="11.5" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMuted}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

    </Grid>
</UserControl>
