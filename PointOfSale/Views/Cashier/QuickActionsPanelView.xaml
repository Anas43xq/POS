<UserControl x:Class="UI.Views.Cashier.QuickActionsPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignWidth="100" d:DesignHeight="900">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="CashierPalette.xaml"/>
                <ResourceDictionary Source="CashierControlStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Style="{StaticResource CardBorder}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Style="{StaticResource CardHeaderBorder}" Padding="8,6">
                <TextBlock Text="Quick Actions"
                           FontSize="11" FontWeight="Medium"
                           Foreground="{StaticResource TextDark}"/>
            </Border>

            <!-- Action tiles -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          Padding="0,6,0,0">
                <StackPanel>

                    <TextBlock Text="Sale"
                               FontSize="9" FontWeight="Medium"
                               Foreground="{StaticResource TextMuted}"
                               Margin="8,0,0,4"/>

                    <Button Style="{StaticResource QuickActionBtn}"
                            Command="{Binding ShowRecentSalesCommand}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="&#xE81C;" FontSize="18"
                                       FontFamily="Segoe MDL2 Assets"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Recent Sales"
                                       FontSize="9" FontWeight="Medium"
                                       Foreground="{StaticResource BrandDark}"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       HorizontalAlignment="Center"
                                       Margin="0,3,0,0"/>
                        </StackPanel>
                    </Button>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
