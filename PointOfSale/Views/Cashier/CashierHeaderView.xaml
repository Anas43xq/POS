<UserControl x:Class="UI.Views.Cashier.CashierHeaderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignWidth="1600" d:DesignHeight="52">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="CashierPalette.xaml"/>
                <ResourceDictionary Source="CashierControlStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Padding="14,0" CornerRadius="0">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                <GradientStop Color="#1A6FC4" Offset="0"/>
                <GradientStop Color="#2589E0" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <!-- Logo + title     -->
                <ColumnDefinition Width="*"/>
                <!-- Shortcut strip   -->
                <ColumnDefinition Width="Auto"/>
                <!-- Shift buttons    -->
                <ColumnDefinition Width="Auto"/>
                <!-- Cashier name     -->
                <ColumnDefinition Width="Auto"/>
                <!-- Logout           -->
            </Grid.ColumnDefinitions>

            <!-- Logo + brand (HTML: .brand gap 8px, logo 28x28 radius 7) -->
            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="0,0,14,0">
                <Border Width="28" Height="28"
                        CornerRadius="7"
                        Background="#29FFFFFF"
                        Margin="0,0,8,0">
                    <Image Source="pack://application:,,,/UI;component/Assets/logo.png"
                           Width="24" Height="24"
                           Stretch="Uniform"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Cafeteria Hawa"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="White"/>
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="0,2,0,0">
                        <Ellipse Width="7" Height="7"
                                 Margin="0,0,5,0"
                                 VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#94A3B8"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsShiftOpen}" Value="True">
                                            <Setter Property="Fill" Value="#22C55E"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding ShiftStatus}"
                                   FontSize="10.5"
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   Opacity="0.85"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <!-- Cashier name chip (HTML: .cashier-chip font 11.5px, opacity .9) -->
            <TextBlock Grid.Column="3"
                       Text="{Binding CashierName}"
                       FontSize="11.5"
                       Foreground="White"
                       VerticalAlignment="Center"
                       Opacity="0.9"
                       Margin="0,0,14,0"/>

            <!-- Action buttons (HTML: .hdr-btn height 28px, gap 14px) -->
            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="0,0,14,0">

                <!-- Settings -->
                <Button Style="{StaticResource HdrBtn}"
                        Margin="0,0,6,0"
                        Command="{Binding ShowSetting}"
                        ToolTip="{DynamicResource Cashier.Settings}">
                    <TextBlock Text="&#xE713;"
                               FontSize="14"
                               FontFamily="Segoe MDL2 Assets"
                               Foreground="White"
                               VerticalAlignment="Center"/>
                </Button>

                <Button Style="{StaticResource HdrBtn}"
                        Margin="0,0,6,0"
                        Command="{Binding StartDayCommand}"
                        Visibility="{Binding CanStartDay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" CornerRadius="7" Background="#10B981">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="12,0"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#059669"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bg" Property="Opacity" Value="0.85"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bg" Property="Opacity" Value="0.4"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE768;"
                                   FontSize="11"
                                   FontFamily="Segoe MDL2 Assets"
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   Margin="0,0,6,0"/>
                        <TextBlock Text="{DynamicResource Cashier.StartDay}"
                                   FontSize="11" FontWeight="Medium"
                                   Foreground="White"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource HdrBtn}"
                        Command="{Binding EndDayCommand}"
                        Visibility="{Binding CanEndDay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" CornerRadius="7" Background="#F97316">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="12,0"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#EA580C"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bg" Property="Opacity" Value="0.85"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bg" Property="Opacity" Value="0.4"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE71A;"
                                   FontSize="11"
                                   FontFamily="Segoe MDL2 Assets"
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   Margin="0,0,6,0"/>
                        <TextBlock Text="{DynamicResource Cashier.EndDay}"
                                   FontSize="11" FontWeight="Medium"
                                   Foreground="White"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- Logout (HTML: .hdr-btn height 28px, padding 0 11px) -->
            <Button Grid.Column="4"
                    Style="{StaticResource HdrDangerBtn}"
                    Command="{Binding LogoutCommand}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="&#xF3B1;"
                               FontSize="11"
                               FontFamily="Segoe MDL2 Assets"
                               Foreground="White"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0"/>
                    <TextBlock Text="{DynamicResource Common.Logout}"
                               FontSize="11" FontWeight="Medium"
                               Foreground="White"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>
    </Border>
</UserControl>
