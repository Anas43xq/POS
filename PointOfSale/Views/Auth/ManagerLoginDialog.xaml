<Window x:Class="UI.Views.ManagerLoginDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="clr-namespace:UI.Behaviors"
        Title="Manager Login"
        Width="420"
        SizeToContent="Height"
        MinHeight="320"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        Background="#F5F7FA">

    <Border Margin="24"
            Padding="20"
            Background="White"
            BorderBrush="#D9DEE7"
            BorderThickness="1"
            CornerRadius="12">

        <StackPanel>

            <!-- Title -->
            <TextBlock Text="Manager Login"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="#1A3A5C"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,4"/>

            <TextBlock Text="Sign in to access manager tools."
                       FontSize="12"
                       Foreground="#6B7280"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,18"/>

            <!-- Username -->
            <TextBlock Text="Username"
                       FontSize="12"
                       FontWeight="Medium"
                       Foreground="#1A3A5C"
                       Margin="0,0,0,4"/>
            <TextBox x:Name="UsernameBox"
                     Text="{Binding Username, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                     IsReadOnly="{Binding IsUsernameReadOnly}"
                     Height="36"
                     Padding="10,0"
                     FontSize="13"
                     Background="#F0F7FF"
                     BorderBrush="#B8D8F5"
                     BorderThickness="1"
                     VerticalContentAlignment="Center"
                     behaviors:FocusExtension.IsFocused="{Binding FocusUsername}"/>

            <!-- Password -->
            <TextBlock Text="Password"
                       FontSize="12"
                       FontWeight="Medium"
                       Foreground="#1A3A5C"
                       Margin="0,14,0,4"/>
            <PasswordBox x:Name="PasswordBox"
                         Height="36"
                         Padding="10,0"
                         FontSize="13"
                         Background="#F0F7FF"
                         BorderBrush="#B8D8F5"
                         BorderThickness="1"
                         VerticalContentAlignment="Center"
                         PasswordChanged="PasswordBox_PasswordChanged"
                         behaviors:FocusExtension.IsFocused="{Binding FocusPassword}"/>

            <!-- Error -->
            <TextBlock Text="{Binding ErrorMessage}"
                       FontSize="11"
                       Foreground="#A32D2D"
                       TextWrapping="Wrap"
                       Margin="0,10,0,0"
                       Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,20,0,0">
                <Button Content="Cancel"
                        Command="{Binding CancelCommand}"
                        IsCancel="True"
                        Width="90"
                        Height="34"
                        Margin="0,0,8,0"
                        Background="#EEEEEE"
                        Foreground="#1A3A5C"
                        BorderBrush="#CBD5E1"
                        BorderThickness="1"
                        FontSize="12"/>
                <Button Content="Login"
                        Command="{Binding LoginCommand}"
                        IsDefault="True"
                        Width="90"
                        Height="34"
                        Background="#1A6FC4"
                        Foreground="White"
                        BorderThickness="0"
                        FontSize="12"
                        FontWeight="SemiBold"/>
            </StackPanel>

        </StackPanel>

    </Border>

</Window>
