<Window x:Class="UI.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Cafeteria Hawa – Login"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Height="480"
        Width="360"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Window.Resources>

        <!-- ── Palette ── -->
        <SolidColorBrush x:Key="BrandDark"      Color="#1A6FC4"/>
        <SolidColorBrush x:Key="BrandMid"       Color="#2589E0"/>
        <SolidColorBrush x:Key="BrandLight"     Color="#F0F7FF"/>
        <SolidColorBrush x:Key="BrandBorder"    Color="#B8D8F5"/>
        <SolidColorBrush x:Key="BrandIcon"      Color="#5BAAE0"/>
        <SolidColorBrush x:Key="TextDark"       Color="#1A3A5C"/>
        <SolidColorBrush x:Key="TextMuted"      Color="#7AAED0"/>
        <SolidColorBrush x:Key="ErrorFg"        Color="#A32D2D"/>
        <SolidColorBrush x:Key="ErrorBg"        Color="#FFF0F0"/>
        <SolidColorBrush x:Key="ErrorBorder"    Color="#F5C1C1"/>
        <SolidColorBrush x:Key="White"          Color="#FFFFFF"/>

        <!-- ── Icon-prefixed input field border ── -->
        <Style x:Key="InputFieldBorder" TargetType="Border">
            <Setter Property="Background"       Value="{StaticResource BrandLight}"/>
            <Setter Property="BorderBrush"      Value="{StaticResource BrandBorder}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="CornerRadius"     Value="9"/>
            <Setter Property="Height"           Value="40"/>
        </Style>

        <!-- ── Transparent TextBox inside field ── -->
        <Style x:Key="FieldTextBox" TargetType="TextBox">
            <Setter Property="Background"               Value="Transparent"/>
            <Setter Property="BorderThickness"          Value="0"/>
            <Setter Property="FontSize"                 Value="13"/>
            <Setter Property="Foreground"               Value="{StaticResource TextDark}"/>
            <Setter Property="CaretBrush"               Value="{StaticResource BrandDark}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding"                  Value="0"/>
            <Setter Property="FocusVisualStyle"         Value="{x:Null}"/>
        </Style>

        <!-- ── Transparent PasswordBox inside field ── -->
        <Style x:Key="FieldPasswordBox" TargetType="PasswordBox">
            <Setter Property="Background"               Value="Transparent"/>
            <Setter Property="BorderThickness"          Value="0"/>
            <Setter Property="FontSize"                 Value="13"/>
            <Setter Property="Foreground"               Value="{StaticResource TextDark}"/>
            <Setter Property="CaretBrush"               Value="{StaticResource BrandDark}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding"                  Value="0"/>
            <Setter Property="FocusVisualStyle"         Value="{x:Null}"/>
        </Style>

        <!-- ── Field label ── -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="FontWeight"   Value="Medium"/>
            <Setter Property="Foreground"   Value="{StaticResource BrandDark}"/>
            <Setter Property="Margin"       Value="0,0,0,5"/>
        </Style>

        <!-- ── Primary (Sign in) button ── -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Height"           Value="42"/>
            <Setter Property="FontSize"         Value="14"/>
            <Setter Property="FontWeight"       Value="Medium"/>
            <Setter Property="Foreground"       Value="White"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                CornerRadius="10"
                                Background="{StaticResource BrandDark}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background"
                                        Value="{StaticResource BrandMid}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Close (X) button ── -->
        <Style x:Key="CloseBtn" TargetType="Button">
            <Setter Property="Width"            Value="26"/>
            <Setter Property="Height"           Value="26"/>
            <Setter Property="FontSize"         Value="12"/>
            <Setter Property="FontWeight"       Value="Bold"/>
            <Setter Property="Foreground"       Value="White"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                CornerRadius="13"
                                Background="#33FFFFFF">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#B32D2D"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- ══ Card only – no page background, no OS frame ══ -->
    <Border MouseLeftButtonDown="Window_MouseDown"
            Width="300"
            Height="460"
            CornerRadius="18"
            Background="{StaticResource White}"
            BorderBrush="{StaticResource BrandBorder}"
            BorderThickness="0.5">

        <Border.Effect>
            <DropShadowEffect Color="#1A3A5C" Opacity="0.25" BlurRadius="24" ShadowDepth="4"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- header panel  -->
                <RowDefinition Height="Auto"/>
                <!-- form body     -->
            </Grid.RowDefinitions>

            <!-- ══ Coloured header ══ -->
            <Border Grid.Row="0"
                    CornerRadius="18,18,0,0"
                    Padding="20,22,20,18">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1A6FC4" Offset="0"/>
                        <GradientStop Color="#2589E0" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid>
                    <StackPanel HorizontalAlignment="Center">

                        <!-- Icon tile -->
                        <Border Width="52" Height="52"
                                CornerRadius="14"
                                Background="#29FFFFFF"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,12">
                            <TextBlock Text="🏪"
                                       FontSize="26"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <!-- Brand name -->
                        <TextBlock Text="Cafeteria Hawa"
                                   FontSize="15"
                                   FontWeight="Medium"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,2"/>

                        <!-- Sub-label -->
                        <TextBlock Text="POINT OF SALE"
                                   FontSize="11"
                                   Foreground="#A8D4F5"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- ── Close button, top-right ── -->
                    <Button x:Name="CloseBtn"
                            Style="{StaticResource CloseBtn}"
                            Content="✕"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,-6,-6,0"
                            Click="CloseBtn_Click"
                            ToolTip="Close"/>
                </Grid>
            </Border>

            <!-- ══ Form body ══ -->
            <StackPanel Grid.Row="1" Margin="22,18,22,20">

                <!-- Username -->
                <TextBlock Text="Username" Style="{StaticResource FieldLabel}"/>
                <Border Style="{StaticResource InputFieldBorder}" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="👤"
                                   FontSize="14"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource BrandIcon}"/>

                        <TextBox Grid.Column="1"
                                 x:Name="UsernameBox"
                                 Style="{StaticResource FieldTextBox}"
                                 Text="{Binding Username, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                 Margin="0,0,10,0">
                            <TextBox.Resources>
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"
                                                 Color="#B8D8F5"/>
                            </TextBox.Resources>
                        </TextBox>
                    </Grid>
                </Border>

                <!-- Password -->
                <TextBlock Text="Password" Style="{StaticResource FieldLabel}"/>
                <Border Style="{StaticResource InputFieldBorder}" Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="32"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="🔒"
                                   FontSize="14"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource BrandIcon}"/>

                        <PasswordBox Grid.Column="1"
                                     x:Name="PasswordBox"
                                     Style="{StaticResource FieldPasswordBox}"
                                     PasswordChanged="PasswordBox_PasswordChanged"
                                     Margin="0,0,4,0">
                            <PasswordBox.Resources>
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"
                                                 Color="#B8D8F5"/>
                            </PasswordBox.Resources>
                        </PasswordBox>

                        <TextBox Grid.Column="1"
                                 x:Name="PasswordTextBox"
                                 Style="{StaticResource FieldTextBox}"
                                 Visibility="Collapsed"
                                 Text="{Binding Password, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                 Margin="0,0,4,0">
                            <TextBox.Resources>
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"
                                                 Color="#B8D8F5"/>
                            </TextBox.Resources>
                        </TextBox>

                        <Button Grid.Column="2"
                                x:Name="EyeToggleBtn"
                                Content="👁"
                                FontSize="13"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Click="EyeToggleBtn_Click"
                                FocusVisualStyle="{x:Null}"
                                ToolTip="Show / hide password"/>
                    </Grid>
                </Border>

                <!-- Error message -->
                <Border x:Name="ErrorBanner"
                        Background="{StaticResource ErrorBg}"
                        BorderBrush="{StaticResource ErrorBorder}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="10,7"
                        Margin="0,0,0,12"
                        Visibility="{Binding ErrorMessage,
                                     Converter={StaticResource StringToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="⚠ "
                                   FontSize="12"
                                   Foreground="{StaticResource ErrorFg}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding ErrorMessage}"
                                   FontSize="12"
                                   Foreground="{StaticResource ErrorFg}"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Sign in button -->
                <Button Style="{StaticResource PrimaryBtn}"
                        Command="{Binding LoginCommand}"
                        IsDefault="True">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="→  " FontSize="14" Foreground="White" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding LoginbtnStatus, FallbackValue='Sign in'}"
                                   FontSize="14"
                                   FontWeight="Medium"
                                   Foreground="White"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Footer label -->
                <TextBlock Text="WFA System  ·  v2.0"
                           FontSize="10"
                           Foreground="{StaticResource TextMuted}"
                           HorizontalAlignment="Center"
                           Margin="0,12,0,0"/>

            </StackPanel>
        </Grid>
    </Border>
</Window>