<!--
    ╔══════════════════════════════════════════════════════╗
    ║   Cafeteria Hawa POS  –  Category Management         ║
    ║   Toolbar + Category cards + Subcategory panel       ║
    ╚══════════════════════════════════════════════════════╝
-->
<UserControl x:Class="UI.Views.CategoryManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignWidth="1200" d:DesignHeight="820">

    <UserControl.Resources>

        <!--
            Converters — register these in your App.xaml or a ResourceDictionary:
            BoolToVis              → BooleanToVisibilityConverter  (standard WPF)
            InverseBoolToVis       → InverseBooleanToVisibilityConverter (custom)
        -->
        <BooleanToVisibilityConverter x:Key="BoolToVis" x:Name="BoolToVis"/>

        <!-- ── Palette ── -->
        <SolidColorBrush x:Key="BrandDark"    Color="#1A6FC4"/>
        <SolidColorBrush x:Key="BrandMid"     Color="#2589E0"/>
        <SolidColorBrush x:Key="BrandLight"   Color="#F0F7FF"/>
        <SolidColorBrush x:Key="BrandBorder"  Color="#B8D8F5"/>
        <SolidColorBrush x:Key="CardBg"       Color="#FFFFFF"/>
        <SolidColorBrush x:Key="CardHdrBg"    Color="#F0F7FF"/>
        <SolidColorBrush x:Key="TextDark"     Color="#1A3A5C"/>
        <SolidColorBrush x:Key="TextMuted"    Color="#8AB0CC"/>
        <SolidColorBrush x:Key="SuccessGreen" Color="#16A34A"/>
        <SolidColorBrush x:Key="DangerRed"    Color="#DC2626"/>
        <SolidColorBrush x:Key="DangerHover"  Color="#B91C1C"/>

        <!-- ════════════════════════════════════
             TOOLBAR BUTTON STYLES
             ════════════════════════════════════ -->

        <!-- Primary (Add) -->
        <Style x:Key="PrimaryToolBtn" TargetType="Button">
            <Setter Property="Height"   Value="32"/>
            <Setter Property="Padding"  Value="14,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor"   Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" CornerRadius="7">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1A6FC4" Offset="0"/>
                                    <GradientStop Color="#2589E0" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Outline (Edit / Refresh) -->
        <Style x:Key="OutlineToolBtn" TargetType="Button">
            <Setter Property="Height"   Value="32"/>
            <Setter Property="Padding"  Value="14,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{StaticResource BrandDark}"/>
            <Setter Property="Cursor"   Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                CornerRadius="7"
                                Background="{StaticResource BrandLight}"
                                BorderBrush="{StaticResource BrandBorder}"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#DBEEFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Danger (Delete) -->
        <Style x:Key="DangerToolBtn" TargetType="Button">
            <Setter Property="Height"   Value="32"/>
            <Setter Property="Padding"  Value="14,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{StaticResource DangerRed}"/>
            <Setter Property="Cursor"   Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                CornerRadius="7"
                                Background="#FEE2E2"
                                BorderBrush="#FECACA"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#FECACA"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ════════════════════════════════════
             CATEGORY CARD STYLE
             ════════════════════════════════════ -->
        <Style x:Key="CategoryCard" TargetType="Border">
            <Setter Property="Width"           Value="120"/>
            <Setter Property="Height"          Value="120"/>
            <Setter Property="Margin"          Value="0,0,10,10"/>
            <Setter Property="Background"      Value="{StaticResource CardBg}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BrandBorder}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="CornerRadius"    Value="10"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>

        <!-- ════════════════════════════════════
             SUBCATEGORY CARD STYLE
             ════════════════════════════════════ -->
        <Style x:Key="SubcategoryCard" TargetType="Border">
            <Setter Property="MinWidth"        Value="110"/>
            <Setter Property="Height"          Value="72"/>
            <Setter Property="Margin"          Value="0,0,10,10"/>
            <Setter Property="Background"      Value="{StaticResource CardBg}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BrandBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="8"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="12,8"/>
        </Style>

        <!-- Add Subcategory card (dashed-border style) -->
        <Style x:Key="AddSubcategoryCard" TargetType="Button">
            <Setter Property="MinWidth"  Value="110"/>
            <Setter Property="Height"   Value="72"/>
            <Setter Property="Margin"   Value="0,0,10,10"/>
            <Setter Property="Cursor"   Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                CornerRadius="8"
                                Background="{StaticResource BrandLight}"
                                BorderBrush="{StaticResource BrandBorder}"
                                BorderThickness="1.5"
                                Padding="12,8">
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <TextBlock Text="＋"
                                           FontSize="18"
                                           Foreground="{StaticResource BrandDark}"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="{DynamicResource Manager.Categories.AddSubcategory}"
                                           FontSize="10"
                                           FontWeight="Medium"
                                           Foreground="{StaticResource BrandDark}"
                                           HorizontalAlignment="Center"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#DBEEFF"/>
                                <Setter TargetName="Bg" Property="BorderBrush" Value="{StaticResource BrandDark}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <!-- ════════════════════════════════════════════
         ROOT
         ════════════════════════════════════════════ -->
    <Grid Background="#EAF4FF">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Page header     -->
            <RowDefinition Height="Auto"/>
            <!-- Toolbar         -->
            <RowDefinition Height="*"/>
            <!-- Body            -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════
             PAGE HEADER
             ══════════════════════════════════════ -->
        <TextBlock Grid.Row="0" Text="{DynamicResource Manager.Categories.Title}"
                       FontSize="18" FontWeight="Medium"
                       Foreground="{StaticResource TextDark}"/>

        <!-- ══════════════════════════════════════
             TOOLBAR
             ══════════════════════════════════════ -->
        <Border Grid.Row="1"
                Background="White"
                BorderBrush="{StaticResource BrandBorder}"
                BorderThickness="0.5"
                CornerRadius="10"
                Padding="12,9"
                Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Action buttons -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">

                    <!-- Add -->
                    <Button Style="{StaticResource PrimaryToolBtn}"
                            Margin="0,0,6,0"
                            Command="{Binding AddCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="＋  " FontSize="13" Foreground="White"/>
                            <TextBlock Text="{DynamicResource Common.Add}" FontSize="12" FontWeight="Medium" Foreground="White"/>
                        </StackPanel>
                    </Button>

                    <!-- Edit -->
                    <Button Style="{StaticResource OutlineToolBtn}"
                            Margin="0,0,6,0"
                            IsEnabled="{Binding HasSelection}"
                            Command="{Binding EditCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✏  " FontSize="12"/>
                            <TextBlock Text="{DynamicResource Common.Edit}" FontSize="12"/>
                        </StackPanel>
                    </Button>

                    <!-- Delete -->
                    <Button Style="{StaticResource DangerToolBtn}"
                            Margin="0,0,6,0"
                            IsEnabled="{Binding HasSelection}"
                            Command="{Binding DeleteCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🗑  " FontSize="12" Foreground="{StaticResource DangerRed}"/>
                            <TextBlock Text="{DynamicResource Common.Delete}" FontSize="12" Foreground="{StaticResource DangerRed}"/>
                        </StackPanel>
                    </Button>

                    <!-- Refresh -->
                    <Button Style="{StaticResource OutlineToolBtn}"
                            Command="{Binding RefreshCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔄  " FontSize="12"/>
                            <TextBlock Text="{DynamicResource Common.Refresh}" FontSize="12"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Search box -->
                <Border Grid.Column="2"
                        Background="{StaticResource BrandLight}"
                        BorderBrush="{StaticResource BrandBorder}"
                        BorderThickness="1"
                        CornerRadius="7"
                        Height="32"
                        Width="220">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="🔍"
                                   FontSize="12"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource TextMuted}"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 FontSize="12"
                                 Foreground="{StaticResource TextDark}"
                                 VerticalContentAlignment="Center"
                                 Padding="0,0,8,0"
                                 FocusVisualStyle="{x:Null}">
                            <TextBox.Resources>
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"
                                                 Color="#B8D8F5"/>
                            </TextBox.Resources>
                        </TextBox>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════
             BODY (Categories + Subcategories)
             ══════════════════════════════════════ -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- ─────────────────────────────
                     CATEGORIES PANEL
                     ───────────────────────────── -->
                <Border Background="White"
                        BorderBrush="{StaticResource BrandBorder}"
                        BorderThickness="0.5"
                        CornerRadius="10"
                        Padding="16,14"
                        Margin="0,0,0,10">
                    <StackPanel>

                        <!-- Section label -->
                        <TextBlock Text="{DynamicResource Manager.Categories.SectionCategories}"
                                   FontSize="10" FontWeight="Medium"
                                   Foreground="{StaticResource TextMuted}"
                                   Margin="0,0,0,12"/>

                        <!-- Empty state (no search results) -->
                        <Border Background="#FEF3C7"
                                BorderBrush="#F59E0B"
                                BorderThickness="1"
                                CornerRadius="7"
                                Padding="12,10"
                                Margin="0,0,0,8"
                                Visibility="{Binding IsEmptySearch, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{DynamicResource Manager.Categories.EmptySearchMessage}"
                                       FontSize="12" FontWeight="Medium"
                                       Foreground="#92400E"
                                       TextAlignment="Center"/>
                        </Border>

                        <!-- Category cards wrap panel -->
                        <ItemsControl ItemsSource="{Binding FilteredCategories}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border>

                                        <!-- Selected highlight via DataTrigger -->
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource CategoryCard}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="Background" Value="#DBEEFF"/>
                                                        <Setter Property="BorderBrush" Value="{StaticResource BrandDark}"/>
                                                        <Setter Property="BorderThickness" Value="2"/>
                                                    </DataTrigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#F0F7FF"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <!-- Click to select -->
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick"
                                                          Command="{Binding DataContext.SelectCategoryCommand,
                                                                    RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                          CommandParameter="{Binding}"/>
                                        </Border.InputBindings>

                                        <Grid Margin="10,10,10,8">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- Chevron (top-right) — only if has subcategories -->
                                            <TextBlock Grid.Row="0"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Top"
                                                       FontSize="10"
                                                       Foreground="{StaticResource TextMuted}"
                                                       Visibility="{Binding HasSubcategories,
                                                                    Converter={StaticResource BoolToVis}}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="▸"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                <Setter Property="Text" Value="▾"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <!-- Icon -->
                                            <TextBlock Grid.Row="1"
                                                       Text="{Binding Icon}"
                                                       FontSize="28"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,0,6"/>

                                            <!-- Name -->
                                            <TextBlock Grid.Row="2"
                                                       Text="{Binding Name}"
                                                       FontSize="12" FontWeight="Medium"
                                                       Foreground="{StaticResource TextDark}"
                                                       HorizontalAlignment="Center"
                                                       TextWrapping="Wrap"
                                                       TextAlignment="Center"
                                                       Margin="0,0,0,3"/>

                                            <!-- Count label -->
                                            <TextBlock Grid.Row="3"
                                                       Text="{Binding CountLabel}"
                                                       FontSize="10"
                                                       Foreground="{StaticResource TextMuted}"
                                                       HorizontalAlignment="Center"
                                                       TextAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- ─────────────────────────────
                     SUBCATEGORIES PANEL
                     Only shown when a category
                     with subcategories is selected
                     ───────────────────────────── -->
                <Border Background="White"
                        BorderBrush="{StaticResource BrandBorder}"
                        BorderThickness="0.5"
                        CornerRadius="10"
                        Padding="16,14"
                        Visibility="{Binding IsSubcategoriesPanelVisible, Converter={StaticResource BoolToVis}}">
                    <StackPanel>

                        <!-- Section header: icon + parent name -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="{Binding SelectedCategory.Icon}"
                                       FontSize="16"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0"/>
                            <TextBlock FontSize="13" FontWeight="Medium"
                                       Foreground="{StaticResource TextDark}"
                                       VerticalAlignment="Center">
                                <Run Text="{Binding SelectedCategory.Name}"/>
                                <Run Text="{DynamicResource Manager.Categories.SubcategoriesSuffix}"
                                     Foreground="{StaticResource TextMuted}"
                                     FontWeight="Normal"/>
                            </TextBlock>
                        </StackPanel>

                        <!-- Empty state for subcategories -->
                        <TextBlock Text="{DynamicResource Manager.Categories.EmptySubcategoriesMessage}"
                                   FontSize="12"
                                   Foreground="{StaticResource TextMuted}"
                                   Margin="0,0,0,10"
                                   Visibility="{Binding IsSubcategoriesEmpty, Converter={StaticResource BoolToVis}}"/>

                        <!-- Subcategory cards + Add card -->
                        <WrapPanel Orientation="Horizontal">

                            <!-- Subcategory cards -->
                            <ItemsControl ItemsSource="{Binding Subcategories}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border>
                                            <Border.Style>
                                                <Style TargetType="Border" BasedOn="{StaticResource SubcategoryCard}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="Background" Value="#DBEEFF"/>
                                                            <Setter Property="BorderBrush" Value="{StaticResource BrandDark}"/>
                                                            <Setter Property="BorderThickness" Value="2"/>
                                                        </DataTrigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#F0F7FF"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>

                                            <Border.InputBindings>
                                                <MouseBinding MouseAction="LeftClick"
                                                              Command="{Binding DataContext.SelectSubcategoryCommand,
                                                                        RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                              CommandParameter="{Binding}"/>
                                            </Border.InputBindings>

                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="12" FontWeight="Medium"
                                                           Foreground="{StaticResource TextDark}"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding CountLabel}"
                                                           FontSize="10"
                                                           Foreground="{StaticResource TextMuted}"
                                                           Margin="0,3,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- + Add Subcategory card (always last) -->
                            <Button Style="{StaticResource AddSubcategoryCard}"
                                    Command="{Binding AddSubcategoryCommand}"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>
