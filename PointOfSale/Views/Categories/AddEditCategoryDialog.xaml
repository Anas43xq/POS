<!--
    ╔══════════════════════════════════════════════════════╗
    ║   Cafeteria Hawa POS  –  Add / Edit Category Dialog  ║
    ║   Modal popup with overlay dismiss                   ║
    ╚══════════════════════════════════════════════════════╝
-->
<Window x:Class="UI.Views.AddEditCategoryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="Category"
        Width="440" Height="400"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- ── Palette ── -->
        <SolidColorBrush x:Key="BrandDark"   Color="#1A6FC4"/>
        <SolidColorBrush x:Key="BrandMid"    Color="#2589E0"/>
        <SolidColorBrush x:Key="BrandLight"  Color="#F0F7FF"/>
        <SolidColorBrush x:Key="BrandBorder" Color="#B8D8F5"/>
        <SolidColorBrush x:Key="TextDark"    Color="#1A3A5C"/>
        <SolidColorBrush x:Key="TextMuted"   Color="#8AB0CC"/>
        <SolidColorBrush x:Key="ErrorFg"     Color="#A32D2D"/>
        <SolidColorBrush x:Key="ErrorBg"     Color="#FFF0F0"/>
        <SolidColorBrush x:Key="ErrorBorder" Color="#F5C1C1"/>

        <!-- ── Field label ── -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{StaticResource BrandDark}"/>
            <Setter Property="Margin"     Value="0,0,0,5"/>
        </Style>

        <!-- ── Input field border ── -->
        <Style x:Key="InputBorder" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource BrandLight}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BrandBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="8"/>
            <Setter Property="Height"          Value="36"/>
        </Style>

        <!-- ── TextBox inside input ── -->
        <Style x:Key="FieldTextBox" TargetType="TextBox">
            <Setter Property="Background"               Value="Transparent"/>
            <Setter Property="BorderThickness"          Value="0"/>
            <Setter Property="FontSize"                 Value="13"/>
            <Setter Property="Foreground"               Value="{StaticResource TextDark}"/>
            <Setter Property="CaretBrush"               Value="{StaticResource BrandDark}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding"                  Value="10,0"/>
            <Setter Property="FocusVisualStyle"         Value="{x:Null}"/>
        </Style>

        <!-- ── ComboBox ── -->
        <Style x:Key="FieldComboBox" TargetType="ComboBox">
            <Setter Property="Background"               Value="{StaticResource BrandLight}"/>
            <Setter Property="BorderBrush"              Value="{StaticResource BrandBorder}"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="FontSize"                 Value="13"/>
            <Setter Property="Foreground"               Value="{StaticResource TextDark}"/>
            <Setter Property="Height"                   Value="36"/>
            <Setter Property="Padding"                  Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle"         Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Bg"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8"/>
                            <Grid Margin="{TemplateBinding Padding}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                                  VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="▾"
                                           FontSize="10"
                                           Foreground="{StaticResource BrandDark}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                            <ToggleButton IsChecked="{Binding IsDropDownOpen,
                                          RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Background="Transparent" BorderThickness="0" ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent"/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   AllowsTransparency="True">
                                <Border Background="White"
                                        BorderBrush="{StaticResource BrandBorder}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Margin="0,4,0,0"
                                        MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer MaxHeight="200">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="BorderBrush"
                                        Value="{StaticResource BrandDark}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Padding"  Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource TextDark}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bg" Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#F0F7FF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#DBEEFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Save (primary) button ── -->
        <Style x:Key="SaveBtn" TargetType="Button">
            <Setter Property="Height"   Value="36"/>
            <Setter Property="Padding"  Value="22,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor"   Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" CornerRadius="7">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1A6FC4" Offset="0"/>
                                    <GradientStop Color="#2589E0" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Cancel button ── -->
        <Style x:Key="CancelBtn" TargetType="Button">
            <Setter Property="Height"   Value="36"/>
            <Setter Property="Padding"  Value="22,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="Cursor"   Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                CornerRadius="7"
                                Background="White"
                                BorderBrush="{StaticResource BrandBorder}"
                                BorderThickness="1.5">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#F0F7FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!--
         Semi-transparent overlay — clicking it closes the dialog (code-behind).
         The card is centered inside it.
    -->
    <Grid x:Name="OverlayGrid"
          Background="#55000000"
          MouseDown="OverlayGrid_MouseDown">

        <!-- Card — clicks here do NOT propagate to overlay -->
        <Border x:Name="DialogCard"
                Width="400"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                CornerRadius="14"
                Background="White"
                BorderBrush="{StaticResource BrandBorder}"
                BorderThickness="0.5"
                MouseDown="DialogCard_MouseDown">
            <Border.Effect>
                <DropShadowEffect BlurRadius="24" ShadowDepth="6"
                                  Direction="270" Opacity="0.14" Color="#1A3A5C"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Header  -->
                    <RowDefinition Height="Auto"/>
                    <!-- Error   -->
                    <RowDefinition Height="*"/>
                    <!-- Fields  -->
                    <RowDefinition Height="Auto"/>
                    <!-- Footer  -->
                </Grid.RowDefinitions>

                <!-- ── Header ── -->
                <Border Grid.Row="0"
                        CornerRadius="14,14,0,0"
                        BorderBrush="#E8F3FF"
                        BorderThickness="0,0,0,0.5"
                        Background="{StaticResource BrandLight}"
                        Padding="18,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{Binding DialogTitle, FallbackValue='Add Category'}"
                                   FontSize="14" FontWeight="Medium"
                                   Foreground="{StaticResource TextDark}"
                                   VerticalAlignment="Center"/>

                        <!-- ✕ close -->
                        <Button Grid.Column="1"
                                Content="✕"
                                FontSize="13"
                                Foreground="{StaticResource TextMuted}"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                Command="{Binding CancelCommand}"
                                FocusVisualStyle="{x:Null}"/>
                    </Grid>
                </Border>

                <!-- ── Validation error banner ── -->
                <Border Grid.Row="1"
                        Background="{StaticResource ErrorBg}"
                        BorderBrush="{StaticResource ErrorBorder}"
                        BorderThickness="1"
                        CornerRadius="7"
                        Padding="12,8"
                        Margin="18,12,18,0"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠ " FontSize="13" Foreground="{StaticResource ErrorFg}"/>
                        <TextBlock Text="{Binding ErrorMessage}"
                                   FontSize="12"
                                   Foreground="{StaticResource ErrorFg}"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- ── Fields ── -->
                <StackPanel Grid.Row="2" Margin="18,16,18,8">

                    <!-- Name -->
                    <TextBlock Text="Name" Style="{StaticResource FieldLabel}"/>
                    <Border Style="{StaticResource InputBorder}" Margin="0,0,0,14">
                        <TextBox x:Name="NameBox"
                                 Style="{StaticResource FieldTextBox}"
                                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}">
                            <TextBox.Resources>
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"
                                                 Color="#B8D8F5"/>
                            </TextBox.Resources>
                        </TextBox>
                    </Border>

                    <!-- Parent Category -->
                    <TextBlock Text="Parent Category" Style="{StaticResource FieldLabel}"/>
                    <ComboBox Style="{StaticResource FieldComboBox}"
                              ItemsSource="{Binding ParentCategoryOptions}"
                              SelectedItem="{Binding SelectedParent}"
                              DisplayMemberPath="DisplayName"
                              Margin="0,0,0,4"/>
                    <TextBlock Text="Leave as &quot;— None —&quot; to create a top-level category."
                               FontSize="10"
                               Foreground="{StaticResource TextMuted}"
                               Margin="0,0,0,14"/>

                    <!-- Icon -->
                    <TextBlock Text="Icon" Style="{StaticResource FieldLabel}"/>
                    <Border Style="{StaticResource InputBorder}" Width="80" HorizontalAlignment="Left">
                        <TextBox Style="{StaticResource FieldTextBox}"
                                 Text="{Binding Icon, UpdateSourceTrigger=PropertyChanged}"
                                 MaxLength="2"
                                 TextAlignment="Center"
                                 FontSize="18">
                            <TextBox.Resources>
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"
                                                 Color="#B8D8F5"/>
                            </TextBox.Resources>
                        </TextBox>
                    </Border>

                </StackPanel>

                <!-- ── Footer ── -->
                <Border Grid.Row="3"
                        Background="{StaticResource BrandLight}"
                        BorderBrush="{StaticResource BrandBorder}"
                        BorderThickness="0,0.5,0,0"
                        CornerRadius="0,0,14,14"
                        Padding="18,12">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource CancelBtn}"
                                Content="Cancel"
                                Margin="0,0,10,0"
                                Command="{Binding CancelCommand}"/>
                        <Button Style="{StaticResource SaveBtn}"
                                Content="Save"
                                Command="{Binding SaveCommand}"/>
                    </StackPanel>
                </Border>

            </Grid>
        </Border>
    </Grid>
</Window>
