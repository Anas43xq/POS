<Window x:Class="UI.Views.ProductFormView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="Product"
        Width="520" Height="520"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        KeyDown="ProductFormView_KeyDown">

    <Window.Resources>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- ── Palette ── -->
        <SolidColorBrush x:Key="BrandDark"   Color="#1A6FC4"/>
        <SolidColorBrush x:Key="BrandMid"    Color="#2589E0"/>
        <SolidColorBrush x:Key="BrandLight"  Color="#F0F7FF"/>
        <SolidColorBrush x:Key="BrandBorder" Color="#B8D8F5"/>
        <SolidColorBrush x:Key="CardHdrBg"   Color="#F0F7FF"/>
        <SolidColorBrush x:Key="TextDark"    Color="#1A3A5C"/>
        <SolidColorBrush x:Key="TextMuted"   Color="#8AB0CC"/>
        <SolidColorBrush x:Key="ErrorFg"     Color="#A32D2D"/>
        <SolidColorBrush x:Key="ErrorBg"     Color="#FFF0F0"/>
        <SolidColorBrush x:Key="ErrorBorder" Color="#F5C1C1"/>

        <!-- ── Field label ── -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{StaticResource BrandDark}"/>
            <Setter Property="Margin"     Value="0,0,0,4"/>
        </Style>

        <!-- ── Input border ── -->
        <Style x:Key="InputBorder" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource BrandLight}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BrandBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="7"/>
            <Setter Property="Height"          Value="34"/>
        </Style>

        <!-- ── TextBox ── -->
        <Style x:Key="FieldTextBox" TargetType="TextBox">
            <Setter Property="Background"               Value="Transparent"/>
            <Setter Property="BorderThickness"          Value="0"/>
            <Setter Property="FontSize"                 Value="12"/>
            <Setter Property="Foreground"               Value="{StaticResource TextDark}"/>
            <Setter Property="CaretBrush"               Value="{StaticResource BrandDark}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding"                  Value="9,0"/>
            <Setter Property="FocusVisualStyle"         Value="{x:Null}"/>
        </Style>

        <!-- ── Multiline TextBox ── -->
        <Style x:Key="FieldTextBoxMulti" TargetType="TextBox"
               BasedOn="{StaticResource FieldTextBox}">
            <Setter Property="AcceptsReturn"            Value="True"/>
            <Setter Property="TextWrapping"             Value="Wrap"/>
            <Setter Property="VerticalContentAlignment" Value="Top"/>
            <Setter Property="Padding"                  Value="9,7"/>
        </Style>

        <!-- ── ComboBox ── -->
        <Style x:Key="FieldComboBox" TargetType="ComboBox">
            <Setter Property="Background"               Value="{StaticResource BrandLight}"/>
            <Setter Property="BorderBrush"              Value="{StaticResource BrandBorder}"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="FontSize"                 Value="12"/>
            <Setter Property="Foreground"               Value="{StaticResource TextDark}"/>
            <Setter Property="Height"                   Value="34"/>
            <Setter Property="Padding"                  Value="9,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle"         Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Bg"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="7"/>
                            <Grid Margin="{TemplateBinding Padding}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="18"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                                  VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="▾" FontSize="10"
                                           Foreground="{StaticResource BrandDark}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                            <ToggleButton IsChecked="{Binding IsDropDownOpen,
                                          RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Background="Transparent" BorderThickness="0" ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent"/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom" AllowsTransparency="True">
                                <Border Background="White"
                                        BorderBrush="{StaticResource BrandBorder}"
                                        BorderThickness="1" CornerRadius="7"
                                        Margin="0,3,0,0"
                                        MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer MaxHeight="200">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="BorderBrush"
                                        Value="{StaticResource BrandDark}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Padding"    Value="9,7"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextDark}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bg" Background="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#F0F7FF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#DBEEFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── CheckBox ── -->
        <Style x:Key="FieldCheckBox" TargetType="CheckBox">
            <Setter Property="FontSize"                Value="12"/>
            <Setter Property="Foreground"              Value="{StaticResource TextDark}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- ── Save button ── -->
        <Style x:Key="SaveBtn" TargetType="Button">
            <Setter Property="Height"     Value="34"/>
            <Setter Property="Padding"    Value="20,0"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" CornerRadius="7">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1A6FC4" Offset="0"/>
                                    <GradientStop Color="#2589E0" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Cancel button ── -->
        <Style x:Key="CancelBtn" TargetType="Button">
            <Setter Property="Height"     Value="34"/>
            <Setter Property="Padding"    Value="20,0"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" CornerRadius="7" Background="White"
                                BorderBrush="{StaticResource BrandBorder}"
                                BorderThickness="1.5">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#F0F7FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- Transparent background — click outside closes dialog -->
    <Grid x:Name="OverlayGrid"
          Background="Transparent"
          MouseDown="OverlayGrid_MouseDown">

        <!-- Dialog card -->
        <Border x:Name="DialogCard"
                Width="480"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                CornerRadius="14"
                Background="White"
                BorderBrush="{StaticResource BrandBorder}"
                BorderThickness="0.5"
                MouseDown="DialogCard_MouseDown">
            <Border.Effect>
                <DropShadowEffect BlurRadius="28" ShadowDepth="6"
                                  Direction="270" Opacity="0.13" Color="#1A3A5C"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Header         -->
                    <RowDefinition Height="Auto"/>
                    <!-- Exists warning -->
                    <RowDefinition Height="*"/>
                    <!-- Form body      -->
                    <RowDefinition Height="Auto"/>
                    <!-- Footer         -->
                </Grid.RowDefinitions>

                <!-- ── HEADER ── -->
                <Border Grid.Row="0"
                        CornerRadius="14,14,0,0"
                        Background="{StaticResource BrandLight}"
                        BorderBrush="#E8F3FF"
                        BorderThickness="0,0,0,0.5"
                        Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="28" Height="28" CornerRadius="7"
                                    Background="{StaticResource BrandDark}"
                                    Margin="0,0,9,0">
                                <TextBlock Text="📦" FontSize="14"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="{Binding FormTitle, FallbackValue='Add Product'}"
                                       FontSize="13" FontWeight="Medium"
                                       Foreground="{StaticResource TextDark}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Content="✕" FontSize="13"
                                Foreground="{StaticResource TextMuted}"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand" Command="{Binding CancelCommand}"
                                FocusVisualStyle="{x:Null}"/>
                    </Grid>
                </Border>

                <!-- ── DUPLICATE WARNING ── -->
                <Border Grid.Row="1"
                        Background="{StaticResource ErrorBg}"
                        BorderBrush="{StaticResource ErrorBorder}"
                        BorderThickness="1" CornerRadius="7"
                        Padding="11,8" Margin="16,10,16,0"
                        Visibility="{Binding ProductExistsWarning, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠ " FontSize="13" Foreground="{StaticResource ErrorFg}"/>
                        <TextBlock Text="A product with this name already exists in the selected category."
                                   FontSize="11" Foreground="{StaticResource ErrorFg}"
                                   TextWrapping="Wrap" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- ── FORM BODY ── -->
                <Grid Grid.Row="2" Margin="16,14,16,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Name | Category  -->
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <!-- Price | Tax       -->
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <!-- Is Active | Addl  -->
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <!-- Description       -->
                    </Grid.RowDefinitions>

                    <!-- ROW 0 · Product Name | Category -->
                    <StackPanel Grid.Row="0" Grid.Column="0">
                        <TextBlock Text="Product Name" Style="{StaticResource FieldLabel}"/>
                        <Border Style="{StaticResource InputBorder}">
                            <TextBox Style="{StaticResource FieldTextBox}"
                                     Text="{Binding ProductName, UpdateSourceTrigger=PropertyChanged}">
                                <TextBox.Resources>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"
                                                     Color="#B8D8F5"/>
                                </TextBox.Resources>
                            </TextBox>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="2">
                        <TextBlock Text="Category" Style="{StaticResource FieldLabel}"/>
                        <ComboBox Style="{StaticResource FieldComboBox}"
                                  ItemsSource="{Binding CategoryOptions}"
                                  SelectedItem="{Binding SelectedCategory}"
                                  DisplayMemberPath="Name"/>
                    </StackPanel>

                    <!-- ROW 2 · Price | Tax -->
                    <StackPanel Grid.Row="2" Grid.Column="0">
                        <TextBlock Text="Price (AED)" Style="{StaticResource FieldLabel}"/>
                        <Border Style="{StaticResource InputBorder}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="AED"
                                           FontSize="10" Foreground="{StaticResource TextMuted}"
                                           VerticalAlignment="Center" Margin="9,0,0,0"/>
                                <TextBox Grid.Column="1"
                                         Style="{StaticResource FieldTextBox}"
                                         Text="{Binding Price, UpdateSourceTrigger=PropertyChanged,
                                                StringFormat=N2}"/>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="2">
                        <TextBlock Text="Tax" Style="{StaticResource FieldLabel}"/>
                        <ComboBox Style="{StaticResource FieldComboBox}"
                                  ItemsSource="{Binding TaxOptions}"
                                  SelectedItem="{Binding SelectedTax}"
                                  DisplayMemberPath="Name"/>
                    </StackPanel>

                    <!-- ROW 4 · Is Active | Additional Tax -->
                    <Border Grid.Row="4" Grid.Column="0"
                            Background="{StaticResource BrandLight}"
                            BorderBrush="{StaticResource BrandBorder}"
                            BorderThickness="1" CornerRadius="7"
                            Height="34" Padding="9,0">
                        <CheckBox Style="{StaticResource FieldCheckBox}"
                                  Content="Is active (visible to cashiers)"
                                  IsChecked="{Binding IsActive}"
                                  VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Row="4" Grid.Column="2">
                        <CheckBox Style="{StaticResource FieldCheckBox}"
                                  Content="Additional tax"
                                  IsChecked="{Binding HasAdditionalTax}"
                                  Margin="0,0,0,6"/>
                        <Border Style="{StaticResource InputBorder}"
                                Visibility="{Binding HasAdditionalTax, Converter={StaticResource BoolToVis}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="AED"
                                           FontSize="10" Foreground="{StaticResource TextMuted}"
                                           VerticalAlignment="Center" Margin="9,0,0,0"/>
                                <TextBox Grid.Column="1"
                                         Style="{StaticResource FieldTextBox}"
                                         Text="{Binding AdditionalTaxAmount,
                                                UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- ROW 6 · Description (full width, optional) -->
                    <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="3">
                        <TextBlock Style="{StaticResource FieldLabel}">
                            <Run Text="Description"/>
                            <Run Text=" (optional)"
                                 Foreground="{StaticResource TextMuted}"
                                 FontWeight="Normal"/>
                        </TextBlock>
                        <Border Background="{StaticResource BrandLight}"
                                BorderBrush="{StaticResource BrandBorder}"
                                BorderThickness="1" CornerRadius="7" Height="58">
                            <TextBox Style="{StaticResource FieldTextBoxMulti}"
                                     Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"/>
                        </Border>
                    </StackPanel>

                </Grid>

                <!-- ── FOOTER ── -->
                <Border Grid.Row="3"
                        Background="{StaticResource CardHdrBg}"
                        BorderBrush="{StaticResource BrandBorder}"
                        BorderThickness="0,0.5,0,0"
                        CornerRadius="0,0,14,14"
                        Padding="16,10">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource CancelBtn}"
                                Content="Cancel" Margin="0,0,8,0"
                                Command="{Binding CancelCommand}"/>
                        <Button Style="{StaticResource SaveBtn}"
                                Content="{Binding SaveButtonLabel, FallbackValue='Save Product'}"
                                Command="{Binding SaveCommand}"/>
                    </StackPanel>
                </Border>

            </Grid>
        </Border>
    </Grid>
</Window>