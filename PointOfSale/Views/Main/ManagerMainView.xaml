<!--
    ╔══════════════════════════════════════════════════════╗
    ║   Cafeteria Hawa POS  –  Manager Main Shell          ║
    ║   Header + Navy Sidebar + Content Frame              ║
    ╚══════════════════════════════════════════════════════╝
-->
<UserControl x:Class="UI.Views.ManagerMainView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:UI.ViewModels"
             xmlns:views="clr-namespace:UI.Views"
             mc:Ignorable="d"
             d:DesignHeight="900" d:DesignWidth="1600"
             Background="#EAF4FF">

    <UserControl.Resources>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- ── Palette ── -->
        <SolidColorBrush x:Key="BrandDark"   Color="#1A6FC4"/>
        <SolidColorBrush x:Key="BrandMid"    Color="#2589E0"/>
        <SolidColorBrush x:Key="BrandBorder" Color="#B8D8F5"/>
        <SolidColorBrush x:Key="TextDark"    Color="#1A3A5C"/>
        <SolidColorBrush x:Key="TextMuted"   Color="#8AB0CC"/>
        <SolidColorBrush x:Key="DangerRed"   Color="#DC2626"/>
        <SolidColorBrush x:Key="DangerHover" Color="#B91C1C"/>
        <SolidColorBrush x:Key="SidebarTop"  Color="#0F2A4A"/>
        <SolidColorBrush x:Key="SidebarBot"  Color="#1A3F6B"/>
        <SolidColorBrush x:Key="NavIdleFg"   Color="#99FFFFFF"/>
        <SolidColorBrush x:Key="NavHoverBg"  Color="#12FFFFFF"/>
        <SolidColorBrush x:Key="NavActiveBg" Color="#402589E0"/>

        <!-- ── Header neutral button (e.g. Settings) ── -->
        <Style x:Key="HdrBtn" TargetType="Button">
            <Setter Property="Height"   Value="30"/>
            <Setter Property="Padding"  Value="10,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{StaticResource BrandDark}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrandBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                CornerRadius="7"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#DBEEFF"/>
                                <Setter TargetName="Bg" Property="BorderBrush" Value="{StaticResource BrandDark}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bg" Property="BorderBrush" Value="{StaticResource BrandDark}"/>
                                <Setter TargetName="Bg" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Header icon/danger button ── -->
        <Style x:Key="HdrDangerBtn" TargetType="Button">
            <Setter Property="Height"   Value="30"/>
            <Setter Property="Padding"  Value="12,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" CornerRadius="7" Background="{StaticResource DangerRed}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource DangerHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.88"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Sidebar section label ── -->
        <Style x:Key="SidebarSectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="9"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="#4DFFFFFF"/>
            <Setter Property="Margin"     Value="16,10,16,4"/>
        </Style>

        <!-- ── Nav item (RadioButton acting as toggle nav) ── -->
        <Style x:Key="NavItem" TargetType="RadioButton">
            <Setter Property="GroupName"  Value="ManagerNav"/>
            <Setter Property="Height"     Value="38"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bg"
                                Background="Transparent"
                                BorderBrush="{StaticResource BrandMid}"
                                BorderThickness="3,0,0,0"
                                Padding="13,0,16,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <ContentPresenter x:Name="IconPresenter"
                                                  Content="{TemplateBinding Tag}"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,9,0"/>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource NavHoverBg}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource NavActiveBg}"/>
                                <Setter TargetName="Bg" Property="BorderBrush" Value="{StaticResource BrandMid}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter TargetName="Bg" Property="BorderBrush" Value="Transparent"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Nav item icon glyph ── -->
        <Style x:Key="NavIcon" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Width"    Value="18"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>

        <!-- ── Nav item label ── -->
        <Style x:Key="NavLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <DataTemplate DataType="{x:Type vm:HomeViewModel}">
            <views:HomeView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:TransactionsViewModel}">
            <views:TransactionsView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:ShiftManagementViewModel}">
            <views:ShiftManagementView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:ReportViewModel}">
            <views:ReportView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:ProductManagementViewModel}">
            <views:ProductManagementView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:CategoryManagementViewModel}">
            <views:CategoryManagementView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:ReceiptManagementViewModel}">
            <views:ReceiptManagementView />
        </DataTemplate>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <!-- Header  -->
            <RowDefinition Height="*"/>
            <!-- Body    -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════
             ROW 0 · HEADER
             ══════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="White"
                BorderBrush="{StaticResource BrandBorder}"
                BorderThickness="0,0,0,0.5"
                Padding="16,0">
            <Grid VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <!-- Logo+title    -->
                    <ColumnDefinition Width="*"/>
                    <!-- Manager name  -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Date/time     -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Settings      -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Logout        -->
                </Grid.ColumnDefinitions>

                <!-- Logo + brand -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,10,0">
                    <Border Width="30" Height="30" CornerRadius="8" Margin="0,0,8,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#1A6FC4" Offset="0"/>
                                <GradientStop Color="#2589E0" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="🏪" FontSize="16"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="{DynamicResource Login.Brand}"
                               FontSize="14" FontWeight="Medium"
                               Foreground="{StaticResource TextDark}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Manager name -->
                <TextBlock Grid.Column="1"
                           Text="{Binding ManagerName, FallbackValue='Sarah (Manager)'}"
                           FontSize="12" FontWeight="Medium"
                           Foreground="{StaticResource TextDark}"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0"/>

                <!-- Date/time -->
                <TextBlock Grid.Column="2"
                           Text="{Binding CurrentDateTime}"
                           FontSize="11"
                           Foreground="{StaticResource TextMuted}"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0"/>

                <!-- Settings (gear icon) — mirrors the cashier header -->
                <Button Grid.Column="3"
                        Style="{StaticResource HdrBtn}"
                        Margin="0,0,6,0"
                        Command="{Binding ShowSetting}"
                        ToolTip="{DynamicResource Settings.Title}">
                    <TextBlock Text="&#xE713;"
                               FontSize="14"
                               FontFamily="Segoe MDL2 Assets"
                               Foreground="{StaticResource BrandDark}"
                               VerticalAlignment="Center"/>
                </Button>

                <!-- Logout -->
                <Button Grid.Column="4"
                        Style="{StaticResource HdrDangerBtn}"
                        Command="{Binding LogoutCommand}">
                    <TextBlock>
                        <Run Text="⎋  "/>
                        <Run Text="{DynamicResource Common.Logout}"/>
                    </TextBlock>
                </Button>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════
             ROW 1 · BODY (Sidebar + Content)
             ══════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ─────────────────────────────────
                 SIDEBAR
                 ───────────────────────────────── -->
            <Border Grid.Column="0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#0F2A4A" Offset="0"/>
                        <GradientStop Color="#1A3F6B" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <StackPanel Margin="0,10,0,0">

                    <TextBlock Text="{DynamicResource Manager.Nav.Menu}" Style="{StaticResource SidebarSectionLabel}"/>

                    <RadioButton Style="{StaticResource NavItem}"
                                 IsChecked="True"
                                 Command="{Binding NavigateHomeCommand}">
                        <RadioButton.Tag>
                            <TextBlock Text="🏠" Style="{StaticResource NavIcon}"/>
                        </RadioButton.Tag>
                        <TextBlock Text="{DynamicResource Manager.Nav.Home}" Style="{StaticResource NavLabel}"/>
                    </RadioButton>

                    <RadioButton Style="{StaticResource NavItem}"
                                 Command="{Binding NavigateTransactionsCommand}">
                        <RadioButton.Tag>
                            <TextBlock Text="🧾" Style="{StaticResource NavIcon}"/>
                        </RadioButton.Tag>
                        <TextBlock Text="{DynamicResource Manager.Nav.Transactions}" Style="{StaticResource NavLabel}"/>
                    </RadioButton>

                    <RadioButton Style="{StaticResource NavItem}"
                                 Command="{Binding NavigateShiftManagementCommand}">
                        <RadioButton.Tag>
                            <TextBlock Text="🕓" Style="{StaticResource NavIcon}"/>
                        </RadioButton.Tag>
                        <TextBlock Text="{DynamicResource Manager.Nav.ShiftManagement}" Style="{StaticResource NavLabel}"/>
                    </RadioButton>

                    <RadioButton Style="{StaticResource NavItem}"
                                 Command="{Binding NavigateReportsCommand}">
                        <RadioButton.Tag>
                            <TextBlock Text="📊" Style="{StaticResource NavIcon}"/>
                        </RadioButton.Tag>
                        <TextBlock Text="{DynamicResource Manager.Nav.Reports}" Style="{StaticResource NavLabel}"/>
                    </RadioButton>

                     <RadioButton Style="{StaticResource NavItem}"
                                  Command="{Binding NavigateProductManagementCommand}">
                         <RadioButton.Tag>
                             <TextBlock Text="📦" Style="{StaticResource NavIcon}"/>
                         </RadioButton.Tag>
                         <TextBlock Text="{DynamicResource Manager.Nav.Products}" Style="{StaticResource NavLabel}"/>
                     </RadioButton>

                     <RadioButton Style="{StaticResource NavItem}"
                                  Command="{Binding NavigateCategoryManagementCommand}">
                         <RadioButton.Tag>
                             <TextBlock Text="🏷" Style="{StaticResource NavIcon}"/>
                         </RadioButton.Tag>
                         <TextBlock Text="{DynamicResource Manager.Nav.Categories}" Style="{StaticResource NavLabel}"/>
                     </RadioButton>

                     <RadioButton Style="{StaticResource NavItem}"
                                  Command="{Binding NavigateReceiptManagementCommand}">
                         <RadioButton.Tag>
                             <TextBlock Text="🧾" Style="{StaticResource NavIcon}"/>
                         </RadioButton.Tag>
                         <TextBlock Text="{DynamicResource Manager.Nav.ReceiptManagement}" Style="{StaticResource NavLabel}"/>
                     </RadioButton>

                 </StackPanel>
            </Border>

            <!-- ─────────────────────────────────
                 CONTENT FRAME
                 Hosts HomeView / TransactionsView / etc.
                 via Frame or ContentControl bound to
                 the active ViewModel.
                 ───────────────────────────────── -->
            <Border Grid.Column="1" Background="#EAF4FF">
                <ContentControl Content="{Binding CurrentPage}" Margin="12"/>
            </Border>

        </Grid>
    </Grid>
</UserControl>
