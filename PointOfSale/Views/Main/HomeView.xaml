<!--
    ╔══════════════════════════════════════════════════════╗
    ║   Cafeteria Hawa POS  –  Manager · Home View         ║
    ║   Filter bar + 3-column dashboard                    ║
    ╚══════════════════════════════════════════════════════╝
-->
<UserControl x:Class="UI.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
              xmlns:controls="clr-namespace:UI.Controls"
             mc:Ignorable="d" d:DesignHeight="820" Width="1225">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/AppChrome.xaml"/>
            </ResourceDictionary.MergedDictionaries>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- ── Small action chip (e.g. "View all") ── -->
        <Style x:Key="CardActionBtn" TargetType="Button">
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="Foreground" Value="{StaticResource BrandDark}"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="#DBEEFF" CornerRadius="5" Padding="8,3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#C5E2FA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── KPI tile ── -->
        <Style x:Key="KpiTile" TargetType="Border" BasedOn="{StaticResource DashboardKpiTile}"/>

        <Style x:Key="KpiLabel" TargetType="TextBlock" BasedOn="{StaticResource DashboardKpiLabel}"/>

        <Style x:Key="KpiValue" TargetType="TextBlock" BasedOn="{StaticResource DashboardKpiValue}"/>

        <Style x:Key="KpiValueCurrency" TargetType="controls:CurrencyText" BasedOn="{StaticResource DashboardKpiValueCurrency}"/>

        <!-- ── List row separator ── -->
        <Style x:Key="ListRow" TargetType="Border">
            <Setter Property="BorderBrush"     Value="{StaticResource BrandLight}"/>
            <Setter Property="BorderThickness" Value="0,0,0,0.5"/>
            <Setter Property="Padding"         Value="0,6"/>
        </Style>

        <!-- ── List column header label ── -->
        <Style x:Key="ColLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="9"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
        </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="#EAF4FF">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Filter bar -->
            <RowDefinition Height="*"/>
            <!-- 3-column grid -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════
             FILTER BAR
             ══════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="White"
                BorderBrush="{StaticResource BrandBorder}"
                BorderThickness="0.5"
                CornerRadius="10"
                Padding="12,9"
                Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">

                    <RadioButton Style="{StaticResource FilterChip}" Content="Today" IsChecked="True"
                                 Command="{Binding FilterTodayCommand}"/>
                    <RadioButton Style="{StaticResource FilterChip}" Content="This Week"
                                 Command="{Binding FilterThisWeekCommand}"/>
                    <RadioButton Style="{StaticResource FilterChip}" Content="This Month"
                                 Command="{Binding FilterMonthCommand}"/>
                    <RadioButton Style="{StaticResource FilterChip}" Content="Period"
                                 Command="{Binding ShowPeriodFilterCommand}"/>

                    <Border Width="1" Height="20" Background="{StaticResource BrandBorder}" Margin="6,0"/>

                    <TextBlock Text="From" FontSize="11" Foreground="{StaticResource TextMuted}"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <DatePicker Style="{StaticResource DateInput}"
                                SelectedDate="{Binding PeriodFromDate}"
                                Margin="0,0,12,0"/>

                    <TextBlock Text="To" FontSize="11" Foreground="{StaticResource TextMuted}"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <DatePicker Style="{StaticResource DateInput}"
                                SelectedDate="{Binding PeriodToDate}"
                                Margin="0,0,12,0"/>

                    <Button Style="{StaticResource ApplyBtn}"
                            Content="Apply"
                            Command="{Binding ApplyPeriodFilterCommand}"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="🔄 Refresh"
                        Height="34"
                        Padding="16,0"
                        FontSize="12"
                        Foreground="White"
                        Background="{StaticResource BrandDark}"
                        BorderThickness="0"
                        Cursor="Hand"
                        Command="{Binding RefreshCommand}"
                        HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════
             3-COLUMN DASHBOARD GRID
             ══════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1.3*"/>
            </Grid.ColumnDefinitions>

            <!-- ─────────────────────────────────
                 LEFT · KPIs + Top Products
                 ───────────────────────────────── -->
            <Grid Grid.Column="0" Margin="0,0,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- KPI card -->
                    <RowDefinition Height="*"/>
                    <!-- Top products -->
                </Grid.RowDefinitions>

                <!-- KPI card -->
                <Border Grid.Row="0" Style="{StaticResource CardBorder}" Margin="0,0,0,10">
                    <StackPanel>
                        <Border Style="{StaticResource CardHeaderBorder}">
                            <TextBlock Text="📈  Key metrics" Style="{StaticResource CardTitle}"/>
                        </Border>

                        <UniformGrid Columns="2" Margin="12,10,12,6">
                            <Border Style="{StaticResource KpiTile}" Margin="0,0,5,5">
                                <StackPanel>
                                    <TextBlock Text="TOTAL SALES" Style="{StaticResource KpiLabel}"/>
                                    <controls:CurrencyText
                                           Amount="{Binding TotalSales}"
                                           Style="{StaticResource KpiValueCurrency}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource KpiTile}" Margin="5,0,0,5">
                                <StackPanel>
                                    <TextBlock Text="AVG. SALE" Style="{StaticResource KpiLabel}"/>
                                    <controls:CurrencyText
                                           Amount="{Binding AverageSales}"
                                           Style="{StaticResource KpiValueCurrency}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource KpiTile}" Margin="0,0,5,0">
                                <StackPanel>
                                    <TextBlock Text="TOTAL CASH" Style="{StaticResource KpiLabel}"/>
                                    <controls:CurrencyText
                                           Amount="{Binding TotalCash}"
                                           Style="{StaticResource KpiValueCurrency}"
                                           Foreground="{StaticResource SuccessGreen}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource KpiTile}" Margin="5,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="TOTAL CARD" Style="{StaticResource KpiLabel}"/>
                                    <controls:CurrencyText
                                           Amount="{Binding TotalCard}"
                                           Style="{StaticResource KpiValueCurrency}"
                                           Foreground="{StaticResource BrandDark}"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <Border Style="{StaticResource KpiTile}" Margin="12,0,12,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="TOTAL ORDERS" Style="{StaticResource KpiLabel}"
                                           Margin="0" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding TotalOrders}"
                                           FontSize="18" FontWeight="Medium"
                                           Foreground="{StaticResource SuccessGreen}"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>


                <!-- Top Products card -->
                <Border Grid.Row="1" Style="{StaticResource CardBorder}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource CardHeaderBorder}">
                            <TextBlock Text="🏆  Top products" Style="{StaticResource CardTitle}"/>
                        </Border>

                        <ScrollViewer Grid.Row="1" Padding="12,4,12,8" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <Grid Margin="0,4,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="PRODUCT" Style="{StaticResource ColLabel}"/>
                                    <TextBlock Grid.Column="1" Text="SALES" Style="{StaticResource ColLabel}"/>
                                </Grid>
                                <Border BorderBrush="#E8F3FF" BorderThickness="0,0,0,0.5" Margin="0,0,0,4"/>

                                <ItemsControl ItemsSource="{Binding TopProducts}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource ListRow}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding ProductName}"
                                                               FontSize="11" FontWeight="Medium"
                                                               Foreground="{StaticResource TextDark}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding SalesAmount, StringFormat={}{0:C}}"
                                                               FontSize="11" FontWeight="Medium"
                                                               Foreground="{StaticResource SuccessGreen}"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <!-- ─────────────────────────────────
                 MIDDLE · Shift Summary
                 ───────────────────────────────── -->
            <Border Grid.Column="1" Style="{StaticResource CardBorder}" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource CardHeaderBorder}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="👥  Shift summary" Style="{StaticResource CardTitle}"/>
                            <Button Grid.Column="1"
                                    Style="{StaticResource CardActionBtn}"
                                    Content="View all"
                                    Command="{Binding OpenShiftManagementCommand}"/>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1" Margin="12,6,12,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="CASHIER" Style="{StaticResource ColLabel}"/>
                        <TextBlock Grid.Column="1" Text="CASH DIFF." Style="{StaticResource ColLabel}"/>
                    </Grid>
                    <Border Grid.Row="1" BorderBrush="#E8F3FF" BorderThickness="0,0,0,0.5"
                            Margin="12,26,12,0" VerticalAlignment="Top"/>

                    <ScrollViewer Grid.Row="2" Padding="12,4,12,8" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding ShiftSummaries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource ListRow}">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding CashierName}"
                                                           FontSize="11" FontWeight="Medium"
                                                           Foreground="{StaticResource TextDark}"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding CashDifference, StringFormat={}{0:+0.00;-0.00}}"
                                                           FontSize="11" FontWeight="Medium">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{StaticResource SuccessGreen}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsShortfall}" Value="True">
                                                                    <Setter Property="Foreground" Value="{StaticResource DangerRed}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                            <TextBlock FontSize="10" Foreground="{StaticResource TextMuted}" Margin="0,2,0,0">
                                                <Run Text="Open "/>
                                                <Run Text="{Binding OpenedAt, StringFormat=HH:mm}"/>
                                                <Run Text="  ·  Close "/>
                                                <Run Text="{Binding ClosedAtDisplay}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- ─────────────────────────────────
                 RIGHT · Recent Transactions
                 ───────────────────────────────── -->
            <Border Grid.Column="2" Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource CardHeaderBorder}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="📃  Recent transactions" Style="{StaticResource CardTitle}"/>
                            <Button Grid.Column="1"
                                    Style="{StaticResource CardActionBtn}"
                                    Content="Show all"
                                    Command="{Binding ShowAllTransactionsCommand}"/>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1" Margin="12,6,12,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="108"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="75"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="RECEIPT" Style="{StaticResource ColLabel}"/>
                        <TextBlock Grid.Column="1" Text="AMOUNT" Style="{StaticResource ColLabel}"/>
                        <TextBlock Grid.Column="2" Text="PAYMENT" Style="{StaticResource ColLabel}"/>
                        <TextBlock Grid.Column="3" Text="DATE" Style="{StaticResource ColLabel}" TextAlignment="Right"/>
                    </Grid>
                    <Border Grid.Row="1" BorderBrush="#E8F3FF" BorderThickness="0,0,0,0.5"
                            Margin="12,26,12,0" VerticalAlignment="Top"/>

                    <ScrollViewer Grid.Row="2" Padding="12,4,12,8" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding RecentTransactions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource ListRow}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="108"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="60"/>
                                                <ColumnDefinition Width="75"/>
                                            </Grid.ColumnDefinitions>

                                            <Button Content="{Binding ReceiptNumber}"
                                                        FontSize="9"
                                                        Foreground="{StaticResource BrandDark}"
                                                        Cursor="Hand"
                                                        Command="{Binding DataContext.OpenReceiptCommand,
                                                                  RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                    HorizontalAlignment="Left">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="#DBEEFF" CornerRadius="4" Padding="6,2">
                                                            <ContentPresenter HorizontalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                            
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding GrandTotal, StringFormat={}{0:C}}"
                                                       FontSize="11" FontWeight="Medium"
                                                       Foreground="{StaticResource BrandDark}"
                                                       VerticalAlignment="Center"/>

                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding PaymentMethod}"
                                                       FontSize="10"
                                                       Foreground="{StaticResource TextMuted}"
                                                       VerticalAlignment="Center"/>

                                            <TextBlock Grid.Column="3"
                                                       Text="{Binding TransactionDate, StringFormat='dd/MM HH:mm'}"
                                                       FontSize="10"
                                                       Foreground="{StaticResource TextMuted}"
                                                       TextAlignment="Right"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

        </Grid>
    </Grid>
</UserControl>
