<!--
    +-+
    ¦   Cafeteria Hawa POS  –  Cashier Dashboard          ¦
    ¦   Redesigned: compact light-blue style              ¦
    +-+
-->
<UserControl x:Class="UI.Views.CashierDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:UI.Controls"
             xmlns:vwp="clr-namespace:WpfToolkit.Controls;assembly=VirtualizingWrapPanel"
             xmlns:behaviors="clr-namespace:UI.Behaviors"
             mc:Ignorable="d"
             d:DesignWidth="1600" d:DesignHeight="900">

    <UserControl.Resources>

        <!-- - Converters -->
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- - Palette -->
        <SolidColorBrush x:Key="BrandDark"      Color="#1A6FC4"/>
        <SolidColorBrush x:Key="BrandMid"       Color="#2589E0"/>
        <SolidColorBrush x:Key="BrandLight"     Color="#F0F7FF"/>
        <SolidColorBrush x:Key="BrandBorder"    Color="#B8D8F5"/>
        <SolidColorBrush x:Key="BrandIcon"      Color="#5BAAE0"/>
        <SolidColorBrush x:Key="PageBg"         Color="#EAF4FF"/>
        <SolidColorBrush x:Key="CardBg"         Color="#FFFFFF"/>
        <SolidColorBrush x:Key="CardHdrBg"      Color="#F0F7FF"/>
        <SolidColorBrush x:Key="TextDark"       Color="#1A3A5C"/>
        <SolidColorBrush x:Key="TextMuted"      Color="#5B8AB0"/>
        <SolidColorBrush x:Key="SuccessGreen"   Color="#16A34A"/>
        <SolidColorBrush x:Key="DangerRed"      Color="#DC2626"/>
        <SolidColorBrush x:Key="DangerHover"    Color="#B91C1C"/>
        <SolidColorBrush x:Key="FooterBg"       Color="#1A6FC4"/>

        <!-- -
             STYLES
             -->

        <!-- - Card panel -->
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource CardBg}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BrandBorder}"/>
            <Setter Property="BorderThickness" Value="0.5"/>
            <Setter Property="CornerRadius"    Value="10"/>
        </Style>

        <!-- - Card panel header -->
        <Style x:Key="CardHeaderBorder" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource CardHdrBg}"/>
            <Setter Property="BorderBrush"     Value="#E8F3FF"/>
            <Setter Property="BorderThickness" Value="0,0,0,0.5"/>
            <Setter Property="Padding"         Value="12,8"/>
        </Style>

        <!-- - Panel title -->
        <Style x:Key="PanelTitle" TargetType="TextBlock">
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="FontWeight"   Value="Medium"/>
            <Setter Property="Foreground"   Value="{StaticResource TextDark}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- - Keyboard shortcut key-cap (header strip) -->
        <Style x:Key="ShortcutKeyCap" TargetType="Border">
            <Setter Property="Background"      Value="#33FFFFFF"/>
            <Setter Property="BorderBrush"      Value="#55FFFFFF"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="CornerRadius"     Value="5"/>
            <Setter Property="Padding"          Value="7,3"/>
            <Setter Property="Margin"           Value="0,0,6,0"/>
        </Style>

        <Style x:Key="ShortcutKeyText" TargetType="TextBlock">
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="FontWeight"   Value="Bold"/>
            <Setter Property="Foreground"   Value="White"/>
        </Style>

        <Style x:Key="ShortcutLabelText" TargetType="TextBlock">
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="FontWeight"   Value="Medium"/>
            <Setter Property="Foreground"   Value="#EAF6FF"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ShortcutChip" TargetType="StackPanel">
            <Setter Property="Orientation" Value="Horizontal"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,18,0"/>
        </Style>

        <!-- - Item count badge -->
        <Style x:Key="CountBadge" TargetType="Border">
            <Setter Property="Background"      Value="#DBEEFF"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BrandBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="5"/>
            <Setter Property="Padding"         Value="8,2"/>
            <Setter Property="Margin"          Value="8,0,0,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- - Primary blue button -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                CornerRadius="7"
                                Background="{StaticResource BrandDark}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background"
                                        Value="{StaticResource BrandMid}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.45"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bg" Property="BorderBrush" Value="White"/>
                                <Setter TargetName="Bg" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- - Header icon button (Start Day / End Day / Logout) -->
        <Style x:Key="HdrBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Height"   Value="30"/>
            <Setter Property="Padding"  Value="12,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Medium"/>
        </Style>

        <!-- - Danger (red) header button -->
        <Style x:Key="HdrDangerBtn" TargetType="Button" BasedOn="{StaticResource HdrBtn}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                CornerRadius="7"
                                Background="{StaticResource DangerRed}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background"
                                        Value="{StaticResource DangerHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bg" Property="BorderBrush" Value="White"/>
                                <Setter TargetName="Bg" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- - Category tab -->
        <Style x:Key="CategoryBtn" TargetType="Button">
            <Setter Property="Height"      Value="26"/>
            <Setter Property="Padding"     Value="12,0"/>
            <Setter Property="Margin"      Value="0,0,5,0"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="FontWeight"  Value="Medium"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                CornerRadius="6"
                                Background="#F0F7FF"
                                BorderBrush="{StaticResource BrandBorder}"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#DBEEFF"/>
                                <Setter TargetName="Bg" Property="BorderBrush"
                                        Value="{StaticResource BrandDark}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#DBEEFF"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bg" Property="BorderBrush" Value="{StaticResource BrandDark}"/>
                                <Setter TargetName="Bg" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- - Sub-category tab -->
        <Style x:Key="SubCategoryBtn" TargetType="Button" BasedOn="{StaticResource CategoryBtn}">
            <Setter Property="Height"   Value="22"/>
            <Setter Property="Padding"  Value="10,0"/>
            <Setter Property="Margin"   Value="0,0,4,0"/>
            <Setter Property="FontSize" Value="10"/>
        </Style>

        <!-- - Product card -->
        <Style x:Key="ProductBtn" TargetType="Button">
            <Setter Property="Height"              Value="76"/>
            <Setter Property="Margin"              Value="3"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment"   Value="Stretch"/>
            <Setter Property="Cursor"              Value="Hand"/>
            <Setter Property="FocusVisualStyle"    Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                CornerRadius="8"
                                Background="{StaticResource CardBg}"
                                BorderBrush="{StaticResource BrandBorder}"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#F0F7FF"/>
                                <Setter TargetName="Bg" Property="BorderBrush"
                                        Value="{StaticResource BrandDark}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#DBEEFF"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bg" Property="BorderBrush" Value="{StaticResource BrandDark}"/>
                                <Setter TargetName="Bg" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- - Quick-action tile -->
        <Style x:Key="QuickActionBtn" TargetType="Button">
            <Setter Property="Height"              Value="70"/>
            <Setter Property="Margin"              Value="5,0,5,5"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Cursor"              Value="Hand"/>
            <Setter Property="FocusVisualStyle"    Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                CornerRadius="8"
                                Background="#F0F7FF"
                                BorderBrush="{StaticResource BrandBorder}"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#DBEEFF"/>
                                <Setter TargetName="Bg" Property="BorderBrush"
                                        Value="{StaticResource BrandDark}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#DBEEFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.45"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bg" Property="BorderBrush" Value="{StaticResource BrandDark}"/>
                                <Setter TargetName="Bg" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- - Ghost footer button (Clear) -->
        <Style x:Key="FooterGhostBtn" TargetType="Button">
            <Setter Property="Height"          Value="50"/>
            <Setter Property="Padding"         Value="16,0"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="FontWeight"      Value="Medium"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                CornerRadius="9"
                                Background="Transparent"
                                BorderBrush="#60FFFFFF"
                                BorderThickness="1.5">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#20FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.4"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bg" Property="BorderBrush" Value="White"/>
                                <Setter TargetName="Bg" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- - DataGrid column header -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="#F0F7FF"/>
            <Setter Property="Foreground"      Value="{StaticResource TextMuted}"/>
            <Setter Property="FontSize"        Value="10"/>
            <Setter Property="FontWeight"      Value="Medium"/>
            <Setter Property="Padding"         Value="10,6"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BrandBorder}"/>
            <Setter Property="BorderThickness" Value="0,0,0,0.5"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <!-- - DataGrid row -->
        <Style TargetType="DataGridRow">
            <Setter Property="BorderBrush"     Value="#F0F7FF"/>
            <Setter Property="BorderThickness" Value="0,0,0,0.5"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8FCFF"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#DBEEFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- - DataGrid cell -->
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="10,0"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Foreground"      Value="{StaticResource TextDark}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="{StaticResource TextDark}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- - Currency value in DataGrid / KPI -->
        <Style x:Key="CurrencyTextStyle" TargetType="controls:CurrencyText">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{StaticResource TextDark}"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>

        <Style x:Key="CurrencyTextStyleLarge" TargetType="controls:CurrencyText">
            <Setter Property="FontSize"   Value="24"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{StaticResource SuccessGreen}"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>

        <Style x:Key="CurrencyTextStyleWhite" TargetType="controls:CurrencyText">
            <Setter Property="FontSize"   Value="15"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

    </UserControl.Resources>

    <!-- -
         ROOT  –  3 rows: header | content | footer
         -->
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#DBEEFF" Offset="0"/>
                <GradientStop Color="#EAF4FF" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Error   -->
            <RowDefinition Height="56"/>
            <!-- Header  -->
            <RowDefinition Height="*"/>
            <!-- Content -->
            <RowDefinition Height="72"/>
            <!-- Footer  -->
        </Grid.RowDefinitions>

        <!-- -
             ROW 0 · HEADER
             -->
        <Border Grid.Row="0" Padding="14,0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#1A6FC4" Offset="0"/>
                    <GradientStop Color="#2589E0" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <!-- Logo + title     -->
                    <ColumnDefinition Width="*"/>
                    <!-- Shortcut strip   -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Shift buttons    -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Cashier name     -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Logout           -->
                </Grid.ColumnDefinitions>

                <!-- Logo + brand -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,10,0">
                    <Border Width="34" Height="34"
                            CornerRadius="8"
                            Background="#29FFFFFF"
                            Margin="0,0,8,0">
                        <Image Source="pack://application:,,,/UI;component/Assets/logo.png"
                               Width="30" Height="30"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Cafeteria Hawa"
                                   FontSize="14" FontWeight="Medium"
                                   Foreground="White"/>
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="0,2,0,0">
                            <Ellipse Width="7" Height="7"
                                     Margin="0,0,5,0"
                                     VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#94A3B8"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsShiftOpen}" Value="True">
                                                <Setter Property="Fill" Value="#22C55E"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="{Binding ShiftStatus}"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="White"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Keyboard shortcut strip -->
                <ScrollViewer Grid.Column="1"
                              VerticalAlignment="Center"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                        <StackPanel Style="{StaticResource ShortcutChip}">
                            <Border Style="{StaticResource ShortcutKeyCap}">
                                <TextBlock Text="F2" Style="{StaticResource ShortcutKeyText}"/>
                            </Border>
                            <TextBlock Text="{DynamicResource Cashier.StartDay}" Style="{StaticResource ShortcutLabelText}"/>
                        </StackPanel>

                        <StackPanel Style="{StaticResource ShortcutChip}">
                            <Border Style="{StaticResource ShortcutKeyCap}">
                                <TextBlock Text="F3" Style="{StaticResource ShortcutKeyText}"/>
                            </Border>
                            <TextBlock Text="{DynamicResource Cashier.EndDay}" Style="{StaticResource ShortcutLabelText}"/>
                        </StackPanel>

                        <StackPanel Style="{StaticResource ShortcutChip}">
                            <Border Style="{StaticResource ShortcutKeyCap}">
                                <TextBlock Text="F4" Style="{StaticResource ShortcutKeyText}"/>
                            </Border>
                            <TextBlock Text="{DynamicResource Cashier.RecentSales}" Style="{StaticResource ShortcutLabelText}"/>
                        </StackPanel>

                        <StackPanel Style="{StaticResource ShortcutChip}">
                            <Border Style="{StaticResource ShortcutKeyCap}">
                                <TextBlock Text="F6" Style="{StaticResource ShortcutKeyText}"/>
                            </Border>
                            <TextBlock Text="{DynamicResource Cashier.CashButton}" Style="{StaticResource ShortcutLabelText}"/>
                        </StackPanel>

                        <StackPanel Style="{StaticResource ShortcutChip}">
                            <Border Style="{StaticResource ShortcutKeyCap}">
                                <TextBlock Text="F7" Style="{StaticResource ShortcutKeyText}"/>
                            </Border>
                            <TextBlock Text="{DynamicResource Cashier.CardButton}" Style="{StaticResource ShortcutLabelText}"/>
                        </StackPanel>

                        <StackPanel Style="{StaticResource ShortcutChip}">
                            <Border Style="{StaticResource ShortcutKeyCap}">
                                <TextBlock Text="F8" Style="{StaticResource ShortcutKeyText}"/>
                            </Border>
                            <TextBlock Text="{DynamicResource Common.Clear}" Style="{StaticResource ShortcutLabelText}"/>
                        </StackPanel>

                        <StackPanel Style="{StaticResource ShortcutChip}">
                            <Border Style="{StaticResource ShortcutKeyCap}">
                                <TextBlock Text="+/-" Style="{StaticResource ShortcutKeyText}"/>
                            </Border>
                            <TextBlock Text="{DynamicResource Cashier.Quantity}" Style="{StaticResource ShortcutLabelText}"/>
                        </StackPanel>

                        <StackPanel Style="{StaticResource ShortcutChip}">
                            <Border Style="{StaticResource ShortcutKeyCap}">
                                <TextBlock Text="Del" Style="{StaticResource ShortcutKeyText}"/>
                            </Border>
                            <TextBlock Text="{DynamicResource Cashier.Remove}" Style="{StaticResource ShortcutLabelText}"/>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>

                <!-- Shift buttons -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,10,0">

                    <!-- Settings -->
                    <Button Style="{StaticResource HdrBtn}"
                            Margin="0,0,6,0"
                            Command="{Binding ShowSetting}"
                            ToolTip="Settings">
                        <TextBlock Text="&#xE713;"
                                   FontSize="14"
                                   FontFamily="Segoe MDL2 Assets"
                                   Foreground="White"
                                   VerticalAlignment="Center"/>
                    </Button>

                    <Button Style="{StaticResource HdrBtn}"
                            Margin="0,0,6,0"
                            Command="{Binding StartDayCommand}"
                            Visibility="{Binding CanStartDay, Converter={StaticResource BoolToVis}}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg" CornerRadius="7" Background="#10B981">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Margin="12,0"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#059669"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Bg" Property="Opacity" Value="0.85"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="Bg" Property="Opacity" Value="0.4"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="&#xE768;"
                                       FontSize="11"
                                       FontFamily="Segoe MDL2 Assets"
                                       Foreground="White"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0"/>
                            <TextBlock Text="{DynamicResource Cashier.StartDay}"
                                       FontSize="11" FontWeight="Medium"
                                       Foreground="White"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource HdrBtn}"
                            Command="{Binding EndDayCommand}"
                            Visibility="{Binding CanEndDay, Converter={StaticResource BoolToVis}}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg" CornerRadius="7" Background="#F97316">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Margin="12,0"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#EA580C"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Bg" Property="Opacity" Value="0.85"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="Bg" Property="Opacity" Value="0.4"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="&#xE71A;"
                                       FontSize="11"
                                       FontFamily="Segoe MDL2 Assets"
                                       Foreground="White"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0"/>
                            <TextBlock Text="{DynamicResource Cashier.EndDay}"
                                       FontSize="11" FontWeight="Medium"
                                       Foreground="White"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Cashier name -->
                <StackPanel Grid.Column="3"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,10,0">
                    <TextBlock Text="&#xE77B; " FontSize="13" Foreground="#A8D4F5"
                               VerticalAlignment="Center"
                               FontFamily="Segoe MDL2 Assets"/>
                    <TextBlock Text="{Binding CashierName}"
                               FontSize="12" FontWeight="Medium"
                               Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Logout -->
                <Button Grid.Column="4"
                        Style="{StaticResource HdrDangerBtn}"
                        Command="{Binding LogoutCommand}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="&#xF3B1;"
                                   FontSize="11"
                                   FontFamily="Segoe MDL2 Assets"
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   Margin="0,0,6,0"/>
                        <TextBlock Text="{DynamicResource Common.Logout}"
                                   FontSize="11" FontWeight="Medium"
                                   Foreground="White"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- -
             ROW 1 · MAIN CONTENT
             3 columns: Cart | Products | Quick Actions
             -->
        <Grid Grid.Row="2" Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3.15*"/>
                <!-- Cart          -->
                <ColumnDefinition Width="3.65*"/>
                <!-- Products      -->
                <ColumnDefinition Width="100"/>
                <!-- Quick Actions -->
            </Grid.ColumnDefinitions>

            <!-- -
                 LEFT · CURRENT SALE
                 -->
            <Border Grid.Column="0"
                    Style="{StaticResource CardBorder}"
                    Margin="0,0,8,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- header -->
                        <RowDefinition Height="*"/>
                        <!-- grid   -->
                        <RowDefinition Height="Auto"/>
                        <!-- totals -->
                    </Grid.RowDefinitions>

                    <!-- Panel header -->
                    <Border Grid.Row="0" Style="{StaticResource CardHeaderBorder}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{DynamicResource Cashier.CurrentSale}" Style="{StaticResource PanelTitle}"/>
                            <Border Style="{StaticResource CountBadge}">
                                <TextBlock FontSize="11" FontWeight="Medium"
                                           Foreground="{StaticResource BrandDark}"
                                           Text="{Binding CartCountDisplay, Mode=OneWay}"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Cart DataGrid -->
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding SaleItems}"
                              SelectedItem="{Binding SelectedCartItem}"
                              AutoGenerateColumns="False"
                              IsReadOnly="False"
                              CanUserAddRows="False"
                              CanUserResizeRows="False"
                              BorderThickness="0"
                              Background="Transparent"
                              GridLinesVisibility="None"
                              RowHeight="44"
                              ColumnHeaderHeight="36"
                              FontSize="11">

                        <DataGrid.Columns>

                            <DataGridTextColumn Binding="{Binding ProductName}"
                                                IsReadOnly="True"
                                                Width="*"
                                                MinWidth="100">
                                <DataGridTextColumn.Header>
                                    <TextBlock Text="{DynamicResource Cashier.ColProduct}"/>
                                </DataGridTextColumn.Header>
                            </DataGridTextColumn>

                            <DataGridTextColumn Width="56"
                                                Binding="{Binding Quantity, Mode=TwoWay,
                                                          UpdateSourceTrigger=PropertyChanged}">
                                <DataGridTextColumn.Header>
                                    <TextBlock Text="{DynamicResource Cashier.ColQty}"/>
                                </DataGridTextColumn.Header>
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextAlignment"     Value="Center"/>
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                                <DataGridTextColumn.EditingElementStyle>
                                    <Style TargetType="TextBox">
                                        <Setter Property="TextAlignment"     Value="Center"/>
                                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.EditingElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Binding="{Binding UnitPrice}"
                                                Width="80"
                                                IsReadOnly="True">
                                <DataGridTextColumn.Header>
                                    <TextBlock Text="{DynamicResource Cashier.ColPrice}"/>
                                </DataGridTextColumn.Header>
                            </DataGridTextColumn>

                            <DataGridTextColumn Binding="{Binding LineTotal}"
                                                Width="85"
                                                IsReadOnly="True">
                                <DataGridTextColumn.Header>
                                    <TextBlock Text="{DynamicResource Cashier.ColTotal}"/>
                                </DataGridTextColumn.Header>
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextAlignment"     Value="Center"/>
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="FontWeight"        Value="Medium"/>
                                        <Setter Property="Foreground"        Value="{StaticResource BrandDark}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Remove button column -->
                            <DataGridTemplateColumn Header="" Width="44" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="&#xE711;"
                                                FontSize="13"
                                                FontWeight="Bold"
                                                FontFamily="Segoe MDL2 Assets"
                                                Foreground="{StaticResource DangerRed}"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                ToolTip="{DynamicResource Cashier.RemoveItemTooltip}"
                                                Command="{Binding DataContext.RemoveSaleItemCommand,
                                                          RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Totals block -->
                    <Border Grid.Row="2"
                            Background="{StaticResource CardHdrBg}"
                            BorderBrush="{StaticResource BrandBorder}"
                            BorderThickness="0,0.5,0,0"
                            Padding="14,12">
                        <StackPanel>

                            <!-- Subtotal -->
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{DynamicResource Common.Subtotal}"
                                           FontSize="20"
                                           Foreground="{StaticResource TextMuted}"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Subtotal, StringFormat={}{0:N2}}"
                                           FontSize="20"
                                           Foreground="{StaticResource TextMuted}"/>
                            </Grid>

                            <!-- Tax -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{DynamicResource Common.Tax}"
                                           FontSize="17"
                                           Foreground="{StaticResource TextMuted}"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Tax, StringFormat={}{0:N2}}"
                                           FontSize="17"
                                           Foreground="{StaticResource TextMuted}"/>
                            </Grid>

                            <!-- Divider -->
                            <Border BorderBrush="{StaticResource BrandBorder}"
                                    BorderThickness="0,0.5,0,0"
                                    Margin="0,0,0,8"/>

                            <!-- Total -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{DynamicResource Common.Total}"
                                           FontSize="25" FontWeight="Medium"
                                           Foreground="{StaticResource TextDark}"
                                           VerticalAlignment="Center"/>
                                <controls:CurrencyText Grid.Column="1"
                                           Amount="{Binding Total}"
                                                       FontSize="25" FontWeight="Medium"
                                           Style="{StaticResource CurrencyTextStyleLarge}"/>
                            </Grid>

                        </StackPanel>
                    </Border>

                </Grid>
            </Border>

            <!-- -
                 MIDDLE · PRODUCTS
                 -->
            <Border Grid.Column="1"
                    Style="{StaticResource CardBorder}"
                    Margin="0,0,8,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- header + search  -->
                        <RowDefinition Height="Auto"/>
                        <!-- categories       -->
                        <RowDefinition Height="Auto"/>
                        <!-- sub-categories   -->
                        <RowDefinition Height="*"/>
                        <!-- product grid     -->
                    </Grid.RowDefinitions>

                    <!-- Panel header + search -->
                    <Border Grid.Row="0" Style="{StaticResource CardHeaderBorder}">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Cashier.Products}"
                                       Style="{StaticResource PanelTitle}"
                                       Margin="0,0,0,8"/>

                            <!-- Search bar -->
                            <Border Background="{StaticResource BrandLight}"
                                    BorderBrush="{StaticResource BrandBorder}"
                                    BorderThickness="1"
                                    CornerRadius="7"
                                    Height="32">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="32"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="&#xE721;"
                                               FontSize="13"
                                               FontFamily="Segoe MDL2 Assets"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource BrandIcon}"/>
                                    <TextBox Grid.Column="1"
                                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             FontSize="12"
                                             Foreground="{StaticResource TextDark}"
                                             VerticalContentAlignment="Center"
                                             Padding="0,0,8,0"
                                             FocusVisualStyle="{x:Null}"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Main categories -->
                    <Border Grid.Row="1"
                            Background="{StaticResource CardHdrBg}"
                            BorderBrush="{StaticResource BrandBorder}"
                            BorderThickness="0,0,0,0.5"
                            Padding="10,8">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding Categories}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding Name}"
                                                Style="{StaticResource CategoryBtn}"
                                                Foreground="{StaticResource TextMuted}"
                                                behaviors:FocusExtension.FocusFirstItem="{Binding IsSelected}"
                                                Command="{Binding DataContext.SelectCategoryCommand,
                                                          RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <!-- Sub-categories -->
                    <Border Grid.Row="2"
                            Background="#F8FBFF"
                            BorderBrush="{StaticResource BrandBorder}"
                            BorderThickness="0,0,0,0.5"
                            Padding="10,6"
                            Visibility="{Binding HasSubCategories, Converter={StaticResource BoolToVis}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Breadcrumb -->
                            <StackPanel Grid.Column="0"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Margin="0,0,10,0">
                                <TextBlock Text="{Binding SelectedCategory.Name}"
                                           FontSize="10" FontWeight="Medium"
                                           Foreground="{StaticResource BrandDark}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text=" ›"
                                           FontSize="10"
                                           Foreground="{StaticResource TextMuted}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Sub-category buttons -->
                            <ScrollViewer Grid.Column="1"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding VisibleSubCategories}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Content="{Binding Name}"
                                                    Style="{StaticResource SubCategoryBtn}"
                                                    Foreground="{StaticResource TextMuted}"
                                                    Command="{Binding DataContext.SelectSubCategoryCommand,
                                                              RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <!-- Product grid (virtualizing) -->
                    <Grid Grid.Row="3">
                        <!--
                            Per the VirtualizingWrapPanel package's documented usage,
                            the ScrollViewer must live INSIDE the ItemsControl.Template
                            (with an ItemsPresenter), not as an external parent. The panel
                            wires its IScrollInfo to that inner ScrollViewer at runtime.
                            Without this, the panel never realizes any containers.
                        -->
                        <ItemsControl ItemsSource="{Binding ProductsView}"
                                      ScrollViewer.CanContentScroll="True"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.VirtualizationMode="Recycling"
                                      VirtualizingPanel.ScrollUnit="Pixel">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <!--
                                        ItemSize is the cell size the panel uses to compute
                                        items-per-row. Width must be > 0 — when set, the panel
                                        does NOT auto-compute it. Height 82 = 76 (ProductBtn.Height)
                                        + 3 top + 3 bottom margin.
                                    -->
                                    <vwp:VirtualizingWrapPanel Orientation="Horizontal"
                                                               ItemSize="140,82"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.Template>
                                <ControlTemplate>
                                    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                                  VerticalScrollBarVisibility="Auto"
                                                  Padding="8"
                                                  CanContentScroll="True">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </ControlTemplate>
                            </ItemsControl.Template>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource ProductBtn}"
                                            Command="{Binding DataContext.AddProductCommand,
                                                      RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}">
                                        <StackPanel VerticalAlignment="Center"
                                                    HorizontalAlignment="Center"
                                                    Margin="4">
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="11" FontWeight="Medium"
                                                       Foreground="{StaticResource TextDark}"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap"
                                                       Margin="0,0,0,5"/>
                                            <controls:CurrencyText Amount="{Binding UnitPrice}"
                                                       Style="{StaticResource CurrencyTextStyle}"/>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- No products banner (overlay so it does not sit in the virtualizing panel) -->
                        <Border Background="#FEF3C7"
                                BorderBrush="#F59E0B"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Top"
                                Margin="0,20,0,0"
                                Visibility="{Binding ShowNoProductsMessage, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{DynamicResource Cashier.NoProductsFound}"
                                       FontSize="12" FontWeight="Medium"
                                       Foreground="#92400E"
                                       TextAlignment="Center"/>
                        </Border>
                    </Grid>

                </Grid>
            </Border>

            <!-- -
                 RIGHT · QUICK ACTIONS
                 -->
            <Border Grid.Column="2"
                    Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0" Style="{StaticResource CardHeaderBorder}" Padding="8,6">
                        <TextBlock Text="{DynamicResource Cashier.Actions}"
                                   FontSize="11" FontWeight="Medium"
                                   Foreground="{StaticResource TextDark}"/>
                    </Border>

                    <!-- Action tiles -->
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="0,6,0,0">
                        <StackPanel>

                            <TextBlock Text="{DynamicResource Cashier.Sale}"
                                       FontSize="9" FontWeight="Medium"
                                       Foreground="{StaticResource TextMuted}"
                                       Margin="8,0,0,4"/>

                            <Button Style="{StaticResource QuickActionBtn}"
                                    Command="{Binding ShowRecentSalesCommand}">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE81C;" FontSize="18"
                                               FontFamily="Segoe MDL2 Assets"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="{DynamicResource Cashier.RecentSales}"
                                               FontSize="9" FontWeight="Medium"
                                               Foreground="{StaticResource BrandDark}"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               HorizontalAlignment="Center"
                                               Margin="0,3,0,0"/>
                                </StackPanel>
                            </Button>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

        </Grid>

        <!-- -
             ROW 2 · FOOTER ACTION BAR
             -->
        <Border Grid.Row="3"
                BorderBrush="#1460A8"
                BorderThickness="0,0.5,0,0"
                Padding="12,0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#1A6FC4" Offset="0"/>
                    <GradientStop Color="#2589E0" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center">

                <!-- CASH -->
                <Button Width="120" Height="50"
                        Margin="0,0,8,0"
                        BorderThickness="0"
                        Cursor="Hand"
                        Command="{Binding PayCashCommand}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg"
                                    Background="#16A34A"
                                    BorderBrush="Transparent"
                                    BorderThickness="0"
                                    CornerRadius="9">
                                <StackPanel HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="&#xE8C7;"
                                                   FontSize="11"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   Foreground="White"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,6,0"/>
                                        <TextBlock Text="{DynamicResource Cashier.CashButton}"
                                                   FontSize="11" FontWeight="Medium"
                                                   Foreground="White"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <controls:CurrencyText Amount="{Binding Total}"
                                               Style="{StaticResource CurrencyTextStyleWhite}"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#15803D"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bg" Property="Opacity" Value="0.88"/>
                                </Trigger>
                                <Trigger Property="IsKeyboardFocused" Value="True">
                                    <Setter TargetName="Bg" Property="BorderBrush" Value="White"/>
                                    <Setter TargetName="Bg" Property="BorderThickness" Value="2"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- CARD -->
                <Button Width="120" Height="50"
                        Margin="0,0,16,0"
                        BorderThickness="0"
                        Cursor="Hand"
                        Command="{Binding PayCardCommand}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg"
                                    Background="#1D4ED8"
                                    BorderBrush="Transparent"
                                    BorderThickness="0"
                                    CornerRadius="9">
                                <StackPanel HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="&#xE8C7;"
                                                   FontSize="11"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   Foreground="White"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,6,0"/>
                                        <TextBlock Text="{DynamicResource Cashier.CardButton}"
                                                   FontSize="11" FontWeight="Medium"
                                                   Foreground="White"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <controls:CurrencyText Amount="{Binding Total}"
                                               Style="{StaticResource CurrencyTextStyleWhite}"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#1E40AF"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bg" Property="Opacity" Value="0.88"/>
                                </Trigger>
                                <Trigger Property="IsKeyboardFocused" Value="True">
                                    <Setter TargetName="Bg" Property="BorderBrush" Value="White"/>
                                    <Setter TargetName="Bg" Property="BorderThickness" Value="2"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Spacer -->
                <Border Width="1" Height="36"
                        Background="#30FFFFFF"
                        Margin="0,0,16,0"/>

                <!-- Clear Sale -->
                <Button Style="{StaticResource FooterGhostBtn}"
                        Width="140"
                        Margin="0,0,8,0"
                        Command="{Binding ClearSaleCommand}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE74D;"
                                   FontSize="11"
                                   FontFamily="Segoe MDL2 Assets"
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   Margin="0,0,6,0"/>
                        <TextBlock Text="{DynamicResource Cashier.ClearSale}"
                                   FontSize="11" FontWeight="Medium"
                                   Foreground="White"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>
