<UserControl x:Class="UI.Views.ReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F6FA">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ============================================================ -->
        <!-- 1. HEADER + FILTER SECTION                                   -->
        <!-- ============================================================ -->
        <Border Background="#FFFFFF"
                Padding="14"
                CornerRadius="6">
            <StackPanel>
                <!-- Title + Mode Toggle + Action Buttons -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Reports"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#333333"
                               VerticalAlignment="Center"/>

                    <!-- Report Mode Toggle + Action Buttons -->
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <RadioButton Content="Sales Mode"
                                     GroupName="ReportMode"
                                     IsChecked="{Binding IsSalesMode}"
                                     Margin="0,0,12,0"
                                     FontSize="13"
                                     Foreground="#555555"/>
                        <RadioButton Content="Product Mode"
                                     GroupName="ReportMode"
                                     IsChecked="{Binding IsProductMode}"
                                     Margin="0,0,16,0"
                                     FontSize="13"
                                     Foreground="#555555"/>

                        <Button Content="Generate and Export"
                                Command="{Binding ReportCommand}"
                                CommandParameter="GenerateAndExport"
                                Padding="14,6"
                                FontSize="12"
                                FontWeight="SemiBold"
                                Background="#1565C0"
                                Foreground="White"
                                BorderThickness="0"
                                Cursor="Hand"/>
                    </StackPanel>
                </Grid>

                <!-- Filter Period Buttons -->
                <Border BorderBrush="#E0E0E0"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="10,8"
                        Margin="0,10,0,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Today"
                                    Command="{Binding FilterTodayCommand}"
                                    Padding="14,6"
                                    Margin="0,0,8,0"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Background="#EEF0F2"
                                    Foreground="#1F2328"
                                    BorderThickness="0"
                                    Cursor="Hand"/>
                            <Button Content="This Week"
                                    Command="{Binding FilterThisWeekCommand}"
                                    Padding="14,6"
                                    Margin="0,0,8,0"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Background="#EEF0F2"
                                    Foreground="#1F2328"
                                    BorderThickness="0"
                                    Cursor="Hand"/>
                            <Button Content="This Month"
                                    Command="{Binding FilterMonthCommand}"
                                    Padding="14,6"
                                    Margin="0,0,8,0"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Background="#EEF0F2"
                                    Foreground="#1F2328"
                                    BorderThickness="0"
                                    Cursor="Hand"/>
                            <Button Content="Period"
                                    Command="{Binding ShowPeriodFilterCommand}"
                                    Padding="14,6"
                                    Margin="0,0,0,0"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Background="#1565C0"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Cursor="Hand"/>

                            <!-- Period Date Pickers (visible when Period is selected) -->
                            <StackPanel Orientation="Horizontal"
                                        Visibility="{Binding IsPeriodFilterVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                                        Margin="12,0,0,0">
                                <TextBlock Text="From:" VerticalAlignment="Center" Margin="0,0,6,0"
                                           Foreground="#6B7280" FontSize="12"/>
                                <DatePicker SelectedDate="{Binding FromDate}" Width="115" Margin="0,0,12,0"/>
                                <TextBlock Text="To:" VerticalAlignment="Center" Margin="0,0,6,0"
                                           Foreground="#6B7280" FontSize="12"/>
                                <DatePicker SelectedDate="{Binding ToDate}" Width="115" Margin="0,0,12,0"/>
                                <Button Content="Apply"
                                        Command="{Binding ApplyPeriodFilterCommand}"
                                        Padding="14,6"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Background="#1565C0"
                                        Foreground="White"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        Margin="0"/>
                            </StackPanel>

                            <!-- Product ComboBox (only visible in Product Mode) -->
                            <StackPanel Orientation="Horizontal"
                                        Visibility="{Binding ProductGridVisibility}"
                                        Margin="12,0,0,0">
                                <TextBlock Text="Product:" VerticalAlignment="Center" Margin="0,0,6,0"
                                           Foreground="#6B7280" FontSize="12"/>
                                <ComboBox ItemsSource="{Binding Products}"
                                          SelectedItem="{Binding SelectedProduct}"
                                          Width="140"
                                          DisplayMemberPath="ProductName"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- ============================================================ -->
        <!-- 2. MAIN CONTENT (SUMMARY + DATA GRID)                        -->
        <!-- ============================================================ -->
        <Border Grid.Row="2"
                Margin="0,10,0,0"
                Background="#FFFFFF"
                Padding="14"
                CornerRadius="6"
                BorderBrush="#E0E0E0"
                BorderThickness="1">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- ============================================================ -->
                <!-- SUMMARY SECTION (CARD STYLE - SALES MODE)                    -->
                <!-- ============================================================ -->
                <Border BorderBrush="#E0E0E0"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="14"
                        Margin="0,0,0,12"
                        Visibility="{Binding SalesSummaryVisibility}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border BorderBrush="#EEF2FF"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="12"
                                Margin="4"
                                Background="#F8FAFF">
                            <StackPanel>
                                <TextBlock Text="Total Orders"
                                           FontSize="11"
                                           Foreground="#6B7280"/>
                                <TextBlock Text="{Binding TotalOrders}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="#333333"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1"
                                BorderBrush="#EEF2FF"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="12"
                                Margin="4"
                                Background="#F8FAFF">
                            <StackPanel>
                                <TextBlock Text="Total Sales"
                                           FontSize="11"
                                           Foreground="#6B7280"/>
                                <TextBlock Text="{Binding TotalSales}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="#333333"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2"
                                BorderBrush="#EEF2FF"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="12"
                                Margin="4"
                                Background="#F8FAFF">
                            <StackPanel>
                                <TextBlock Text="Cash Total"
                                           FontSize="11"
                                           Foreground="#6B7280"/>
                                <TextBlock Text="{Binding CashTotal}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="#333333"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="3"
                                BorderBrush="#EEF2FF"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="12"
                                Margin="4"
                                Background="#F8FAFF">
                            <StackPanel>
                                <TextBlock Text="Card Total"
                                           FontSize="11"
                                           Foreground="#6B7280"/>
                                <TextBlock Text="{Binding CardTotal}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="#333333"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- ============================================================ -->
                <!-- SUMMARY SECTION (CARD STYLE - PRODUCT MODE)                  -->
                <!-- ============================================================ -->
                <Border BorderBrush="#E0E0E0"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="14"
                        Margin="0,0,0,12"
                        Visibility="{Binding ProductSummaryVisibility}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border BorderBrush="#EEF2FF"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="12"
                                Margin="4"
                                Background="#F8FAFF">
                            <StackPanel>
                                <TextBlock Text="Total Qty Sold"
                                           FontSize="11"
                                           Foreground="#6B7280"/>
                                <TextBlock Text="{Binding TotalQuantitySold}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="#333333"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1"
                                BorderBrush="#EEF2FF"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="12"
                                Margin="4"
                                Background="#F8FAFF">
                            <StackPanel>
                                <TextBlock Text="Total Revenue"
                                           FontSize="11"
                                           Foreground="#6B7280"/>
                                <TextBlock Text="{Binding TotalRevenue}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="#333333"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2"
                                BorderBrush="#EEF2FF"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="12"
                                Margin="4"
                                Background="#F8FAFF">
                            <StackPanel>
                                <TextBlock Text="Average Price"
                                           FontSize="11"
                                           Foreground="#6B7280"/>
                                <TextBlock Text="{Binding AveragePrice}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="#333333"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- ============================================================ -->
                <!-- DATA GRID - SALES MODE                                       -->
                <!-- ============================================================ -->
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding TransactionReports}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          AlternatingRowBackground="#F9F9F9"
                          GridLinesVisibility="Horizontal"
                          BorderBrush="#E0E0E0"
                          BorderThickness="1"
                          RowHeaderWidth="0"
                          FontSize="13"
                          Visibility="{Binding SalesGridVisibility}">

                    <DataGrid.Resources>
                        <Style x:Key="ReportColumnHeaderStyle" TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F3F4F6"/>
                            <Setter Property="Foreground" Value="#374151"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter Property="BorderBrush" Value="#E5E7EB"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        </Style>
                        <Style x:Key="ReportCellStyle" TargetType="DataGridCell">
                            <Setter Property="Padding" Value="10,6"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Receipt Number"
                                            Binding="{Binding ReceiptNumber}"
                                            Width="*"/>
                        <DataGridTextColumn Header="Date &#38; Time"
                                            Binding="{Binding TransactionDate, StringFormat={}{0:g}}"
                                            Width="*"/>
                        <DataGridTextColumn Header="Payment Method"
                                            Binding="{Binding PaymentMethod}"
                                            Width="*"/>
                        <DataGridTextColumn Header="Grand Total"
                                            Binding="{Binding GrandTotal, StringFormat={}{0:N2}}"
                                            Width="*"/>
                        <DataGridTextColumn Header="Note"
                                            Binding="{Binding Note}"
                                            Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- ============================================================ -->
                <!-- DATA GRID - PRODUCT MODE                                     -->
                <!-- ============================================================ -->
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding ProductReports}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          AlternatingRowBackground="#F9F9F9"
                          GridLinesVisibility="Horizontal"
                          BorderBrush="#E0E0E0"
                          BorderThickness="1"
                          RowHeaderWidth="0"
                          FontSize="13"
                          Visibility="{Binding ProductGridVisibility}">

                    <DataGrid.Resources>
                        <Style x:Key="ReportColumnHeaderStyle" TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F3F4F6"/>
                            <Setter Property="Foreground" Value="#374151"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter Property="BorderBrush" Value="#E5E7EB"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        </Style>
                        <Style x:Key="ReportCellStyle" TargetType="DataGridCell">
                            <Setter Property="Padding" Value="10,6"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Receipt Number"
                                            Binding="{Binding ReceiptNumber}"
                                            Width="*"/>
                        <DataGridTextColumn Header="Date &#38; Time"
                                            Binding="{Binding TransactionDate, StringFormat={}{0:g}}"
                                            Width="*"/>
                        <DataGridTextColumn Header="Payment Method"
                                            Binding="{Binding PaymentMethod}"
                                            Width="*"/>
                        <DataGridTextColumn Header="Quantity"
                                            Binding="{Binding Quantity}"
                                            Width="*"/>
                        <DataGridTextColumn Header="Line Total"
                                            Binding="{Binding LineTotal, StringFormat={}{0:N2}}"
                                            Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>

            </Grid>
        </Border>

    </Grid>
</UserControl>