<UserControl x:Class="UI.Views.ReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:UI.Controls"
             Background="#F5F6FA">

    <UserControl.Resources>
        <!-- Shared DataGrid column header style (applied to both report grids) -->
        <Style x:Key="ReportColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F3F4F6"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>

        <!-- Shared DataGrid cell style (applied to both report grids) -->
        <Style x:Key="ReportCellStyle" TargetType="DataGridCell">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ============================================================ -->
        <!-- 1. HEADER + FILTER SECTION                                   -->
        <!-- ============================================================ -->
        <Border Background="#FFFFFF"
                Padding="14"
                CornerRadius="6">
            <StackPanel>
                <!-- Title + Mode Toggle + Action Buttons -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="{DynamicResource Manager.Reports.Title}"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#333333"
                               VerticalAlignment="Center"/>

                    <!-- Keyboard shortcut hints -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                        <StackPanel Style="{StaticResource ShortcutChip}">
                            <Border Style="{StaticResource ShortcutKeyCap}">
                                <TextBlock Text="{Binding GenerateGesture, Mode=OneWay}" Style="{StaticResource ShortcutKeyText}"/>
                            </Border>
                            <TextBlock Text="{DynamicResource Shortcut.Generate}" Style="{StaticResource ShortcutLabelText}"/>
                        </StackPanel>
                        <StackPanel Style="{StaticResource ShortcutChip}">
                            <Border Style="{StaticResource ShortcutKeyCap}">
                                <TextBlock Text="{Binding ExportGesture, Mode=OneWay}" Style="{StaticResource ShortcutKeyText}"/>
                            </Border>
                            <TextBlock Text="{DynamicResource Shortcut.Export}" Style="{StaticResource ShortcutLabelText}"/>
                        </StackPanel>
                        <StackPanel Style="{StaticResource ShortcutChip}">
                            <Border Style="{StaticResource ShortcutKeyCap}">
                                <TextBlock Text="{Binding PrintGesture, Mode=OneWay}" Style="{StaticResource ShortcutKeyText}"/>
                            </Border>
                            <TextBlock Text="{DynamicResource Shortcut.Print}" Style="{StaticResource ShortcutLabelText}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Report Mode Toggle + Action Buttons -->
                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <RadioButton Content="{DynamicResource Manager.Reports.SalesMode}"
                                     GroupName="ReportMode"
                                     IsChecked="{Binding IsSalesMode}"
                                     Margin="0,0,12,0"
                                     FontSize="13"
                                     Foreground="#555555"/>
                        <RadioButton Content="{DynamicResource Manager.Reports.ProductMode}"
                                     GroupName="ReportMode"
                                     IsChecked="{Binding IsProductMode}"
                                     Margin="0,0,16,0"
                                     FontSize="13"
                                     Foreground="#555555"/>

                        <Button Content="{DynamicResource Manager.Reports.GenerateExport}"
                                Command="{Binding ReportCommand}"
                                CommandParameter="GenerateAndExport"
                                Padding="14,6"
                                FontSize="12"
                                FontWeight="SemiBold"
                                Background="#1565C0"
                                Foreground="White"
                                BorderThickness="0"
                                Cursor="Hand"/>
                    </StackPanel>
                </Grid>

                <!-- Filter Period Buttons -->
                <Border BorderBrush="#E0E0E0"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="10,8"
                        Margin="0,10,0,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="{DynamicResource Common.Today}"
                                    Command="{Binding FilterTodayCommand}"
                                    Padding="14,6"
                                    Margin="0,0,8,0"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Background="#EEF0F2"
                                    Foreground="#1F2328"
                                    BorderThickness="0"
                                    Cursor="Hand"/>
                            <Button Content="{DynamicResource Common.ThisWeek}"
                                    Command="{Binding FilterThisWeekCommand}"
                                    Padding="14,6"
                                    Margin="0,0,8,0"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Background="#EEF0F2"
                                    Foreground="#1F2328"
                                    BorderThickness="0"
                                    Cursor="Hand"/>
                            <Button Content="{DynamicResource Common.ThisMonth}"
                                    Command="{Binding FilterMonthCommand}"
                                    Padding="14,6"
                                    Margin="0,0,8,0"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Background="#EEF0F2"
                                    Foreground="#1F2328"
                                    BorderThickness="0"
                                    Cursor="Hand"/>
                            <Button Content="{DynamicResource Common.Period}"
                                    Command="{Binding ShowPeriodFilterCommand}"
                                    Padding="14,6"
                                    Margin="0,0,0,0"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Background="#1565C0"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Cursor="Hand"/>

                            <controls:PeriodFilterPanel FilterVisibility="{Binding IsPeriodFilterVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                                                        FromDate="{Binding FromDate, Mode=TwoWay}"
                                                        ToDate="{Binding ToDate, Mode=TwoWay}"
                                                        ApplyCommand="{Binding ApplyPeriodFilterCommand}"
                                                        Margin="12,0,0,0"/>

                            <!-- Product ComboBox (only visible in Product Mode) -->
                            <StackPanel Orientation="Horizontal"
                                        Visibility="{Binding ProductGridVisibility}"
                                        Margin="12,0,0,0">
                                <TextBlock Text="{DynamicResource Manager.Reports.ProductLabel}" VerticalAlignment="Center" Margin="0,0,6,0"
                                           Foreground="#6B7280" FontSize="12"/>
                                <ComboBox ItemsSource="{Binding Products}"
                                          SelectedItem="{Binding SelectedProduct}"
                                          Width="140"
                                          DisplayMemberPath="Name"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- ============================================================ -->
        <!-- 2. MAIN CONTENT (SUMMARY + DATA GRID)                        -->
        <!-- ============================================================ -->
        <Border Grid.Row="2"
                Margin="0,10,0,0"
                Background="#FFFFFF"
                Padding="14"
                CornerRadius="6"
                BorderBrush="#E0E0E0"
                BorderThickness="1">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- ============================================================ -->
                <!-- SUMMARY SECTION (CARD STYLE - SALES MODE)                    -->
                <!-- ============================================================ -->
                <Border BorderBrush="#E0E0E0"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="14"
                        Margin="0,0,0,12"
                        Visibility="{Binding SalesSummaryVisibility}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border BorderBrush="#EEF2FF"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="12"
                                Margin="4"
                                Background="#F8FAFF">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Manager.Reports.TotalOrders}"
                                           FontSize="11"
                                           Foreground="#6B7280"/>
                                <TextBlock Text="{Binding TotalOrders}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="#333333"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1"
                                BorderBrush="#EEF2FF"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="12"
                                Margin="4"
                                Background="#F8FAFF">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Manager.Reports.TotalSales}"
                                           FontSize="11"
                                           Foreground="#6B7280"/>
                                <TextBlock Text="{Binding TotalSales}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="#333333"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2"
                                BorderBrush="#EEF2FF"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="12"
                                Margin="4"
                                Background="#F8FAFF">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Manager.Reports.CashTotal}"
                                           FontSize="11"
                                           Foreground="#6B7280"/>
                                <TextBlock Text="{Binding CashTotal}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="#333333"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="3"
                                BorderBrush="#EEF2FF"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="12"
                                Margin="4"
                                Background="#F8FAFF">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Manager.Reports.CardTotal}"
                                           FontSize="11"
                                           Foreground="#6B7280"/>
                                <TextBlock Text="{Binding CardTotal}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="#333333"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- ============================================================ -->
                <!-- SUMMARY SECTION (CARD STYLE - PRODUCT MODE)                  -->
                <!-- ============================================================ -->
                <Border BorderBrush="#E0E0E0"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="14"
                        Margin="0,0,0,12"
                        Visibility="{Binding ProductSummaryVisibility}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border BorderBrush="#EEF2FF"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="12"
                                Margin="4"
                                Background="#F8FAFF">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Manager.Reports.TotalQuantitySold}"
                                           FontSize="11"
                                           Foreground="#6B7280"/>
                                <TextBlock Text="{Binding TotalQuantitySold}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="#333333"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1"
                                BorderBrush="#EEF2FF"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="12"
                                Margin="4"
                                Background="#F8FAFF">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Manager.Reports.TotalRevenue}"
                                           FontSize="11"
                                           Foreground="#6B7280"/>
                                <TextBlock Text="{Binding TotalRevenue}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="#333333"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2"
                                BorderBrush="#EEF2FF"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="12"
                                Margin="4"
                                Background="#F8FAFF">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Manager.Reports.AveragePrice}"
                                           FontSize="11"
                                           Foreground="#6B7280"/>
                                <TextBlock Text="{Binding AveragePrice}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="#333333"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- ============================================================ -->
                <!-- DATA GRID - SALES MODE                                       -->
                <!-- ============================================================ -->
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding TransactionReports}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          AlternatingRowBackground="#F9F9F9"
                          GridLinesVisibility="Horizontal"
                          BorderBrush="#E0E0E0"
                          BorderThickness="1"
                          RowHeaderWidth="0"
                          FontSize="13"
                          ColumnHeaderStyle="{StaticResource ReportColumnHeaderStyle}"
                          CellStyle="{StaticResource ReportCellStyle}"
                          Visibility="{Binding SalesGridVisibility}">

                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="{DynamicResource Manager.Reports.ColReceiptNumber}"
                                                Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding ReceiptNumber}"
                                            FontSize="13"
                                            Cursor="Hand"
                                            HorizontalAlignment="Left"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="0"
                                            Foreground="#1A6FC4"
                                            Command="{Binding DataContext.OpenReceiptCommand,
                                                      RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="#DBEEFF" CornerRadius="4" Padding="7,2">
                                                    <ContentPresenter HorizontalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="{DynamicResource Manager.Reports.ColDateTime}"
                                            Binding="{Binding TransactionDate, StringFormat={}{0:g}}"
                                            Width="*"/>
                        <DataGridTextColumn Header="{DynamicResource Manager.Reports.ColPaymentMethod}"
                                            Binding="{Binding PaymentMethod}"
                                            Width="*"/>
                        <DataGridTextColumn Header="{DynamicResource Manager.Reports.ColGrandTotal}"
                                            Binding="{Binding GrandTotal, StringFormat={}{0:N2}}"
                                            Width="*"/>
                        <DataGridTextColumn Header="{DynamicResource Manager.Reports.ColNote}"
                                            Binding="{Binding Note}"
                                            Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- ============================================================ -->
                <!-- DATA GRID - PRODUCT MODE                                     -->
                <!-- ============================================================ -->
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding ProductReports}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          AlternatingRowBackground="#F9F9F9"
                          GridLinesVisibility="Horizontal"
                          BorderBrush="#E0E0E0"
                          BorderThickness="1"
                          RowHeaderWidth="0"
                          FontSize="13"
                          ColumnHeaderStyle="{StaticResource ReportColumnHeaderStyle}"
                          CellStyle="{StaticResource ReportCellStyle}"
                          Visibility="{Binding ProductGridVisibility}">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{DynamicResource Manager.Reports.ColReceiptNumber}"
                                            Binding="{Binding ReceiptNumber}"
                                            Width="*"/>
                        <DataGridTextColumn Header="{DynamicResource Manager.Reports.ColDateTime}"
                                            Binding="{Binding TransactionDate, StringFormat={}{0:g}}"
                                            Width="*"/>
                        <DataGridTextColumn Header="{DynamicResource Manager.Reports.ColPaymentMethod}"
                                            Binding="{Binding PaymentMethod}"
                                            Width="*"/>
                        <DataGridTextColumn Header="{DynamicResource Manager.Reports.ColQuantity}"
                                            Binding="{Binding Quantity}"
                                            Width="*"/>
                        <DataGridTextColumn Header="{DynamicResource Manager.Reports.ColLineTotal}"
                                            Binding="{Binding LineTotal, StringFormat={}{0:N2}}"
                                            Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>

            </Grid>
        </Border>

    </Grid>
</UserControl>
