<UserControl x:Class="UI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:localization="clr-namespace:POS.Contracts.Localization;assembly=Contracts"
             xmlns:vm="clr-namespace:UI.ViewModels"
             xmlns:views="clr-namespace:UI.Views"
             mc:Ignorable="d"
             d:DesignWidth="400" d:DesignHeight="600">

    <UserControl.Resources>
        <DataTemplate DataType="{x:Type vm:KeyboardShortcutsViewModel}">
            <views:KeyboardShortcutsView/>
        </DataTemplate>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style x:Key="SectionSubHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="OutlineBtn" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" CornerRadius="7" Background="White"
                                BorderBrush="#CBD5E1" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#F1F5F9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- Main settings panel (hidden when keyboard shortcuts are shown) -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding IsNotKeyboardShortcutsVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Title -->
                <TextBlock Grid.Row="0"
                           Text="{DynamicResource Settings.Title}"
                           FontSize="22" FontWeight="Bold"
                           Foreground="#0F172A"
                           Margin="0,0,0,20"/>

                <!-- Language Selection -->
                <StackPanel Grid.Row="1">
                    <TextBlock Text="{DynamicResource Settings.Language}"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="#334155"
                               Margin="0,0,0,10"/>

                    <ListBox ItemsSource="{Binding SupportedLanguages}"
                             SelectedItem="{Binding SelectedLanguage}"
                             DisplayMemberPath="DisplayName"
                             FontSize="16"
                             Height="Auto"
                             BorderBrush="#CBD5E1"
                             BorderThickness="1">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="14,10"/>
                                <Setter Property="Cursor" Value="Hand"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </StackPanel>

                <!-- Printing Settings -->
                <StackPanel Grid.Row="2" Margin="0,24,0,0">
                    <TextBlock Text="{DynamicResource Settings.Printing}"
                               FontSize="18" FontWeight="Bold"
                               Foreground="#0F172A"
                               Margin="0,0,0,16"/>

                    <!-- Receipt Printer -->
                    <TextBlock Text="{DynamicResource Settings.ReceiptPrinter}"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="#334155"
                               Margin="0,0,0,6"/>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <ComboBox Grid.Column="0"
                                  ItemsSource="{Binding AvailablePrinters}"
                                  SelectedItem="{Binding SelectedReceiptPrinter}"
                                  FontSize="14"
                                  Height="32"
                                  VerticalContentAlignment="Center"/>

                        <Button Grid.Column="1"
                                Content="{DynamicResource Settings.Refresh}"
                                Width="80" Height="32"
                                Margin="8,0,0,0"
                                Command="{Binding RefreshPrintersCommand}"
                                FontSize="12"/>
                    </Grid>

                    <!-- Paper Width -->
                    <TextBlock Text="{DynamicResource Settings.PaperWidth}"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="#334155"
                               Margin="0,0,0,6"/>

                    <ComboBox ItemsSource="{Binding PaperWidthOptions}"
                              SelectedItem="{Binding PaperWidth}"
                              FontSize="14"
                              Height="32"
                              VerticalContentAlignment="Center"
                              Margin="0,0,0,12"/>

                    <!-- Auto Print -->
                    <CheckBox Content="{DynamicResource Settings.AutoPrintAfterPayment}"
                              IsChecked="{Binding AutoPrint}"
                              FontSize="14"
                              Margin="0,0,0,8"/>

                    <!-- Show Print Dialog -->
                    <CheckBox Content="{DynamicResource Settings.ShowWindowsPrintDialog}"
                              IsChecked="{Binding ShowPrintDialog}"
                              FontSize="14"
                              Margin="0,0,0,8"/>

                    <!-- Copies -->
                    <TextBlock Text="{DynamicResource Settings.Copies}"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="#334155"
                               Margin="0,0,0,6"/>

                    <TextBox Text="{Binding Copies, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="14"
                             Width="60" Height="32"
                             VerticalContentAlignment="Center"
                             Margin="0,0,0,12"/>

                    <!-- Test Print -->
                    <Button Content="{DynamicResource Settings.PrintTestReceipt}"
                            Width="160" Height="36"
                            Background="#3B82F6" Foreground="White"
                            FontSize="12"
                            HorizontalAlignment="Left"
                            Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Keyboard Shortcuts Section (Manager only) -->
                <StackPanel Grid.Row="3" Margin="0,24,0,0"
                            Visibility="{Binding IsManager, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="{DynamicResource Settings.KeyboardShortcuts}"
                               Style="{StaticResource SectionHeader}"/>

                    <TextBlock Text="{DynamicResource Settings.KeyboardShortcutsDescription}"
                               FontSize="13" Foreground="#64748B"
                               Margin="0,0,0,12"/>

                    <Button Style="{StaticResource OutlineBtn}"
                            HorizontalAlignment="Left"
                            Command="{Binding OpenKeyboardShortcutsCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x2328;" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock Text="{DynamicResource Settings.ConfigureKeyboardShortcuts}" FontSize="13"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Close Button -->
                <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
                    <Button Content="{DynamicResource Common.Close}"
                            Width="100" Height="38"
                            Background="#E2E8F0" Foreground="#0F172A"
                            Command="{Binding CloseCommand}"
                            FontSize="12"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- Keyboard Shortcuts View (shown when activated) -->
        <Border Visibility="{Binding IsKeyboardShortcutsVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Back Button -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="20,16,20,0">
                    <Button Style="{StaticResource OutlineBtn}"
                            Margin="0,0,12,0"
                            Click="BackButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x2190;" FontSize="14" Margin="0,0,6,0"/>
                            <TextBlock Text="{DynamicResource Settings.BackToSettings}" FontSize="13"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Keyboard Shortcuts Content -->
                <ContentControl Grid.Row="1"
                                Content="{Binding KeyboardShortcuts}"
                                Margin="20,8,20,20"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
