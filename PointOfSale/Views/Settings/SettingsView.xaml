<UserControl x:Class="UI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:localization="clr-namespace:POS.Contracts.Localization;assembly=Contracts"
             mc:Ignorable="d"
             d:DesignWidth="400" d:DesignHeight="300">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="Settings"
                   FontSize="22" FontWeight="Bold"
                   Foreground="#0F172A"
                   Margin="0,0,0,20"/>

        <!-- Language Selection -->
        <StackPanel Grid.Row="1">
            <TextBlock Text="Language"
                       FontSize="14" FontWeight="SemiBold"
                       Foreground="#334155"
                       Margin="0,0,0,10"/>

            <ListBox ItemsSource="{Binding SupportedLanguages}"
                     SelectedItem="{Binding SelectedLanguage}"
                     DisplayMemberPath="DisplayName"
                     FontSize="16"
                     Height="Auto"
                     BorderBrush="#CBD5E1"
                     BorderThickness="1">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="14,10"/>
                        <Setter Property="Cursor" Value="Hand"/>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </StackPanel>

        <!-- Close Button -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Close"
                    Width="100" Height="38"
                    Background="#E2E8F0" Foreground="#0F172A"
                    Command="{Binding CloseCommand}"
                    FontSize="12"/>
        </StackPanel>
    </Grid>
</UserControl>