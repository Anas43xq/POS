<UserControl x:Class="UI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:localization="clr-namespace:POS.Contracts.Localization;assembly=Contracts"
             mc:Ignorable="d"
             d:DesignWidth="400" d:DesignHeight="600">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <TextBlock Grid.Row="0"
                       Text="{DynamicResource Settings.Title}"
                       FontSize="22" FontWeight="Bold"
                       Foreground="#0F172A"
                       Margin="0,0,0,20"/>

            <!-- Language Selection -->
            <StackPanel Grid.Row="1">
                <TextBlock Text="{DynamicResource Settings.Language}"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="#334155"
                           Margin="0,0,0,10"/>

                <ListBox ItemsSource="{Binding SupportedLanguages}"
                         SelectedItem="{Binding SelectedLanguage}"
                         DisplayMemberPath="DisplayName"
                         FontSize="16"
                         Height="Auto"
                         BorderBrush="#CBD5E1"
                         BorderThickness="1">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="14,10"/>
                            <Setter Property="Cursor" Value="Hand"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </StackPanel>

            <!-- Printing Settings -->
            <StackPanel Grid.Row="2" Margin="0,24,0,0">
                <TextBlock Text="Printing"
                           FontSize="18" FontWeight="Bold"
                           Foreground="#0F172A"
                           Margin="0,0,0,16"/>

                <!-- Receipt Printer -->
                <TextBlock Text="Receipt Printer"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="#334155"
                           Margin="0,0,0,6"/>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <ComboBox Grid.Column="0"
                              ItemsSource="{Binding AvailablePrinters}"
                              SelectedItem="{Binding SelectedReceiptPrinter}"
                              FontSize="14"
                              Height="32"
                              VerticalContentAlignment="Center"/>

                    <Button Grid.Column="1"
                            Content="Refresh"
                            Width="80" Height="32"
                            Margin="8,0,0,0"
                            Command="{Binding RefreshPrintersCommand}"
                            FontSize="12"/>
                </Grid>

                <!-- Paper Width -->
                <TextBlock Text="Paper Width"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="#334155"
                           Margin="0,0,0,6"/>

                <ComboBox ItemsSource="{Binding PaperWidthOptions}"
                          SelectedItem="{Binding PaperWidth}"
                          FontSize="14"
                          Height="32"
                          VerticalContentAlignment="Center"
                          Margin="0,0,0,12"/>

                <!-- Auto Print -->
                <CheckBox Content="Auto Print After Payment"
                          IsChecked="{Binding AutoPrint}"
                          FontSize="14"
                          Margin="0,0,0,8"/>

                <!-- Show Print Dialog -->
                <CheckBox Content="Show Windows Print Dialog"
                          IsChecked="{Binding ShowPrintDialog}"
                          FontSize="14"
                          Margin="0,0,0,8"/>

                <!-- Copies -->
                <TextBlock Text="Copies"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="#334155"
                           Margin="0,0,0,6"/>

                <TextBox Text="{Binding Copies, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="14"
                         Width="60" Height="32"
                         VerticalContentAlignment="Center"
                         Margin="0,0,0,12"/>

                <!-- Test Print -->
                <Button Content="Print Test Receipt"
                        Width="160" Height="36"
                        Background="#3B82F6" Foreground="White"
                        FontSize="12"
                        HorizontalAlignment="Left"
                        Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Close Button -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
                <Button Content="{DynamicResource Common.Close}"
                        Width="100" Height="38"
                        Background="#E2E8F0" Foreground="#0F172A"
                        Command="{Binding CloseCommand}"
                        FontSize="12"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
