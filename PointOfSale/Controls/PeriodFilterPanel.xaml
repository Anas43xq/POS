<UserControl x:Class="UI.Controls.PeriodFilterPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="root">
    <StackPanel Orientation="Horizontal"
                Visibility="{Binding FilterVisibility, ElementName=root}">
        <TextBlock Text="{Binding FromLabel, ElementName=root}"
                   VerticalAlignment="Center"
                   Margin="0,0,6,0"
                   Foreground="#6B7280"
                   FontSize="12"/>
        <DatePicker SelectedDate="{Binding FromDate, ElementName=root}"
                    Width="115"
                    Margin="0,0,12,0"/>
        <TextBlock Text="{Binding ToLabel, ElementName=root}"
                   VerticalAlignment="Center"
                   Margin="0,0,6,0"
                   Foreground="#6B7280"
                   FontSize="12"/>
        <DatePicker SelectedDate="{Binding ToDate, ElementName=root}"
                    Width="115"
                    Margin="0,0,12,0"/>
        <Button Content="{Binding ApplyButtonText, ElementName=root}"
                Command="{Binding ApplyCommand, ElementName=root}"
                Padding="14,6"
                FontSize="12"
                FontWeight="SemiBold"
                Background="#1565C0"
                Foreground="White"
                BorderThickness="0"
                Cursor="Hand"
                Margin="0"/>
    </StackPanel>
</UserControl>
